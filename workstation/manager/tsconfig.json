{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["bun-types"],
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": ["electrobun.config.ts", "app/**/*.ts", "app/**/*.d.ts"]
}
