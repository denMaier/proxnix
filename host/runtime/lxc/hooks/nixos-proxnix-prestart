#!/bin/bash
# LXC pre-start hook: render proxnix's desired guest state on the host.
#
# Registered automatically for every ostype=nixos container via
# nixos.common.conf / nixos.userns.conf. Runs after lxc-pve-prestart-hook so
# the PVE config is available, but before the rootfs mount is required.
# The same script can also be invoked directly by local harnesses with
# --vmid/--pve-conf so they reuse the real hook logic instead of duplicating it.
#
# This hook does not touch the guest rootfs directly. It stages the desired
# state under /run/proxnix/<vmid>/. NixOS config is staged for the host build
# path only; the matching mount hook injects only guest-consumed runtime assets:
#   bind/runtime/{current-config-hash,vmid}      # diagnostic markers
#   bind/secrets/{effective.sops.yaml,identity}   # copied into the guest
#   copy/runtime/bin/*.{sh,py}
# Config hashes remain diagnostic metadata; host-side reconciliation owns
# activation by exact NixOS system path.

set -uo pipefail
umask 077  # staging starts private; config binds are relaxed later, secrets stay host-root only

VMID=""
PVE_CONF_OVERRIDE=""
PROXNIX_LIB_DIR="/usr/local/lib/proxnix"
PROXNIX_SECRETS_GUEST_BIN="${PROXNIX_LIB_DIR}/proxnix-secrets-guest"
COMMON_LIB="${PROXNIX_LIB_DIR}/nixos-proxnix-common.sh"
START_SECONDS=$SECONDS

log() {
    local message="[proxnix-prestart][${VMID:-unknown}] $*"
    echo "$message" >&2
    if command -v logger >/dev/null 2>&1; then
        logger -t proxnix-prestart -- "$message"
    fi
}

usage() {
    cat <<'EOF'
Usage:
  nixos-proxnix-prestart
  nixos-proxnix-prestart <vmid> lxc pre-start
  nixos-proxnix-prestart --vmid <vmid> [--pve-conf </path/to/lxc.conf>]

When invoked without arguments, this script behaves like the normal LXC
pre-start hook and reads the VMID from LXC_NAME. LXC/Proxmox may also pass
the VMID and hook metadata as positional arguments.
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --vmid)
            [[ $# -ge 2 ]] || { echo "ERROR: --vmid requires a value" >&2; exit 1; }
            VMID="$2"
            shift 2
            ;;
        --pve-conf)
            [[ $# -ge 2 ]] || { echo "ERROR: --pve-conf requires a value" >&2; exit 1; }
            PVE_CONF_OVERRIDE="$2"
            shift 2
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        lxc|pre-start)
            shift
            ;;
        *)
            if [[ -z "$VMID" ]]; then
                VMID="$1"
                shift
            else
                echo "ERROR: unknown argument: $1" >&2
                usage >&2
                exit 1
            fi
            ;;
    esac
done

if [[ -z "$VMID" ]]; then
    VMID="${LXC_NAME:-}"
fi

if [[ -z "$VMID" ]]; then
    log "ERROR: VMID not set (pass --vmid or export LXC_NAME)."
    exit 1
fi

if [[ ! -f "$COMMON_LIB" ]]; then
    log "ERROR: ${COMMON_LIB} not found."
    log "Run host/deploy/ansible/install.yml for this Proxmox node to install local runtime files."
    exit 1
fi

# shellcheck source=/dev/null
source "$COMMON_LIB"

PVE_CONF_TO_NIX="${PROXNIX_LIB_DIR}/pve-conf-to-nix.py"
CONTAINER_TEMPLATE_DIR="${NIXLXC_DIR}/containers/_template"
CONTAINER_DIR="${NIXLXC_DIR}/containers/${VMID}"
CONTAINER_PRIV_DIR="${NIXLXC_PRIV_DIR}/containers/${VMID}"
TEMPLATE_SELECTOR_DIR="${CONTAINER_DIR}/templates"
DROPIN_DIR="${CONTAINER_DIR}/dropins"
STAGE_DIR="$(proxnix_stage_dir "$VMID")"
BIND_STAGE_DIR="${STAGE_DIR}/bind"
BIND_CONFIG_DIR="${BIND_STAGE_DIR}/config"
MANAGED_DIR="${BIND_CONFIG_DIR}/managed"
MANAGED_DROPIN_DIR="${MANAGED_DIR}/dropins"
MANAGED_TEMPLATE_DIR="${MANAGED_DIR}/_template"
BIND_RUNTIME_DIR="${BIND_STAGE_DIR}/runtime"
SECRETS_STAGE_DIR="${BIND_STAGE_DIR}/secrets"
COPY_STAGE_DIR="${STAGE_DIR}/copy"
COPY_RUNTIME_DIR="${COPY_STAGE_DIR}/runtime"
COPY_RUNTIME_BIN_DIR="${COPY_RUNTIME_DIR}/bin"
PVE_CONF="${PVE_CONF_OVERRIDE:-/etc/pve/lxc/${VMID}.conf}"

cleanup_stage() {
    rm -rf "$STAGE_DIR"
}

finish_prestart() {
    local status=$?
    local elapsed=$((SECONDS - START_SECONDS))
    if [[ $status -eq 0 ]]; then
        log "Finished pre-start hook in ${elapsed}s."
    else
        log "ERROR: pre-start hook failed after ${elapsed}s; removing incomplete stage ${STAGE_DIR}."
        cleanup_stage
    fi
    exit "$status"
}

trap finish_prestart EXIT

run_prestart_build() {
    if [[ "${PROXNIX_PRESTART_BUILD:-1}" == "0" ]]; then
        log "Skipping pre-start build because PROXNIX_PRESTART_BUILD=0."
        return
    fi
    if [[ "${PROXNIX_PRESTART_GOLDEN_BUILD:-1}" != "0" ]]; then
        if command -v proxnix-reconcile-build-golden >/dev/null 2>&1; then
            if proxnix-reconcile-build-golden; then
                log "Golden-template build completed or was already current."
            else
                log "WARN: golden-template build failed; continuing with the VMID-specific build."
            fi
        else
            log "WARN: proxnix-reconcile-build-golden is unavailable; continuing with the VMID-specific build."
        fi
    fi
    if ! command -v proxnix-reconcile-build >/dev/null 2>&1; then
        log "WARN: proxnix-reconcile-build is unavailable; container will start with the last seeded generation."
        return
    fi
    if ! proxnix-reconcile-build --vmid "$VMID"; then
        log "WARN: pre-start build failed; container will start with the last seeded generation."
        return
    fi
    log "Pre-start build completed or was already current."
}

log "Starting pre-start hook (PVE conf: ${PVE_CONF}, stage: ${STAGE_DIR})."

if [[ ! -f "$PVE_CONF_TO_NIX" ]]; then
    log "ERROR: ${PVE_CONF_TO_NIX} not found."
    log "Run host/deploy/ansible/install.yml for this Proxmox node to install local runtime files."
    exit 1
fi

if ! command -v sops >/dev/null 2>&1; then
    log "ERROR: sops not found on the Proxmox host."
    log "Install sops on the host; proxnix now decrypts relay-encrypted guest identities during pre-start."
    exit 1
fi

log "Preparing fresh stage directory."
cleanup_stage
mkdir -p \
    "$MANAGED_DROPIN_DIR" \
    "$BIND_RUNTIME_DIR" \
    "$SECRETS_STAGE_DIR" \
    "$COPY_RUNTIME_BIN_DIR"

log "Checking shared host-managed Nix files."
for f in "${PROXNIX_SHARED_FILES[@]}"; do
    src="${NIXLXC_DIR}/${f}"
    if [[ ! -f "$src" ]]; then
        log "ERROR: missing required shared file: ${src}"
    log "Run host/deploy/ansible/install.yml for this Proxmox node to restore proxnix shared files."
        exit 1
    fi
done

if [[ ! -f "$PROXNIX_SECRETS_GUEST_BIN" ]]; then
    log "ERROR: ${PROXNIX_SECRETS_GUEST_BIN} not found."
    log "Run host/deploy/ansible/install.yml for this Proxmox node to restore proxnix runtime helpers."
    exit 1
fi

log "Copying shared managed config into stage."
cp "${NIXLXC_DIR}/configuration.nix" "${BIND_CONFIG_DIR}/configuration.nix"
cp "${NIXLXC_DIR}/base.nix"          "${MANAGED_DIR}/base.nix"
cp "${NIXLXC_DIR}/common.nix"        "${MANAGED_DIR}/common.nix"
cp "${NIXLXC_DIR}/security-policy.nix" "${MANAGED_DIR}/security-policy.nix"
if [[ -f "${NIXLXC_DIR}/site.nix" ]]; then
    cp "${NIXLXC_DIR}/site.nix"      "${MANAGED_DIR}/site.nix"
    log "Included optional site.nix."
else
    log "No optional site.nix present."
fi

for legacy_yaml in "${CONTAINER_DIR}/proxmox.yaml" "${CONTAINER_DIR}/user.yaml"; do
    if [[ -f "$legacy_yaml" ]]; then
        log "ERROR: legacy YAML config is no longer supported: ${legacy_yaml}"
        log "Move container config into ${CONTAINER_DIR}/dropins/*.nix and keep base identity in the Proxmox CT config."
        exit 1
    fi
done

log "Rendering Proxmox CT config into managed/proxmox.nix."
if ! python3 "$PVE_CONF_TO_NIX" --pve-conf "$PVE_CONF" --out-dir "$MANAGED_DIR"; then
    log "ERROR: pve-conf-to-nix.py failed — check ${PVE_CONF}"
    exit 1
fi
log "Rendered Proxmox CT config."

if [[ -d "${CONTAINER_DIR}/quadlets" ]] && find "${CONTAINER_DIR}/quadlets" -mindepth 1 -maxdepth 1 -print -quit | grep -q .; then
    log "ERROR: raw quadlet passthrough is no longer supported: ${CONTAINER_DIR}/quadlets"
    log "Move Podman workloads into dropins/*.nix via site-managed Nix imports."
    exit 1
fi

if [[ -d "$TEMPLATE_SELECTOR_DIR" ]]; then
    if [[ ! -d "$CONTAINER_TEMPLATE_DIR" ]]; then
        log "ERROR: ${TEMPLATE_SELECTOR_DIR} exists but ${CONTAINER_TEMPLATE_DIR} is missing."
        exit 1
    fi

    template_count=0
    while IFS= read -r -d '' selector; do
        selector_name="$(basename "$selector")"
        template_name="${selector_name%.template}"
        template_source="${CONTAINER_TEMPLATE_DIR}/${template_name}"

        if [[ ! -d "$template_source" ]]; then
            log "ERROR: selected template not found: ${template_source}"
            exit 1
        fi

        mkdir -p "$MANAGED_TEMPLATE_DIR"
        cp -a "$template_source" "${MANAGED_TEMPLATE_DIR}/${template_name}"
        log "Included template: ${template_name}"
        template_count=$((template_count + 1))
    done < <(find "$TEMPLATE_SELECTOR_DIR" -maxdepth 1 -type f -name '*.template' -print0 2>/dev/null | sort -z)
    log "Processed ${template_count} selected template(s)."
else
    log "No container template selectors found."
fi

if [[ -d "$DROPIN_DIR" ]]; then
    nix_dropin_count=0
    script_dropin_count=0
    dir_dropin_count=0
    while IFS= read -r -d '' f; do
        fname="$(basename "$f")"
        case "$fname" in
            *.nix)
                cp "$f" "${MANAGED_DROPIN_DIR}/${fname}"
                nix_dropin_count=$((nix_dropin_count + 1))
                ;;
            *.service)
                log "ERROR: host-side dropins/*.service are no longer supported: ${f}"
                log "Move service definitions into dropins/*.nix so they are guest Nix-managed."
                exit 1
                ;;
            *.sh|*.py)
                cp "$f" "${COPY_RUNTIME_BIN_DIR}/${fname}"
                script_dropin_count=$((script_dropin_count + 1))
                ;;
            *.container|*.volume|*.network|*.pod|*.image|*.build)
                log "ERROR: raw Quadlet drop-ins are no longer supported: ${f}"
                log "Move Podman workloads into dropins/*.nix via site-managed Nix imports."
                exit 1
                ;;
            *)
                log "Ignored unknown drop-in type: ${fname}"
                ;;
        esac
    done < <(find "$DROPIN_DIR" -maxdepth 1 -type f -print0 2>/dev/null)

    while IFS= read -r -d '' d; do
        dname="$(basename "$d")"
        rm -rf "${MANAGED_DROPIN_DIR:?}/${dname}"
        cp -a "$d" "${MANAGED_DROPIN_DIR}/${dname}"
        dir_dropin_count=$((dir_dropin_count + 1))
    done < <(find "$DROPIN_DIR" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
    log "Processed drop-ins: ${nix_dropin_count} nix file(s), ${script_dropin_count} runtime script(s), ${dir_dropin_count} directory/directories."
else
    log "No container drop-ins found."
fi

DESIRED_CONFIG_HASH="$(proxnix_hash_tree "$BIND_CONFIG_DIR")"
log "Computed desired config hash: ${DESIRED_CONFIG_HASH}."

EFFECTIVE_SECRETS_FILE="${CONTAINER_PRIV_DIR}/effective.sops.yaml"

if [[ -f "$EFFECTIVE_SECRETS_FILE" ]]; then
    cp "$EFFECTIVE_SECRETS_FILE" "${SECRETS_STAGE_DIR}/effective.sops.yaml"
    log "Staged effective encrypted secrets store."
else
    log "No effective encrypted secrets store found."
fi

printf '%s' "$DESIRED_CONFIG_HASH" > "${BIND_RUNTIME_DIR}/current-config-hash"
printf '%s' "$VMID" > "${BIND_RUNTIME_DIR}/vmid"

cp "$PROXNIX_SECRETS_GUEST_BIN" "${COPY_RUNTIME_BIN_DIR}/proxnix-secrets"

CONTAINER_IDENTITY_STORE_PATH="$(proxnix_container_age_identity_store_path "$VMID")"
if [[ -f "$CONTAINER_IDENTITY_STORE_PATH" ]]; then
    log "Decrypting host-relay container identity for mount-time staging."
    if ! proxnix_decrypt_host_identity_store_to_file "$CONTAINER_IDENTITY_STORE_PATH" "${SECRETS_STAGE_DIR}/identity"; then
        log "ERROR: failed to decrypt host-relay container identity: ${CONTAINER_IDENTITY_STORE_PATH}"
        exit 1
    fi
    log "Staged decrypted container identity."
else
    log "No host-relay container identity store found."
fi

# Restrict staged content to the container's host-side root UID so the mount
# hook can read it. The secret files are still copied into the guest as
# root-owned regular files instead of being bind-mounted, so guest-visible
# ownership and permissions are enforced there rather than on the host stage.
HOST_SUBUID=""
if [[ -f "$PVE_CONF" ]]; then
    HOST_SUBUID=$(awk '/^lxc\.idmap: *u 0 / { print $4; exit }' "$PVE_CONF")
fi

if [[ -z "$HOST_SUBUID" && -f "$PVE_CONF" ]]; then
    if [[ "$(awk -F': *' '$1 == "unprivileged" { print $2; exit }' "$PVE_CONF")" == "1" ]]; then
        HOST_SUBUID="100000"
    else
        HOST_SUBUID="0"
    fi
fi

if [[ -n "$HOST_SUBUID" && "$HOST_SUBUID" =~ ^[0-9]+$ ]]; then
    log "Restricting staged files for container host root UID ${HOST_SUBUID}."
    chown -R "${HOST_SUBUID}" "${STAGE_DIR}"
    find "${STAGE_DIR}" -type d -exec chmod 700 {} +
    find "${STAGE_DIR}" -type f -exec chmod 400 {} +
    find "${COPY_RUNTIME_BIN_DIR}" -type f -exec chmod 500 {} + 2>/dev/null || true
else
    log "ERROR: could not determine container host root UID from ${PVE_CONF}"
    exit 1
fi

log "Rendered staged state at ${STAGE_DIR} (host root uid: ${HOST_SUBUID})"
run_prestart_build
exit 0
