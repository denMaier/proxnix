#!/usr/bin/env bash
# Build the host-local golden template closure used to warm the Nix store.

set -euo pipefail

SELF_NAME="${0##*/}"
NIXLXC_DIR="${PROXNIX_DIR:-/var/lib/proxnix}"
AUTHORITY_DIR="${PROXNIX_AUTHORITY_DIR:-${NIXLXC_DIR}/authority}"
PVE_LXC_DIR="${PROXNIX_PVE_LXC_DIR:-/etc/pve/lxc}"
GCROOT_DIR="${PROXNIX_GCROOT_DIR:-${NIXLXC_DIR}/gcroots/deploy}"
NODE_NAME="${PROXNIX_NODE_NAME:-$(hostname -s 2>/dev/null || hostname)}"
AUTHORITY_RENDER="${PROXNIX_AUTHORITY_RENDER:-/usr/local/sbin/proxnix-authority-render}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat >&2 <<EOF
Usage:
  ${SELF_NAME} [--node-name <name>]

Renders the host authority and builds
nixosConfigurations.proxnix-golden-template.config.system.build.toplevel.
The resulting closure is protected by a node-local GC root so later container
builds can reuse the common store paths.
EOF
}

die() {
  echo "error: $*" >&2
  exit 2
}

need_cmd() {
  local cmd="$1"
  command -v "$cmd" >/dev/null 2>&1 || die "${cmd} not found"
}

render_authority() {
  if [[ -x "$AUTHORITY_RENDER" ]]; then
    "$AUTHORITY_RENDER" \
      --root "$NIXLXC_DIR" \
      --authority "$AUTHORITY_DIR" \
      --pve-lxc-dir "$PVE_LXC_DIR" \
      --node-name "$NODE_NAME" >/dev/null
    return
  fi

  local proxnix_host="${PROXNIX_HOST_BIN:-/usr/local/sbin/proxnix-host}"
  if [[ -x "$proxnix_host" ]]; then
    "$proxnix_host" authority render \
      --root "$NIXLXC_DIR" \
      --authority "$AUTHORITY_DIR" \
      --pve-lxc-dir "$PVE_LXC_DIR" \
      --node-name "$NODE_NAME" >/dev/null
    return
  fi

  die "proxnix-authority-render not found"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --node-name)
      [[ $# -ge 2 ]] || die "--node-name requires a value"
      NODE_NAME="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

need_cmd nix
render_authority

mkdir -p "$GCROOT_DIR"
root_path="${GCROOT_DIR}/golden-template"

# `nix build --out-link <root>` writes a real Nix indirect gcroot in one step:
# the closure is pinned against nix-collect-garbage before the command returns,
# so we no longer need a separate `nix-store --realise --add-root --indirect`.
system_path="$(nix build --out-link "$root_path" --print-out-paths "${AUTHORITY_DIR}#nixosConfigurations.proxnix-golden-template.config.system.build.toplevel")"
system_path="$(tr -d '\r\n' <<<"$system_path")"
[[ -n "$system_path" ]] || die "nix build produced no output path"
printf 'golden-template built %s\n' "$system_path"
