#!/usr/bin/env bash
# Prune proxnix host-side transient state and stale deployment GC roots.

set -euo pipefail

SELF_NAME="${0##*/}"
RUN_DIR="${PROXNIX_RUN_DIR:-/run/proxnix}"
NIXLXC_DIR="${PROXNIX_DIR:-/var/lib/proxnix}"
GCROOT_DIR="${PROXNIX_GCROOT_DIR:-${NIXLXC_DIR}/gcroots/deploy}"
DRY_RUN=0

usage() {
  cat >&2 <<EOF
Usage:
  ${SELF_NAME} [--dry-run]

Removes copied/staged pre-start config directories from ${RUN_DIR} when the CT
is not running, preserves the golden-template GC root, and removes per-CT
desired closure GC roots for CTs that are no longer present on this host.
EOF
}

log() {
  echo "proxnix-gc: $*" >&2
}

remove_path() {
  local path="$1"
  if [[ "$DRY_RUN" == "1" ]]; then
    log "would remove ${path}"
  else
    rm -rf "$path"
  fi
}

pct_status() {
  local vmid="$1"
  command -v pct >/dev/null 2>&1 || return 1
  pct status "$vmid" 2>/dev/null
}

ct_exists_locally() {
  local vmid="$1"
  pct_status "$vmid" >/dev/null
}

ct_is_running() {
  local vmid="$1"
  pct_status "$vmid" | grep -q 'status: running'
}

prune_stage_dirs() {
  local dir vmid
  [[ -d "$RUN_DIR" ]] || return 0
  for dir in "$RUN_DIR"/*/; do
    [[ -d "$dir" ]] || continue
    vmid="$(basename "$dir")"
    if ct_is_running "$vmid"; then
      log "removed stale stage dir for running CT ${vmid}; build input is copied into the guest rootfs"
      remove_path "$dir"
      continue
    fi
    remove_path "$dir"
    log "removed stage dir for CT ${vmid}"
  done
}

prune_gc_roots() {
  local root name vmid
  [[ -d "$GCROOT_DIR" ]] || return 0
  for root in "$GCROOT_DIR"/*; do
    [[ -e "$root" || -L "$root" ]] || continue
    name="$(basename "$root")"
    case "$name" in
      golden-template)
        continue
        ;;
      *-desired)
        vmid="${name%-desired}"
        ;;
      *)
        continue
        ;;
    esac
    if [[ ! "$vmid" =~ ^[0-9]+$ ]]; then
      continue
    fi
    if ct_exists_locally "$vmid"; then
      continue
    fi
    remove_path "$root"
    log "removed stale desired closure GC root for CT ${vmid}"
  done
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "error: unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

prune_stage_dirs
prune_gc_roots
