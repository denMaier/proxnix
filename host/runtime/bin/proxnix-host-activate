#!/bin/bash
# Activate a Nix-installed proxnix host runtime on a Proxmox node.

set -euo pipefail

PROXNIX_PROFILE="${PROXNIX_PROFILE:-/nix/var/nix/profiles/proxnix-host}"
LXC_CONFIG_DIR="/usr/share/lxc/config"
LXC_HOOKS_DIR="/usr/share/lxc/hooks"
PROXNIX_LIB_DIR="/usr/local/lib/proxnix"
PROXNIX_SBIN_DIR="/usr/local/sbin"
PROXNIX_LOCAL_BIN_DIR="/usr/local/bin"
SYSTEMD_UNIT_DIR="/etc/systemd/system"
PROXNIX_DATA_DIR="/var/lib/proxnix"
PROXNIX_PRIVATE_DIR="${PROXNIX_DATA_DIR}/private"
PROXNIX_HOST_STATE_DIR="/etc/proxnix"
PROXNIX_INSTALL_MANIFEST="${PROXNIX_LIB_DIR}/install-manifest.txt"
PROXNIX_INSTALL_INFO="${PROXNIX_LIB_DIR}/install-info.txt"
MANIFEST_ENTRIES=()

die() { echo "error: $*" >&2; exit 1; }
log() { echo "  $*"; }

need_root() {
    [[ "$(id -u)" -eq 0 ]] || die "proxnix-host-activate must run as root"
}

ensure_dir() {
    local path="$1" mode="$2"
    install -d -m "$mode" "$path"
}

link_file() {
    local src="$1" dest="$2"
    [[ -e "$src" || -L "$src" ]] || die "missing source: $src"
    ln -sfn "$src" "$dest"
    MANIFEST_ENTRIES+=("$dest")
    log "linked $dest -> $src"
}

need_root
command -v pveversion >/dev/null 2>&1 || die "pveversion not found; is this a Proxmox host?"
[[ -d "$PROXNIX_PROFILE" ]] || die "missing proxnix profile: $PROXNIX_PROFILE"

for path in \
    "$LXC_CONFIG_DIR" \
    "$LXC_HOOKS_DIR" \
    "$PROXNIX_LIB_DIR" \
    "$PROXNIX_SBIN_DIR" \
    "$PROXNIX_LOCAL_BIN_DIR" \
    "$SYSTEMD_UNIT_DIR" \
    "$PROXNIX_DATA_DIR" \
    "$PROXNIX_DATA_DIR/containers" \
    "$PROXNIX_DATA_DIR/authority" \
    "$PROXNIX_DATA_DIR/status" \
    "$PROXNIX_DATA_DIR/state" \
    "$PROXNIX_DATA_DIR/gcroots" \
    "$PROXNIX_DATA_DIR/gcroots/deploy"
do
    ensure_dir "$path" "0755"
done

for path in \
    "$PROXNIX_PRIVATE_DIR" \
    "$PROXNIX_HOST_STATE_DIR" \
    "$PROXNIX_PRIVATE_DIR/shared" \
    "$PROXNIX_PRIVATE_DIR/containers"
do
    ensure_dir "$path" "0700"
done

rm -f "$PROXNIX_DATA_DIR/state/proxnix-reconciler.sqlite"

link_file "$PROXNIX_PROFILE/share/proxnix/lxc/config/nixos.common.conf" "$LXC_CONFIG_DIR/nixos.common.conf"
link_file "$PROXNIX_PROFILE/share/proxnix/lxc/config/nixos.userns.conf" "$LXC_CONFIG_DIR/nixos.userns.conf"
link_file "$PROXNIX_PROFILE/share/proxnix/lxc/hooks/nixos-proxnix-start-host" "$LXC_HOOKS_DIR/nixos-proxnix-start-host"

for path in \
    "$PROXNIX_LIB_DIR/pve-conf-to-nix" \
    "$PROXNIX_LIB_DIR/nixos-proxnix-common.sh" \
    /usr/share/lxc/hooks/nixos-proxnix-prestart \
    /usr/share/lxc/hooks/nixos-proxnix-mount \
    /usr/share/lxc/hooks/nixos-proxnix-poststop \
    "$PROXNIX_LIB_DIR/proxnix_authority_render.py" \
    "$PROXNIX_LIB_DIR/proxnix_reconciler_state.py" \
    "$PROXNIX_LIB_DIR/proxnix_reconcile_podman_secrets.py"
do
    rm -f "$path"
done
link_file "$PROXNIX_PROFILE/lib/proxnix/proxnix-secrets-guest" "$PROXNIX_LIB_DIR/proxnix-secrets-guest"

for command in \
    proxnix-doctor \
    proxnix-host \
    proxnix-host-activate \
    proxnix-host-uninstall
do
    link_file "$PROXNIX_PROFILE/bin/$command" "$PROXNIX_SBIN_DIR/$command"
done

for unit in \
    proxnix-gc.service \
    proxnix-gc.timer \
    proxnix-flake-update.service \
    proxnix-flake-update.timer \
    proxnix-reconcile.service \
    proxnix-reconcile.timer \
    proxnix-reconcile@.service
do
    link_file "$PROXNIX_PROFILE/share/systemd/system/$unit" "$SYSTEMD_UNIT_DIR/$unit"
done

for module in base.nix common.nix security-policy.nix configuration.nix; do
    link_file "$PROXNIX_PROFILE/share/proxnix/nix/$module" "$PROXNIX_DATA_DIR/$module"
done

{
    printf '%s\n' "${MANIFEST_ENTRIES[@]}"
    printf '%s\n' "$PROXNIX_INSTALL_MANIFEST" "$PROXNIX_INSTALL_INFO" "$PROXNIX_PROFILE"
} > "$PROXNIX_INSTALL_MANIFEST"

cat > "$PROXNIX_INSTALL_INFO" <<EOF
proxnix host install
====================

This node uses a Nix profile for normal proxnix host operations:
$PROXNIX_PROFILE

Installed local commands:
- proxnix-doctor
- proxnix-host
- proxnix-host-activate
- proxnix-host-uninstall

Managed local runtime links are listed in:
$PROXNIX_INSTALL_MANIFEST

Published relay data remains external:
- $PROXNIX_DATA_DIR
- $PROXNIX_HOST_STATE_DIR

To remove only the installed proxnix runtime from this node, run:
  proxnix-host-uninstall

The uninstall command removes proxnix host symlinks and the proxnix host
profile. It does not remove Nix itself.
EOF

systemctl daemon-reload
for timer in proxnix-gc.timer proxnix-flake-update.timer proxnix-reconcile.timer; do
    systemctl enable --now "$timer"
done

echo "proxnix host runtime activated from $PROXNIX_PROFILE"
