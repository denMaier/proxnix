#!/usr/bin/env python3
"""Upload pending proxnix closures to the configured shared Nix cache."""

from __future__ import annotations

import argparse
import os
import subprocess
import sys
from pathlib import Path


SCRIPT_DIR = Path(__file__).resolve().parent
LIB_DIRS = [
    SCRIPT_DIR.parent / "lib",
    Path("/usr/local/lib/proxnix"),
]
for lib_dir in LIB_DIRS:
    if (lib_dir / "proxnix_reconciler_state.py").exists():
        sys.path.insert(0, str(lib_dir))
        break

from proxnix_reconciler_state import (  # noqa: E402
    DEFAULT_DB,
    connect,
    observe_closure,
    pending_cache_uploads,
    record_attempt,
)


def run(cmd: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, check=False, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)


def unlink_gc_root(gc_root_path: str | None, store_path: str) -> None:
    if not gc_root_path:
        return
    path = Path(gc_root_path)
    try:
        if path.is_symlink() and os.readlink(path) == store_path:
            path.unlink()
    except FileNotFoundError:
        return


def reconcile_one(conn, cache_store: str, row: dict) -> bool:
    store_path = row["store_path"]
    gc_root_path = row.get("gc_root_path")

    host_check = run(["nix", "path-info", store_path])
    if host_check.returncode != 0:
        record_attempt(
            conn,
            vmid=0,
            store_path=store_path,
            phase="cache-upload",
            status="cache-upload-blocked",
            error=f"host closure missing: {host_check.stderr.strip()}",
        )
        return False

    upload = run(["nix", "copy", "--to", cache_store, store_path])
    if upload.returncode != 0:
        record_attempt(
            conn,
            vmid=0,
            store_path=store_path,
            phase="cache-upload",
            status="cache-upload-blocked",
            error=f"nix copy failed: {upload.stderr.strip()}",
        )
        return False

    verify = run(["nix", "path-info", "--store", cache_store, store_path])
    if verify.returncode != 0:
        record_attempt(
            conn,
            vmid=0,
            store_path=store_path,
            phase="cache-upload",
            status="cache-upload-blocked",
            error=f"cache verification failed: {verify.stderr.strip()}",
        )
        return False

    unlink_gc_root(gc_root_path, store_path)
    observe_closure(
        conn,
        store_path=store_path,
        host_has_closure=True,
        container_has_closure=None,
        shared_cache_has_closure=True,
        pending_cache_upload=False,
        protected_by_host_gc_root=False,
        gc_root_path=gc_root_path,
    )
    record_attempt(
        conn,
        vmid=0,
        store_path=store_path,
        phase="cache-upload",
        status="cache-uploaded",
        error=None,
    )
    return True


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--db", default=os.environ.get("PROXNIX_RECONCILER_DB", DEFAULT_DB))
    parser.add_argument(
        "--cache-store",
        default=os.environ.get("PROXNIX_SHARED_CACHE_STORE") or os.environ.get("PROXNIX_SHARED_CACHE"),
        help="Nix store URI passed to nix copy --to, or PROXNIX_SHARED_CACHE_STORE",
    )
    args = parser.parse_args(argv)

    if not args.cache_store:
        parser.error("--cache-store or PROXNIX_SHARED_CACHE_STORE is required")

    any_failed = False
    with connect(args.db) as conn:
        for row in pending_cache_uploads(conn):
            if reconcile_one(conn, args.cache_store, row):
                print(f"{row['store_path']} cache-uploaded")
            else:
                print(f"{row['store_path']} cache-upload-blocked", file=sys.stderr)
                any_failed = True
    return 1 if any_failed else 0


if __name__ == "__main__":
    raise SystemExit(main())
