#!/usr/bin/env bash
# Update the host-managed proxnix authority flake lock.

set -euo pipefail

SELF_NAME="${0##*/}"
NIXLXC_DIR="${PROXNIX_DIR:-/var/lib/proxnix}"
AUTHORITY_DIR="${PROXNIX_AUTHORITY_DIR:-${NIXLXC_DIR}/authority}"
PVE_LXC_DIR="${PROXNIX_PVE_LXC_DIR:-/etc/pve/lxc}"
LOCK_DIR="${PROXNIX_RUN_DIR:-/run/proxnix}"
STATE_DIR="${PROXNIX_STATE_DIR:-${NIXLXC_DIR}/state}"
STAMP_FILE="${PROXNIX_FLAKE_UPDATE_STAMP_FILE:-${STATE_DIR}/flake-update.last-success}"
NODE_NAME="${PROXNIX_NODE_NAME:-$(hostname -s 2>/dev/null || hostname)}"
AUTHORITY_RENDER="${PROXNIX_AUTHORITY_RENDER:-/usr/local/sbin/proxnix-authority-render}"
FREQUENCY="${PROXNIX_FLAKE_UPDATE_FREQUENCY:-weekly}"
INPUTS="${PROXNIX_FLAKE_UPDATE_INPUTS:-}"
NOW="${PROXNIX_FLAKE_UPDATE_NOW:-}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

FORCE=0
CLI_INPUTS=()

usage() {
  cat >&2 <<EOF
Usage:
  ${SELF_NAME} [--force] [--frequency daily|weekly|monthly|disabled] [input ...]

Updates /var/lib/proxnix/authority/flake.lock with nix flake update and copies
the resulting lock back to /var/lib/proxnix/flake.lock so later authority
renders keep using the advanced inputs. The command serializes with reconcile
through /run/proxnix/reconcile.lock.
EOF
}

die() {
  echo "error: $*" >&2
  exit 2
}

log() {
  echo "$SELF_NAME: $*"
}

need_cmd() {
  local cmd="$1"
  command -v "$cmd" >/dev/null 2>&1 || die "${cmd} not found"
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force)
        FORCE=1
        shift
        ;;
      --frequency)
        [[ $# -ge 2 ]] || die "--frequency requires a value"
        FREQUENCY="$2"
        shift 2
        ;;
      --input)
        [[ $# -ge 2 ]] || die "--input requires a value"
        CLI_INPUTS+=("$2")
        shift 2
        ;;
      --)
        shift
        CLI_INPUTS+=("$@")
        break
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      -*)
        die "unknown argument: $1"
        ;;
      *)
        CLI_INPUTS+=("$1")
        shift
        ;;
    esac
  done
}

frequency_seconds() {
  case "$FREQUENCY" in
    daily) printf '86400\n' ;;
    weekly) printf '604800\n' ;;
    monthly) printf '2592000\n' ;;
    disabled) printf 'disabled\n' ;;
    *) die "invalid flake update frequency: ${FREQUENCY}" ;;
  esac
}

current_epoch() {
  if [[ -n "$NOW" ]]; then
    [[ "$NOW" =~ ^[0-9]+$ ]] || die "invalid PROXNIX_FLAKE_UPDATE_NOW: ${NOW}"
    printf '%s\n' "$NOW"
    return
  fi
  need_cmd date
  date +%s
}

last_success_epoch() {
  local value=""
  if [[ -f "$STAMP_FILE" ]]; then
    read -r value < "$STAMP_FILE" || true
  fi
  if [[ "$value" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$value"
  else
    printf '0\n'
  fi
}

should_update() {
  [[ "$FORCE" -eq 1 ]] && return 0

  local interval
  interval="$(frequency_seconds)"
  if [[ "$interval" == "disabled" ]]; then
    return 1
  fi

  local now last
  now="$(current_epoch)"
  last="$(last_success_epoch)"
  [[ "$last" -eq 0 ]] && return 0
  [[ $((now - last)) -ge "$interval" ]]
}

take_lock() {
  need_cmd flock
  mkdir -p "$LOCK_DIR"
  exec 9>"${LOCK_DIR}/reconcile.lock"
  flock -n 9 || die "another proxnix reconcile or flake update run is active"
}

render_authority() {
  if [[ -x "$AUTHORITY_RENDER" ]]; then
    "$AUTHORITY_RENDER" \
      --root "$NIXLXC_DIR" \
      --authority "$AUTHORITY_DIR" \
      --pve-lxc-dir "$PVE_LXC_DIR" \
      --node-name "$NODE_NAME" >/dev/null
    return
  fi

  local proxnix_host="${PROXNIX_HOST_BIN:-/usr/local/sbin/proxnix-host}"
  if [[ -x "$proxnix_host" ]]; then
    "$proxnix_host" authority render \
      --root "$NIXLXC_DIR" \
      --authority "$AUTHORITY_DIR" \
      --pve-lxc-dir "$PVE_LXC_DIR" \
      --node-name "$NODE_NAME" >/dev/null
    return
  fi

  die "proxnix-authority-render not found"
}

run_flake_update() {
  need_cmd nix

  local -a args=(flake update)
  local -a env_inputs=()
  local input
  if [[ -n "$INPUTS" ]]; then
    read -r -a env_inputs <<< "$INPUTS"
  fi
  for input in "${env_inputs[@]}"; do
    args+=("$input")
  done
  for input in "${CLI_INPUTS[@]}"; do
    args+=("$input")
  done
  args+=(--flake "$AUTHORITY_DIR")

  nix "${args[@]}"
}

persist_authority_lock() {
  [[ -f "${AUTHORITY_DIR}/flake.lock" ]] || die "nix flake update did not produce ${AUTHORITY_DIR}/flake.lock"
  mkdir -p "$NIXLXC_DIR"
  local tmp="${NIXLXC_DIR}/flake.lock.$$"
  install -m 0644 "${AUTHORITY_DIR}/flake.lock" "$tmp"
  mv -f "$tmp" "${NIXLXC_DIR}/flake.lock"
}

write_stamp() {
  local now
  now="$(current_epoch)"
  mkdir -p "$(dirname "$STAMP_FILE")"
  local tmp="${STAMP_FILE}.$$"
  printf '%s\n' "$now" > "$tmp"
  mv -f "$tmp" "$STAMP_FILE"
}

main() {
  parse_args "$@"
  take_lock

  if ! should_update; then
    log "flake update skipped; frequency=${FREQUENCY}"
    return 0
  fi

  render_authority
  run_flake_update
  persist_authority_lock
  write_stamp
  log "updated flake lock; frequency=${FREQUENCY}"
}

main "$@"
