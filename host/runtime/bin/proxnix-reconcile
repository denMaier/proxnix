#!/usr/bin/env bash
# proxnix-reconcile -- host-side reconciler entrypoint.
#
# Host-side orchestration for authority rendering, manifest evaluation, builds,
# closure seeding, and activation.

set -euo pipefail

SELF_NAME="${0##*/}"
NIXLXC_DIR="${PROXNIX_DIR:-/var/lib/proxnix}"
AUTHORITY_DIR="${PROXNIX_AUTHORITY_DIR:-${NIXLXC_DIR}/authority}"
STATUS_DIR="${PROXNIX_STATUS_DIR:-${NIXLXC_DIR}/status}"
PVE_LXC_DIR="${PROXNIX_PVE_LXC_DIR:-/etc/pve/lxc}"
LOCK_DIR="${PROXNIX_RUN_DIR:-/run/proxnix}"
GCROOT_DIR="${PROXNIX_GCROOT_DIR:-${NIXLXC_DIR}/gcroots/deploy}"
NODE_NAME="${PROXNIX_NODE_NAME:-$(hostname -s 2>/dev/null || hostname)}"
AUTHORITY_RENDER="${PROXNIX_AUTHORITY_RENDER:-/usr/local/sbin/proxnix-authority-render}"
CREATE_LXC="${PROXNIX_CREATE_LXC:-/usr/local/sbin/proxnix-create-lxc}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat >&2 <<EOF
Usage:
  ${SELF_NAME} [--dry-run] [--vmid <id>] [--node-name <name>]
  ${SELF_NAME} --build-only --vmid <id> [--node-name <name>]
  ${SELF_NAME} --seed-only --vmid <id>
  ${SELF_NAME} --activate-only --vmid <id>
  ${SELF_NAME} --vmid <id> --recreate-missing
  ${SELF_NAME} --status [--vmid <id>]
  ${SELF_NAME} --rollback --vmid <id>

Dry-run renders and evaluates the authority manifest, then prints planned
container actions without building, starting, stopping, creating, or modifying
containers.
EOF
}

die() {
  echo "error: $*" >&2
  exit 2
}

need_cmd() {
  local cmd="$1"
  command -v "$cmd" >/dev/null 2>&1 || die "${cmd} not found"
}

json_or_null_arg() {
  local value="$1"
  if [[ -n "$value" ]]; then
    printf '%s\n' "$value"
  else
    printf 'null\n'
  fi
}

render_authority() {
  if [[ -x "$AUTHORITY_RENDER" ]]; then
    "$AUTHORITY_RENDER" \
      --root "$NIXLXC_DIR" \
      --authority "$AUTHORITY_DIR" \
      --pve-lxc-dir "$PVE_LXC_DIR" \
      --node-name "$NODE_NAME" >/dev/null
    return
  fi

  local repo_renderer="${SCRIPT_DIR}/../lib/proxnix_authority_render.py"
  if [[ -f "$repo_renderer" ]]; then
    need_cmd python3
    python3 "$repo_renderer" \
      --root "$NIXLXC_DIR" \
      --authority "$AUTHORITY_DIR" \
      --pve-lxc-dir "$PVE_LXC_DIR" \
      --node-name "$NODE_NAME" >/dev/null
    return
  fi

  die "proxnix-authority-render not found"
}

node_attr_fragment() {
  if [[ "$NODE_NAME" =~ ^[A-Za-z_][A-Za-z0-9_\'-]*$ ]]; then
    printf 'proxnix.nodes.%s\n' "$NODE_NAME"
  else
    printf 'proxnix.nodes."%s"\n' "${NODE_NAME//\"/\\\"}"
  fi
}

eval_node_manifest() {
  need_cmd nix
  local attr
  attr="$(node_attr_fragment)"
  local lock_args=()
  [[ -f "${AUTHORITY_DIR}/flake.lock" ]] || lock_args+=(--no-write-lock-file)
  nix eval "${lock_args[@]}" --json "${AUTHORITY_DIR}#${attr}"
}

is_local_container() {
  local vmid="$1"
  local placement_node
  if placement_node="$(cluster_placement_node "$vmid")"; then
    [[ "$placement_node" == "$NODE_NAME" ]]
    return
  fi
  command -v pct >/dev/null 2>&1 || return 1
  pct status "$vmid" >/dev/null 2>&1
}

cluster_placement_node() {
  local vmid="$1"
  command -v pvesh >/dev/null 2>&1 || return 1
  command -v jq >/dev/null 2>&1 || return 1

  local resources node
  if ! resources="$(pvesh get /cluster/resources --type vm --output-format json 2>/dev/null)"; then
    return 1
  fi
  node="$(jq -r --arg vmid "$vmid" 'map(select((.vmid | tostring) == $vmid))[0].node // empty' <<<"$resources" 2>/dev/null || true)"
  [[ -n "$node" ]] || return 1
  printf '%s\n' "$node"
}

selected_container_is_local_or_skip() {
  local vmid="$1"
  if is_local_container "$vmid"; then
    return 0
  fi
  printf '%s skip not-local\n' "$vmid"
  return 1
}

take_global_lock() {
  need_cmd flock
  mkdir -p "$LOCK_DIR"
  exec 9>"${LOCK_DIR}/reconcile.lock"
  flock -n 9 || die "another proxnix-reconcile run is active"
}

take_container_lock() {
  local vmid="$1"
  mkdir -p "$LOCK_DIR"
  exec 8>"${LOCK_DIR}/reconcile-${vmid}.lock"
  flock -n 8 || die "another proxnix-reconcile run is active for VMID ${vmid}"
}

status() {
  local vmid=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --vmid)
        [[ $# -ge 2 ]] || die "--vmid requires a value"
        vmid="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown status argument: $1"
        ;;
    esac
  done

  if [[ -n "$vmid" ]]; then
    [[ "$vmid" =~ ^[0-9]+$ ]] || die "invalid VMID: $vmid"
    local path="${STATUS_DIR}/${vmid}.json"
    [[ -f "$path" ]] || die "status not found for VMID ${vmid}: ${path}"
    cat "$path"
    printf '\n'
    return
  fi

  if [[ ! -d "$STATUS_DIR" ]]; then
    printf '[]\n'
    return
  fi

  if command -v jq >/dev/null 2>&1; then
    jq -s '.' "${STATUS_DIR}"/*.json 2>/dev/null || printf '[]\n'
  else
    local first=1 file
    printf '['
    for file in "${STATUS_DIR}"/*.json; do
      [[ -f "$file" ]] || continue
      if [[ "$first" -eq 0 ]]; then
        printf ','
      fi
      first=0
      cat "$file"
    done
    printf ']\n'
  fi
}

dry_run() {
  local selected_vmid="$1"
  need_cmd jq
  need_cmd readlink
  take_global_lock
  render_authority

  local manifest
  if ! manifest="$(eval_node_manifest)"; then
    die "failed to evaluate node manifest for ${NODE_NAME}"
  fi

  local vmids=()
  if [[ -n "$selected_vmid" ]]; then
    if ! jq -e --arg vmid "$selected_vmid" '.containers[$vmid] != null' >/dev/null <<<"$manifest"; then
      die "VMID ${selected_vmid} is not present in proxnix.nodes.${NODE_NAME}"
    fi
    vmids=("$selected_vmid")
  else
    mapfile -t vmids < <(jq -r '.containers | keys[]' <<<"$manifest" | sort -n)
  fi

  if [[ ${#vmids[@]} -eq 0 ]]; then
    printf 'no managed containers in proxnix.nodes.%s\n' "$NODE_NAME"
    return
  fi

  local vmid status_file desired_system last_desired current_system
  for vmid in "${vmids[@]}"; do
    if ! is_local_container "$vmid"; then
      printf '%s skip not-local\n' "$vmid"
      continue
    fi
    status_file="${STATUS_DIR}/${vmid}.json"
    desired_system="$(jq -r --arg vmid "$vmid" '.containers[$vmid].system // "unknown until build"' <<<"$manifest")"
    last_desired=""
    current_system=""
    if [[ -f "$status_file" ]]; then
      last_desired="$(jq -r '.desiredSystem // empty' "$status_file" 2>/dev/null || true)"
      current_system="$(jq -r '.currentSystem // empty' "$status_file" 2>/dev/null || true)"
    fi

    if [[ "$last_desired" == "$desired_system" && -n "$current_system" && "$current_system" == "$desired_system" ]]; then
      printf '%s noop current system matches desired\n' "$vmid"
      continue
    fi

    printf '%s build %s\n' "$vmid" "$desired_system"
    printf '%s keep local CT\n' "$vmid"
    printf '%s seed desired closure\n' "$vmid"
    printf '%s activate desired system\n' "$vmid"
  done
}

write_build_status() {
  local vmid="$1" hostname="$2" source_revision="$3" desired_system="$4" current_system="$5" previous_system="$6" last_deploy_status="$7"
  need_cmd jq
  need_cmd date
  mkdir -p "$STATUS_DIR"

  local tmp="${STATUS_DIR}/${vmid}.json.tmp"
  jq -n \
    --argjson vmid "$vmid" \
    --arg hostname "$hostname" \
    --argjson sourceRevision "$(json_or_null_arg "$source_revision")" \
    --arg desiredSystem "$desired_system" \
    --arg currentSystem "$current_system" \
    --arg previousSystem "$previous_system" \
    --arg lastDeployStatus "${last_deploy_status:-not-run}" \
    --arg node "$NODE_NAME" \
    --arg updatedAt "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{
      vmid: $vmid,
      hostname: $hostname,
      node: $node,
      local: true,
      sourceRevision: $sourceRevision,
      desiredSystem: $desiredSystem,
      currentSystem: (if $currentSystem == "" then null else $currentSystem end),
      previousSystem: (if $previousSystem == "" then null else $previousSystem end),
      desired_system: $desiredSystem,
      current_system: (if $currentSystem == "" then null else $currentSystem end),
      container_is_local: true,
      host_has_closure: true,
      container_has_closure: (if $currentSystem == $desiredSystem then true else false end),
      protected_by_host_gc_root: true,
      lastBuildStatus: "ok",
      lastDeployStatus: $lastDeployStatus,
      lastError: null,
      updatedAt: $updatedAt
    }' > "$tmp"
  mv "$tmp" "${STATUS_DIR}/${vmid}.json"
}

write_activation_status() {
  local vmid="$1" desired_system="$2" previous_system="$3"
  need_cmd jq
  need_cmd date
  local status_file="${STATUS_DIR}/${vmid}.json"
  [[ -f "$status_file" ]] || die "status not found for VMID ${vmid}; run --build-only first"
  local tmp="${status_file}.tmp"
  jq \
    --arg desiredSystem "$desired_system" \
    --arg previousSystem "$previous_system" \
    --arg activatedAt "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '.desiredSystem = $desiredSystem
      | .currentSystem = $desiredSystem
      | .previousSystem = (if $previousSystem == "" then .previousSystem else $previousSystem end)
      | .desired_system = $desiredSystem
      | .current_system = $desiredSystem
      | .container_is_local = true
      | .host_has_closure = true
      | .container_has_closure = true
      | .protected_by_host_gc_root = true
      | .lastBuildStatus = "ok"
      | .lastDeployStatus = "ok"
      | .lastError = null
      | .activatedAt = $activatedAt
      | .updatedAt = $activatedAt' \
    "$status_file" > "$tmp"
  mv "$tmp" "$status_file"
}

write_noop_status() {
  local vmid="$1" hostname="$2" source_revision="$3" desired_system="$4" current_system="$5" previous_system="$6"
  need_cmd jq
  need_cmd date
  mkdir -p "$STATUS_DIR"

  local status_file="${STATUS_DIR}/${vmid}.json"
  local last_build_status="not-run"
  if [[ -f "$status_file" ]]; then
    last_build_status="$(jq -r '.lastBuildStatus // "not-run"' "$status_file" 2>/dev/null || true)"
  fi

  local tmp="${STATUS_DIR}/${vmid}.json.tmp"
  jq -n \
    --argjson vmid "$vmid" \
    --arg hostname "$hostname" \
    --argjson sourceRevision "$(json_or_null_arg "$source_revision")" \
    --arg desiredSystem "$desired_system" \
    --arg currentSystem "$current_system" \
    --arg previousSystem "$previous_system" \
    --arg lastBuildStatus "$last_build_status" \
    --arg node "$NODE_NAME" \
    --arg updatedAt "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{
      vmid: $vmid,
      hostname: $hostname,
      node: $node,
      local: true,
      sourceRevision: $sourceRevision,
      desiredSystem: $desiredSystem,
      currentSystem: (if $currentSystem == "" then null else $currentSystem end),
      previousSystem: (if $previousSystem == "" then null else $previousSystem end),
      desired_system: $desiredSystem,
      current_system: (if $currentSystem == "" then null else $currentSystem end),
      container_is_local: true,
      host_has_closure: null,
      container_has_closure: true,
      protected_by_host_gc_root: false,
      lastBuildStatus: $lastBuildStatus,
      lastDeployStatus: "noop-current",
      lastError: null,
      updatedAt: $updatedAt
    }' > "$tmp"
  mv "$tmp" "${STATUS_DIR}/${vmid}.json"
}

write_build_failed_status() {
  local vmid="$1" hostname="$2" source_revision="$3" desired_system="$4" current_system="$5" previous_system="$6" error="$7"
  need_cmd jq
  need_cmd date
  mkdir -p "$STATUS_DIR"

  local tmp="${STATUS_DIR}/${vmid}.json.tmp"
  jq -n \
    --argjson vmid "$vmid" \
    --arg hostname "$hostname" \
    --argjson sourceRevision "$(json_or_null_arg "$source_revision")" \
    --arg desiredSystem "$desired_system" \
    --arg currentSystem "$current_system" \
    --arg previousSystem "$previous_system" \
    --arg lastError "$error" \
    --arg node "$NODE_NAME" \
    --arg updatedAt "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{
      vmid: $vmid,
      hostname: $hostname,
      node: $node,
      local: true,
      sourceRevision: $sourceRevision,
      desiredSystem: $desiredSystem,
      currentSystem: (if $currentSystem == "" then null else $currentSystem end),
      previousSystem: (if $previousSystem == "" then null else $previousSystem end),
      desired_system: $desiredSystem,
      current_system: (if $currentSystem == "" then null else $currentSystem end),
      container_is_local: true,
      host_has_closure: false,
      container_has_closure: false,
      protected_by_host_gc_root: false,
      lastBuildStatus: "failed",
      lastDeployStatus: "build-failed",
      lastError: $lastError,
      updatedAt: $updatedAt
    }' > "$tmp"
  mv "$tmp" "${STATUS_DIR}/${vmid}.json"
}

write_rollback_status() {
  local vmid="$1" rollback_system="$2"
  need_cmd jq
  need_cmd date
  local status_file="${STATUS_DIR}/${vmid}.json"
  [[ -f "$status_file" ]] || die "status not found for VMID ${vmid}"
  local tmp="${status_file}.tmp"
  jq \
    --arg currentSystem "$rollback_system" \
    --arg rolledBackAt "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '.currentSystem = $currentSystem
      | .current_system = $currentSystem
      | .container_has_closure = true
      | .lastDeployStatus = "rollback-ok"
      | .lastError = null
      | .rolledBackAt = $rolledBackAt
      | .updatedAt = $rolledBackAt' \
    "$status_file" > "$tmp"
  mv "$tmp" "$status_file"
}

update_deploy_status() {
  local vmid="$1" deploy_status="$2" error="$3"
  need_cmd jq
  need_cmd date
  local status_file="${STATUS_DIR}/${vmid}.json"
  [[ -f "$status_file" ]] || die "status not found for VMID ${vmid}; run --build-only first"
  local tmp="${status_file}.tmp"
  jq \
    --arg lastDeployStatus "$deploy_status" \
    --arg lastError "$error" \
    --arg updatedAt "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '.lastDeployStatus = $lastDeployStatus
      | .lastError = (if $lastError == "" then null else $lastError end)
      | .updatedAt = $updatedAt' \
    "$status_file" > "$tmp"
  mv "$tmp" "$status_file"
}

update_lost_locality_status() {
  local vmid="$1" phase="$2"
  need_cmd jq
  need_cmd date
  local status_file="${STATUS_DIR}/${vmid}.json"
  [[ -f "$status_file" ]] || die "status not found for VMID ${vmid}; run --build-only first"
  local tmp="${status_file}.tmp"
  jq \
    --arg phase "$phase" \
    --arg updatedAt "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '.local = false
      | .container_is_local = false
      | .lastDeployStatus = "lost-locality"
      | .lastError = ("container locality lost before " + $phase)
      | .updatedAt = $updatedAt' \
    "$status_file" > "$tmp"
  mv "$tmp" "$status_file"
}

build_manifest_system() {
  local selected_vmid="$1" manifest="$2"
  local system_attr
  system_attr="$(jq -r --arg vmid "$selected_vmid" '.containers[$vmid].systemAttr // empty' <<<"$manifest")"
  [[ -n "$system_attr" ]] || die "manifest for VMID ${selected_vmid} is missing systemAttr"
  local lock_args=()
  [[ -f "${AUTHORITY_DIR}/flake.lock" ]] || lock_args+=(--no-write-lock-file)
  nix build "${lock_args[@]}" --print-out-paths "${AUTHORITY_DIR}#${system_attr}"
}

protect_host_closure() {
  local vmid="$1" system_path="$2"
  mkdir -p "$GCROOT_DIR"
  local root_path="${GCROOT_DIR}/${vmid}-desired"
  local tmp_path="${root_path}.tmp.$$"
  rm -f "$tmp_path"
  ln -s "$system_path" "$tmp_path"
  mv -f "$tmp_path" "$root_path"
}

manifest_system() {
  local selected_vmid="$1" manifest="$2"
  jq -r --arg vmid "$selected_vmid" '.containers[$vmid].system // empty' <<<"$manifest"
}

manifest_hostname() {
  local selected_vmid="$1" manifest="$2"
  jq -r --arg vmid "$selected_vmid" '.containers[$vmid].hostname // ("ct" + $vmid)' <<<"$manifest"
}

manifest_source_revision() {
  local selected_vmid="$1" manifest="$2"
  jq -c --arg vmid "$selected_vmid" '.containers[$vmid].sourceRevision // null' <<<"$manifest"
}

pve_field() {
  local selected_vmid="$1" manifest="$2" field="$3"
  jq -r --arg vmid "$selected_vmid" --arg field "$field" '.containers[$vmid].pve[$field] // empty' <<<"$manifest"
}

placement_field() {
  local selected_vmid="$1" manifest="$2" field="$3"
  jq -r --arg vmid "$selected_vmid" --arg field "$field" '.containers[$vmid].placement[$field] // empty' <<<"$manifest"
}

net0_part() {
  local net0="$1" key="$2"
  tr ',' '\n' <<<"$net0" | awk -F= -v key="$key" '$1 == key { print $2; exit }'
}

rootfs_storage() {
  local rootfs="$1"
  [[ "$rootfs" == *:* ]] || return 0
  printf '%s\n' "${rootfs%%:*}"
}

rootfs_disk_gb() {
  local rootfs="$1" size
  size="$(tr ',' '\n' <<<"$rootfs" | awk -F= '$1 == "size" { print $2; exit }')"
  size="${size%G}"
  size="${size%g}"
  [[ -n "$size" ]] || return 0
  printf '%s\n' "$size"
}

container_state() {
  local vmid="$1"
  command -v pct >/dev/null 2>&1 || return 1
  pct status "$vmid" 2>/dev/null | awk '{ print $2 }' || true
}

build_only() {
  local selected_vmid="$1"
  [[ -n "$selected_vmid" ]] || die "--build-only requires --vmid"
  need_cmd jq
  need_cmd nix
  need_cmd flock
  take_global_lock
  take_container_lock "$selected_vmid"
  render_authority

  local manifest
  if ! manifest="$(eval_node_manifest)"; then
    die "failed to evaluate node manifest for ${NODE_NAME}"
  fi
  if ! jq -e --arg vmid "$selected_vmid" '.containers[$vmid] != null' >/dev/null <<<"$manifest"; then
    die "VMID ${selected_vmid} is not present in proxnix.nodes.${NODE_NAME}"
  fi
  if ! selected_container_is_local_or_skip "$selected_vmid"; then
    return
  fi

  local system_path desired_system hostname source_revision status_file current_system previous_system last_deploy_status
  hostname="$(manifest_hostname "$selected_vmid" "$manifest")"
  source_revision="$(manifest_source_revision "$selected_vmid" "$manifest")"
  desired_system="$(manifest_system "$selected_vmid" "$manifest")"
  [[ -n "$desired_system" ]] || die "manifest for VMID ${selected_vmid} is missing system"

  status_file="${STATUS_DIR}/${selected_vmid}.json"
  current_system=""
  previous_system=""
  last_deploy_status="not-run"
  if [[ -f "$status_file" ]]; then
    current_system="$(jq -r '.currentSystem // empty' "$status_file" 2>/dev/null || true)"
    previous_system="$(jq -r '.previousSystem // empty' "$status_file" 2>/dev/null || true)"
    last_deploy_status="$(jq -r '.lastDeployStatus // "not-run"' "$status_file" 2>/dev/null || true)"
  fi

  if [[ "$current_system" == "$desired_system" ]]; then
    write_noop_status "$selected_vmid" "$hostname" "$source_revision" "$desired_system" "$current_system" "$previous_system"
    printf '%s noop current system matches desired\n' "$selected_vmid"
    return
  fi

  system_path="$(build_manifest_system "$selected_vmid" "$manifest")"
  system_path="$(tr -d '\r\n' <<<"$system_path")"
  [[ -n "$system_path" ]] || die "nix build produced no output path for VMID ${selected_vmid}"
  [[ "$system_path" == "$desired_system" ]] || die "nix build produced ${system_path}, expected ${desired_system}"
  protect_host_closure "$selected_vmid" "$system_path"

  write_build_status "$selected_vmid" "$hostname" "$source_revision" "$system_path" "$current_system" "$previous_system" "$last_deploy_status"
  printf '%s built %s\n' "$selected_vmid" "$system_path"
}

seed_closure() {
  local vmid="$1" system_path="$2"
  need_cmd nix-store
  need_cmd pct
  need_cmd xargs

  local closure_file="${LOCK_DIR}/closure-${vmid}.txt"
  mkdir -p "$LOCK_DIR"
  nix-store --query --requisites "$system_path" > "$closure_file"
  xargs nix-store --export < "$closure_file" | pct exec "$vmid" -- nix-store --import
  pct exec "$vmid" -- test -x "${system_path}/bin/switch-to-configuration"
}

seed_only() {
  local selected_vmid="$1"
  [[ -n "$selected_vmid" ]] || die "--seed-only requires --vmid"
  need_cmd jq
  need_cmd flock
  take_global_lock
  take_container_lock "$selected_vmid"
  if ! selected_container_is_local_or_skip "$selected_vmid"; then
    return
  fi

  local status_file="${STATUS_DIR}/${selected_vmid}.json"
  [[ -f "$status_file" ]] || die "status not found for VMID ${selected_vmid}; run --build-only first"
  local desired_system
  desired_system="$(jq -r '.desiredSystem // empty' "$status_file")"
  [[ -n "$desired_system" ]] || die "status for VMID ${selected_vmid} does not contain desiredSystem"

  local seed_output
  if ! seed_output="$(seed_closure "$selected_vmid" "$desired_system" 2>&1)"; then
    update_deploy_status "$selected_vmid" "failed" "closure seed failed: ${seed_output}"
    printf '%s seed failed\n' "$selected_vmid" >&2
    return 2
  fi

  update_deploy_status "$selected_vmid" "seeded" ""
  printf '%s seeded %s\n' "$selected_vmid" "$desired_system"
}

resolve_create_lxc() {
  if [[ -x "$CREATE_LXC" ]]; then
    printf '%s\n' "$CREATE_LXC"
    return
  fi

  local repo_create="${SCRIPT_DIR}/proxnix-create-lxc"
  if [[ -x "$repo_create" ]]; then
    printf '%s\n' "$repo_create"
    return
  fi

  die "proxnix-create-lxc not found"
}

ensure_container_exists() {
  local selected_vmid="$1" manifest="$2" recreate_missing="$3"
  if is_local_container "$selected_vmid"; then
    return
  fi

  if [[ "$recreate_missing" -ne 1 ]]; then
    printf '%s skip not-local\n' "$selected_vmid"
    return 1
  fi

  local placement_node target_node
  placement_node="$(placement_field "$selected_vmid" "$manifest" node)"
  target_node="$(placement_field "$selected_vmid" "$manifest" targetNode)"
  if [[ "$placement_node" != "$NODE_NAME" && "$target_node" != "$NODE_NAME" ]]; then
    die "VMID ${selected_vmid} is not local to ${NODE_NAME}; --recreate-missing requires placement.node or placement.targetNode to match this node"
  fi

  local create_lxc hostname memory swap cores unprivileged rootfs storage disk net0 bridge ip gw template
  create_lxc="$(resolve_create_lxc)"
  hostname="$(manifest_hostname "$selected_vmid" "$manifest")"
  memory="$(pve_field "$selected_vmid" "$manifest" memory)"
  swap="$(pve_field "$selected_vmid" "$manifest" swap)"
  cores="$(pve_field "$selected_vmid" "$manifest" cores)"
  unprivileged="$(pve_field "$selected_vmid" "$manifest" unprivileged)"
  rootfs="$(pve_field "$selected_vmid" "$manifest" rootfs)"
  storage="$(rootfs_storage "$rootfs")"
  disk="$(rootfs_disk_gb "$rootfs")"
  net0="$(pve_field "$selected_vmid" "$manifest" net0)"
  bridge="$(net0_part "$net0" bridge)"
  ip="$(net0_part "$net0" ip)"
  gw="$(net0_part "$net0" gw)"
  template="$(pve_field "$selected_vmid" "$manifest" template)"

  local -a cmd=(
    "$create_lxc"
    --vmid "$selected_vmid"
    --hostname "$hostname"
    --yes
    --no-start
    --no-doctor
  )
  [[ -n "$template" ]] && cmd+=(--template "$template")
  [[ -n "$storage" ]] && cmd+=(--storage "$storage")
  [[ -n "$disk" ]] && cmd+=(--disk "$disk")
  [[ -n "$memory" ]] && cmd+=(--memory "$memory")
  [[ -n "$swap" ]] && cmd+=(--swap "$swap")
  [[ -n "$cores" ]] && cmd+=(--cores "$cores")
  [[ -n "$bridge" ]] && cmd+=(--bridge "$bridge")
  [[ -n "$ip" ]] && cmd+=(--ip "$ip")
  [[ -n "$gw" ]] && cmd+=(--gw "$gw")
  [[ -n "$unprivileged" ]] && cmd+=(--unprivileged "$unprivileged")

  "${cmd[@]}"
  is_local_container "$selected_vmid" || die "proxnix-create-lxc completed but VMID ${selected_vmid} is still not local"
}

ensure_container_running_for_exec() {
  local vmid="$1" state=""
  need_cmd pct
  need_cmd sleep
  need_cmd awk
  need_cmd seq
  state="$(pct status "$vmid" 2>/dev/null | awk '{ print $2 }' || true)"
  if [[ "$state" != "running" ]]; then
    pct start "$vmid"
  fi

  local attempt
  for attempt in $(seq 1 30); do
    if pct exec "$vmid" -- true >/dev/null 2>&1; then
      return
    fi
    sleep 1
  done
  die "VMID ${vmid} did not become ready for pct exec"
}

current_system() {
  local vmid="$1"
  pct exec "$vmid" -- readlink -f /run/current-system 2>/dev/null || true
}

activate_system() {
  local vmid="$1" system_path="$2"
  pct exec "$vmid" -- "${system_path}/bin/switch-to-configuration" switch
}

verify_system() {
  local vmid="$1" system_path="$2" current
  current="$(current_system "$vmid" | tr -d '\r\n')"
  [[ "$current" == "$system_path" ]]
}

reconcile_build_phase() {
  local selected_vmid="$1" manifest="$2" desired_system="$3" hostname="$4" source_revision="$5" live_current="$6" previous_system="$7"
  local build_output built_system
  if ! build_output="$(build_manifest_system "$selected_vmid" "$manifest" 2>&1)"; then
    write_build_failed_status "$selected_vmid" "$hostname" "$source_revision" "$desired_system" "$live_current" "$previous_system" "nix build failed: ${build_output}"
    printf '%s build failed\n' "$selected_vmid" >&2
    return 2
  fi
  built_system="$(tr -d '\r\n' <<<"$build_output")"
  if [[ -z "$built_system" ]]; then
    write_build_failed_status "$selected_vmid" "$hostname" "$source_revision" "$desired_system" "$live_current" "$previous_system" "nix build produced no output path"
    printf '%s build failed\n' "$selected_vmid" >&2
    return 2
  fi
  if [[ "$built_system" != "$desired_system" ]]; then
    write_build_failed_status "$selected_vmid" "$hostname" "$source_revision" "$desired_system" "$live_current" "$previous_system" "nix build produced ${built_system}, expected ${desired_system}"
    printf '%s build failed\n' "$selected_vmid" >&2
    return 2
  fi
  protect_host_closure "$selected_vmid" "$desired_system"
  write_build_status "$selected_vmid" "$hostname" "$source_revision" "$desired_system" "$live_current" "$previous_system" "not-run"
}

reconcile_seed_phase() {
  local selected_vmid="$1" desired_system="$2"
  local seed_output
  if ! is_local_container "$selected_vmid"; then
    update_lost_locality_status "$selected_vmid" "seed"
    printf '%s lost locality\n' "$selected_vmid" >&2
    return 2
  fi
  if ! seed_output="$(seed_closure "$selected_vmid" "$desired_system" 2>&1)"; then
    update_deploy_status "$selected_vmid" "failed" "closure seed failed: ${seed_output}"
    printf '%s seed failed\n' "$selected_vmid" >&2
    return 2
  fi
  update_deploy_status "$selected_vmid" "seeded" ""
}

reconcile_activate_phase() {
  local selected_vmid="$1" desired_system="$2" previous_system="$3"
  local deploy_output
  if ! is_local_container "$selected_vmid"; then
    update_lost_locality_status "$selected_vmid" "activation"
    printf '%s lost locality\n' "$selected_vmid" >&2
    return 2
  fi
  if ! deploy_output="$(activate_system "$selected_vmid" "$desired_system" 2>&1)"; then
    update_deploy_status "$selected_vmid" "failed" "activation failed: ${deploy_output}"
    printf '%s activation failed\n' "$selected_vmid" >&2
    return 2
  fi
  if ! verify_system "$selected_vmid" "$desired_system"; then
    update_deploy_status "$selected_vmid" "failed" "activation verification failed"
    printf '%s activation verification failed\n' "$selected_vmid" >&2
    return 2
  fi
  if ! is_local_container "$selected_vmid"; then
    update_lost_locality_status "$selected_vmid" "current status update"
    printf '%s lost locality\n' "$selected_vmid" >&2
    return 2
  fi
  write_activation_status "$selected_vmid" "$desired_system" "$previous_system"
}

activate_only() {
  local selected_vmid="$1"
  [[ -n "$selected_vmid" ]] || die "--activate-only requires --vmid"
  need_cmd jq
  need_cmd flock
  need_cmd pct
  take_global_lock
  take_container_lock "$selected_vmid"
  if ! selected_container_is_local_or_skip "$selected_vmid"; then
    return
  fi

  local status_file="${STATUS_DIR}/${selected_vmid}.json"
  [[ -f "$status_file" ]] || die "status not found for VMID ${selected_vmid}; run --build-only first"
  local desired_system previous_system live_current
  desired_system="$(jq -r '.desiredSystem // empty' "$status_file")"
  previous_system="$(jq -r '.previousSystem // empty' "$status_file")"
  [[ -n "$desired_system" ]] || die "status for VMID ${selected_vmid} does not contain desiredSystem"

  ensure_container_running_for_exec "$selected_vmid"
  live_current="$(current_system "$selected_vmid" | tr -d '\r\n')"
  if [[ -n "$live_current" && "$live_current" != "$desired_system" ]]; then
    previous_system="$live_current"
  fi
  reconcile_activate_phase "$selected_vmid" "$desired_system" "$previous_system"
  printf '%s activated %s\n' "$selected_vmid" "$desired_system"
}

reconcile_selected() {
  local selected_vmid="$1" recreate_missing="$2"
  [[ -n "$selected_vmid" ]] || die "full reconcile currently requires --vmid"
  need_cmd jq
  need_cmd nix
  need_cmd flock
  need_cmd pct
  take_global_lock
  take_container_lock "$selected_vmid"
  render_authority

  local manifest
  if ! manifest="$(eval_node_manifest)"; then
    die "failed to evaluate node manifest for ${NODE_NAME}"
  fi
  if ! jq -e --arg vmid "$selected_vmid" '.containers[$vmid] != null' >/dev/null <<<"$manifest"; then
    die "VMID ${selected_vmid} is not present in proxnix.nodes.${NODE_NAME}"
  fi

  if ! ensure_container_exists "$selected_vmid" "$manifest" "$recreate_missing"; then
    return
  fi

  local desired_system hostname source_revision status_file live_current previous_system prior_previous
  hostname="$(manifest_hostname "$selected_vmid" "$manifest")"
  source_revision="$(manifest_source_revision "$selected_vmid" "$manifest")"
  desired_system="$(manifest_system "$selected_vmid" "$manifest")"
  [[ -n "$desired_system" ]] || die "manifest for VMID ${selected_vmid} is missing system"

  ensure_container_running_for_exec "$selected_vmid"
  live_current="$(current_system "$selected_vmid" | tr -d '\r\n')"
  status_file="${STATUS_DIR}/${selected_vmid}.json"
  prior_previous=""
  if [[ -f "$status_file" ]]; then
    prior_previous="$(jq -r '.previousSystem // empty' "$status_file" 2>/dev/null || true)"
  fi

  if [[ "$live_current" == "$desired_system" ]]; then
    write_noop_status "$selected_vmid" "$hostname" "$source_revision" "$desired_system" "$desired_system" "$prior_previous"
    printf '%s noop current system matches desired\n' "$selected_vmid"
    return
  fi

  previous_system="$prior_previous"
  if [[ -n "$live_current" && "$live_current" != "$desired_system" ]]; then
    previous_system="$live_current"
  fi
  reconcile_build_phase "$selected_vmid" "$manifest" "$desired_system" "$hostname" "$source_revision" "$live_current" "$previous_system"
  reconcile_seed_phase "$selected_vmid" "$desired_system"
  reconcile_activate_phase "$selected_vmid" "$desired_system" "$previous_system"
  printf '%s activated %s\n' "$selected_vmid" "$desired_system"
}

reconcile_all_running() {
  local recreate_missing="$1"
  need_cmd jq
  need_cmd pct
  need_cmd awk
  render_authority

  local manifest
  if ! manifest="$(eval_node_manifest)"; then
    die "failed to evaluate node manifest for ${NODE_NAME}"
  fi

  local vmids=()
  mapfile -t vmids < <(jq -r '.containers | keys[]' <<<"$manifest" | sort -n)
  if [[ ${#vmids[@]} -eq 0 ]]; then
    printf 'no managed containers in proxnix.nodes.%s\n' "$NODE_NAME"
    return
  fi

  local vmid state
  for vmid in "${vmids[@]}"; do
    if ! is_local_container "$vmid"; then
      printf '%s skip not-local\n' "$vmid"
      continue
    fi
    state="$(container_state "$vmid" | tr -d '\r\n')"
    if [[ "$state" != "running" ]]; then
      printf '%s skip %s\n' "$vmid" "${state:-not-running}"
      continue
    fi
    reconcile_selected "$vmid" "$recreate_missing"
  done
}

rollback_container() {
  local selected_vmid="$1"
  [[ -n "$selected_vmid" ]] || die "--rollback requires --vmid"
  need_cmd jq
  need_cmd flock
  need_cmd pct
  take_global_lock
  take_container_lock "$selected_vmid"
  if ! selected_container_is_local_or_skip "$selected_vmid"; then
    return
  fi

  local status_file="${STATUS_DIR}/${selected_vmid}.json"
  [[ -f "$status_file" ]] || die "status not found for VMID ${selected_vmid}"
  local previous_system
  previous_system="$(jq -r '.previousSystem // empty' "$status_file")"
  [[ -n "$previous_system" ]] || die "status for VMID ${selected_vmid} does not contain previousSystem"

  ensure_container_running_for_exec "$selected_vmid"
  local rollback_output
  if ! rollback_output="$(seed_closure "$selected_vmid" "$previous_system" 2>&1)"; then
    update_deploy_status "$selected_vmid" "rollback-failed" "rollback seed failed: ${rollback_output}"
    printf '%s rollback seed failed\n' "$selected_vmid" >&2
    return 2
  fi
  if ! rollback_output="$(activate_system "$selected_vmid" "$previous_system" 2>&1)"; then
    update_deploy_status "$selected_vmid" "rollback-failed" "rollback activation failed: ${rollback_output}"
    printf '%s rollback activation failed\n' "$selected_vmid" >&2
    return 2
  fi
  if ! verify_system "$selected_vmid" "$previous_system"; then
    update_deploy_status "$selected_vmid" "rollback-failed" "rollback verification failed"
    printf '%s rollback verification failed\n' "$selected_vmid" >&2
    return 2
  fi

  write_rollback_status "$selected_vmid" "$previous_system"
  printf '%s rolled back %s\n' "$selected_vmid" "$previous_system"
}

main() {
  local vmid="" dry_run=0 build_only=0 seed_only=0 activate_only=0 rollback=0 show_status=0 recreate_missing=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        dry_run=1
        shift
        ;;
      --build-only)
        build_only=1
        shift
        ;;
      --seed-only)
        seed_only=1
        shift
        ;;
      --activate-only)
        activate_only=1
        shift
        ;;
      --recreate-missing)
        recreate_missing=1
        shift
        ;;
      --vmid)
        [[ $# -ge 2 ]] || die "--vmid requires a value"
        vmid="$2"
        [[ "$vmid" =~ ^[0-9]+$ ]] || die "invalid VMID: $vmid"
        shift 2
        ;;
      --node-name)
        [[ $# -ge 2 ]] || die "--node-name requires a value"
        NODE_NAME="$2"
        shift 2
        ;;
      --rollback)
        rollback=1
        shift
        ;;
      --status)
        show_status=1
        shift
        status "$@"
        return
        ;;
      -h|--help)
        usage
        return
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  if [[ "$rollback" -eq 1 && -z "$vmid" ]]; then
    die "--rollback requires --vmid"
  fi

  if [[ "$show_status" -eq 1 ]]; then
    return
  fi

  if [[ "$rollback" -eq 1 ]]; then
    rollback_container "$vmid"
    return
  fi

  if [[ "$dry_run" -eq 1 ]]; then
    dry_run "$vmid"
    return
  fi

  if [[ "$build_only" -eq 1 ]]; then
    build_only "$vmid"
    return
  fi

  if [[ "$seed_only" -eq 1 ]]; then
    seed_only "$vmid"
    return
  fi

  if [[ "$activate_only" -eq 1 ]]; then
    activate_only "$vmid"
    return
  fi

  if [[ -n "$vmid" ]]; then
    reconcile_selected "$vmid" "$recreate_missing"
  else
    reconcile_all_running "$recreate_missing"
  fi
}

main "$@"
