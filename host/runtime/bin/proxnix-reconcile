#!/usr/bin/env bash
# proxnix-reconcile -- host-side reconciler entrypoint.
#
# Host-side orchestration for authority rendering, manifest evaluation, builds,
# closure seeding, and activation.

set -euo pipefail

SELF_NAME="${0##*/}"
NIXLXC_DIR="${PROXNIX_DIR:-/var/lib/proxnix}"
AUTHORITY_DIR="${PROXNIX_AUTHORITY_DIR:-${NIXLXC_DIR}/authority}"
STATUS_DIR="${PROXNIX_STATUS_DIR:-${NIXLXC_DIR}/status}"
PVE_LXC_DIR="${PROXNIX_PVE_LXC_DIR:-/etc/pve/lxc}"
LOCK_DIR="${PROXNIX_RUN_DIR:-/run/proxnix}"
NODE_NAME="${PROXNIX_NODE_NAME:-$(hostname -s 2>/dev/null || hostname)}"
AUTHORITY_RENDER="${PROXNIX_AUTHORITY_RENDER:-/usr/local/sbin/proxnix-authority-render}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat >&2 <<EOF
Usage:
  ${SELF_NAME} [--dry-run] [--vmid <id>] [--node-name <name>]
  ${SELF_NAME} --build-only --vmid <id> [--node-name <name>]
  ${SELF_NAME} --status [--vmid <id>]
  ${SELF_NAME} --rollback --vmid <id>

Dry-run renders and evaluates the authority manifest, then prints planned
container actions without building, starting, stopping, creating, or modifying
containers.
EOF
}

die() {
  echo "error: $*" >&2
  exit 2
}

need_cmd() {
  local cmd="$1"
  command -v "$cmd" >/dev/null 2>&1 || die "${cmd} not found"
}

json_or_null_arg() {
  local value="$1"
  if [[ -n "$value" ]]; then
    printf '%s\n' "$value"
  else
    printf 'null\n'
  fi
}

render_authority() {
  if [[ -x "$AUTHORITY_RENDER" ]]; then
    "$AUTHORITY_RENDER" \
      --root "$NIXLXC_DIR" \
      --authority "$AUTHORITY_DIR" \
      --pve-lxc-dir "$PVE_LXC_DIR" \
      --node-name "$NODE_NAME" >/dev/null
    return
  fi

  local repo_renderer="${SCRIPT_DIR}/../lib/proxnix_authority_render.py"
  if [[ -f "$repo_renderer" ]]; then
    need_cmd python3
    python3 "$repo_renderer" \
      --root "$NIXLXC_DIR" \
      --authority "$AUTHORITY_DIR" \
      --pve-lxc-dir "$PVE_LXC_DIR" \
      --node-name "$NODE_NAME" >/dev/null
    return
  fi

  die "proxnix-authority-render not found"
}

node_attr_fragment() {
  if [[ "$NODE_NAME" =~ ^[A-Za-z_][A-Za-z0-9_\'-]*$ ]]; then
    printf 'proxnix.nodes.%s\n' "$NODE_NAME"
  else
    printf 'proxnix.nodes."%s"\n' "${NODE_NAME//\"/\\\"}"
  fi
}

eval_node_manifest() {
  need_cmd nix
  local attr
  attr="$(node_attr_fragment)"
  nix eval --json "${AUTHORITY_DIR}#${attr}"
}

take_global_lock() {
  need_cmd flock
  mkdir -p "$LOCK_DIR"
  exec 9>"${LOCK_DIR}/reconcile.lock"
  flock -n 9 || die "another proxnix-reconcile run is active"
}

take_container_lock() {
  local vmid="$1"
  mkdir -p "$LOCK_DIR"
  exec 8>"${LOCK_DIR}/reconcile-${vmid}.lock"
  flock -n 8 || die "another proxnix-reconcile run is active for VMID ${vmid}"
}

status() {
  local vmid=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --vmid)
        [[ $# -ge 2 ]] || die "--vmid requires a value"
        vmid="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown status argument: $1"
        ;;
    esac
  done

  if [[ -n "$vmid" ]]; then
    [[ "$vmid" =~ ^[0-9]+$ ]] || die "invalid VMID: $vmid"
    local path="${STATUS_DIR}/${vmid}.json"
    [[ -f "$path" ]] || die "status not found for VMID ${vmid}: ${path}"
    cat "$path"
    printf '\n'
    return
  fi

  if [[ ! -d "$STATUS_DIR" ]]; then
    printf '[]\n'
    return
  fi

  if command -v jq >/dev/null 2>&1; then
    jq -s '.' "${STATUS_DIR}"/*.json 2>/dev/null || printf '[]\n'
  else
    local first=1 file
    printf '['
    for file in "${STATUS_DIR}"/*.json; do
      [[ -f "$file" ]] || continue
      if [[ "$first" -eq 0 ]]; then
        printf ','
      fi
      first=0
      cat "$file"
    done
    printf ']\n'
  fi
}

dry_run() {
  local selected_vmid="$1"
  need_cmd jq
  need_cmd readlink
  take_global_lock
  render_authority

  local manifest
  if ! manifest="$(eval_node_manifest)"; then
    die "failed to evaluate node manifest for ${NODE_NAME}"
  fi

  local vmids=()
  if [[ -n "$selected_vmid" ]]; then
    if ! jq -e --arg vmid "$selected_vmid" '.containers[$vmid] != null' >/dev/null <<<"$manifest"; then
      die "VMID ${selected_vmid} is not present in proxnix.nodes.${NODE_NAME}"
    fi
    vmids=("$selected_vmid")
  else
    mapfile -t vmids < <(jq -r '.containers | keys[]' <<<"$manifest" | sort -n)
  fi

  if [[ ${#vmids[@]} -eq 0 ]]; then
    printf 'no managed containers in proxnix.nodes.%s\n' "$NODE_NAME"
    return
  fi

  local vmid conf status_file desired_system last_desired current_system
  for vmid in "${vmids[@]}"; do
    conf="${PVE_LXC_DIR}/${vmid}.conf"
    status_file="${STATUS_DIR}/${vmid}.json"
    desired_system="$(jq -r --arg vmid "$vmid" '.containers[$vmid].system // "unknown until build"' <<<"$manifest")"
    last_desired=""
    current_system=""
    if [[ -f "$status_file" ]]; then
      last_desired="$(jq -r '.desiredSystem // empty' "$status_file" 2>/dev/null || true)"
      current_system="$(jq -r '.currentSystem // empty' "$status_file" 2>/dev/null || true)"
    fi

    if [[ "$last_desired" == "$desired_system" && -n "$current_system" && "$current_system" == "$desired_system" ]]; then
      printf '%s noop current system matches desired\n' "$vmid"
      continue
    fi

    printf '%s build %s\n' "$vmid" "$desired_system"
    if [[ -f "$conf" ]]; then
      printf '%s keep existing CT\n' "$vmid"
    else
      printf '%s create missing CT\n' "$vmid"
    fi
    printf '%s seed desired closure\n' "$vmid"
    printf '%s activate desired system\n' "$vmid"
  done
}

write_build_status() {
  local vmid="$1" hostname="$2" source_revision="$3" desired_system="$4" current_system="$5" previous_system="$6" last_deploy_status="$7"
  need_cmd jq
  need_cmd date
  mkdir -p "$STATUS_DIR"

  local tmp="${STATUS_DIR}/${vmid}.json.tmp"
  jq -n \
    --argjson vmid "$vmid" \
    --arg hostname "$hostname" \
    --argjson sourceRevision "$(json_or_null_arg "$source_revision")" \
    --arg desiredSystem "$desired_system" \
    --arg currentSystem "$current_system" \
    --arg previousSystem "$previous_system" \
    --arg lastDeployStatus "${last_deploy_status:-not-run}" \
    --arg updatedAt "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{
      vmid: $vmid,
      hostname: $hostname,
      sourceRevision: $sourceRevision,
      desiredSystem: $desiredSystem,
      currentSystem: (if $currentSystem == "" then null else $currentSystem end),
      previousSystem: (if $previousSystem == "" then null else $previousSystem end),
      lastBuildStatus: "ok",
      lastDeployStatus: $lastDeployStatus,
      lastError: null,
      updatedAt: $updatedAt
    }' > "$tmp"
  mv "$tmp" "${STATUS_DIR}/${vmid}.json"
}

build_only() {
  local selected_vmid="$1"
  [[ -n "$selected_vmid" ]] || die "--build-only requires --vmid"
  need_cmd jq
  need_cmd nix
  need_cmd flock
  take_global_lock
  take_container_lock "$selected_vmid"
  render_authority

  local manifest
  if ! manifest="$(eval_node_manifest)"; then
    die "failed to evaluate node manifest for ${NODE_NAME}"
  fi
  if ! jq -e --arg vmid "$selected_vmid" '.containers[$vmid] != null' >/dev/null <<<"$manifest"; then
    die "VMID ${selected_vmid} is not present in proxnix.nodes.${NODE_NAME}"
  fi

  local system_attr system_path hostname source_revision status_file current_system previous_system last_deploy_status
  system_attr="$(jq -r --arg vmid "$selected_vmid" '.containers[$vmid].systemAttr // empty' <<<"$manifest")"
  [[ -n "$system_attr" ]] || die "manifest for VMID ${selected_vmid} is missing systemAttr"
  hostname="$(jq -r --arg vmid "$selected_vmid" '.containers[$vmid].hostname // ("ct" + $vmid)' <<<"$manifest")"
  source_revision="$(jq -c --arg vmid "$selected_vmid" '.containers[$vmid].sourceRevision // null' <<<"$manifest")"

  system_path="$(nix build --print-out-paths "${AUTHORITY_DIR}#${system_attr}")"
  [[ -n "$system_path" ]] || die "nix build produced no output path for ${system_attr}"

  status_file="${STATUS_DIR}/${selected_vmid}.json"
  current_system=""
  previous_system=""
  last_deploy_status="not-run"
  if [[ -f "$status_file" ]]; then
    current_system="$(jq -r '.currentSystem // empty' "$status_file" 2>/dev/null || true)"
    previous_system="$(jq -r '.previousSystem // empty' "$status_file" 2>/dev/null || true)"
    last_deploy_status="$(jq -r '.lastDeployStatus // "not-run"' "$status_file" 2>/dev/null || true)"
  fi

  write_build_status "$selected_vmid" "$hostname" "$source_revision" "$system_path" "$current_system" "$previous_system" "$last_deploy_status"
  printf '%s built %s\n' "$selected_vmid" "$system_path"
}

main() {
  local vmid="" dry_run=0 build_only=0 rollback=0 show_status=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        dry_run=1
        shift
        ;;
      --build-only)
        build_only=1
        shift
        ;;
      --vmid)
        [[ $# -ge 2 ]] || die "--vmid requires a value"
        vmid="$2"
        [[ "$vmid" =~ ^[0-9]+$ ]] || die "invalid VMID: $vmid"
        shift 2
        ;;
      --node-name)
        [[ $# -ge 2 ]] || die "--node-name requires a value"
        NODE_NAME="$2"
        shift 2
        ;;
      --rollback)
        rollback=1
        shift
        ;;
      --status)
        show_status=1
        shift
        status "$@"
        return
        ;;
      -h|--help)
        usage
        return
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done

  if [[ "$rollback" -eq 1 && -z "$vmid" ]]; then
    die "--rollback requires --vmid"
  fi

  if [[ "$show_status" -eq 1 ]]; then
    return
  fi

  if [[ "$dry_run" -eq 1 ]]; then
    dry_run "$vmid"
    return
  fi

  if [[ "$build_only" -eq 1 ]]; then
    build_only "$vmid"
    return
  fi

  die "seed/activation support is not implemented yet; use --dry-run or --build-only --vmid <id>"
}

main "$@"
