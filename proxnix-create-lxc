#!/bin/bash
# proxnix-create-lxc — Create a Proxmox NixOS LXC prepared for proxnix.
#
# Run on a Proxmox host as root. This helper intentionally does not install
# proxnix; it only verifies that an existing proxnix install is healthy enough
# to manage the new container.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SELF_NAME="${0##*/}"

pick_bin() {
  local candidate
  for candidate in "$@"; do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

ID_BIN=""
MKDIR_BIN=""
PCT_BIN=""
PVEVERSION_BIN=""
PVEAM_BIN=""
PVESM_BIN=""
PVESH_BIN=""
AWK_BIN=""
STAT_BIN=""
COMMON_LIB=""

init_bins() {
  ID_BIN="$(pick_bin /usr/bin/id /bin/id)" || die "id not found"
  MKDIR_BIN="$(pick_bin /usr/bin/mkdir /bin/mkdir)" || die "mkdir not found"
  PCT_BIN="$(pick_bin /usr/sbin/pct /usr/bin/pct)" || die "pct not found — is this a Proxmox host?"
  PVEVERSION_BIN="$(pick_bin /usr/sbin/pveversion /usr/bin/pveversion)" || die "pveversion not found — is this a Proxmox host?"
  PVEAM_BIN="$(pick_bin /usr/sbin/pveam /usr/bin/pveam)" || die "pveam not found — is this a Proxmox host?"
  PVESM_BIN="$(pick_bin /usr/sbin/pvesm /usr/bin/pvesm)" || die "pvesm not found — is this a Proxmox host?"
  PVESH_BIN="$(pick_bin /usr/bin/pvesh /usr/sbin/pvesh || true)"
  AWK_BIN="$(pick_bin /usr/bin/awk /bin/awk)" || die "awk not found"
  STAT_BIN="$(pick_bin /usr/bin/stat /bin/stat)" || die "stat not found"
  if [[ -f /usr/local/lib/proxnix/nixos-proxnix-common.sh ]]; then
    COMMON_LIB="/usr/local/lib/proxnix/nixos-proxnix-common.sh"
  elif [[ -f "${SCRIPT_DIR}/lxc/hooks/nixos-proxnix-common.sh" ]]; then
    COMMON_LIB="${SCRIPT_DIR}/lxc/hooks/nixos-proxnix-common.sh"
  else
    die "nixos-proxnix-common.sh not found"
  fi
}

resolve_bootstrap_guest_secrets() {
  if [[ -x /usr/local/sbin/bootstrap-guest-secrets.sh ]]; then
    printf '%s\n' /usr/local/sbin/bootstrap-guest-secrets.sh
    return
  fi

  if [[ -x "${SCRIPT_DIR}/bootstrap-guest-secrets.sh" ]]; then
    printf '%s\n' "${SCRIPT_DIR}/bootstrap-guest-secrets.sh"
    return
  fi

  printf '%s\n' bootstrap-guest-secrets.sh
}

ensure_container_age_identity() {
  # shellcheck source=/dev/null
  source "$COMMON_LIB"
  proxnix_ensure_container_age_identity "$VMID"
}

VMID=""
HOSTNAME=""
TEMPLATE=""
STORAGE=""
DISK="8"
MEMORY="2048"
SWAP="512"
CORES="2"
BRIDGE="vmbr0"
IP_CONFIG="dhcp"
GATEWAY=""
SSH_PUBLIC_KEYS=""
UNPRIVILEGED="1"
ENABLE_NESTING=0
START_AFTER_CREATE=1
CREATE_CONFIG_DIR=1
DRY_RUN=0
ASSUME_YES=0
TEMPLATE_AUTO=0
STORAGE_AUTO=0

die() {
  echo "ERROR: $*" >&2
  exit 1
}

msg_info() {
  printf ' → %s\n' "$*"
}

msg_ok() {
  printf ' ✓ %s\n' "$*"
}

info() {
  echo "  $*"
}

usage() {
  printf '%s\n' \
    "Usage:" \
    "  ${SELF_NAME} [options]" \
    "" \
    "Required:" \
    "  --vmid ID                 Numeric container VMID" \
    "  --hostname NAME           Container hostname" \
    "" \
    "Optional:" \
    "  --template STORAGE:FILE   Proxmox LXC template reference" \
    "                            (omit to auto-detect the newest local NixOS template)" \
    "  --storage STORAGE         Rootfs storage name used with --disk" \
    "                            (omit to auto-detect a rootdir-capable storage)" \
    "  --disk GB                 Rootfs size in GB (default: ${DISK})" \
    "  --memory MB               RAM in MB (default: ${MEMORY})" \
    "  --swap MB                 Swap in MB (default: ${SWAP})" \
    "  --cores N                 CPU cores (default: ${CORES})" \
    "  --bridge NAME             Network bridge (default: ${BRIDGE})" \
    "  --ip CIDR|dhcp            IP config for net0 (default: ${IP_CONFIG})" \
    "  --gw ADDRESS              Gateway for static IP config" \
    "  --ssh-public-keys PATH    SSH public keys file for the CT root account" \
    "  --unprivileged 0|1        Create privileged or unprivileged CT (default: ${UNPRIVILEGED})" \
    "  --nesting                 Deprecated; nesting=1 is always enabled for NixOS" \
    "  --start                   Start the CT after creation (default)" \
    "  --no-start                Create the CT but do not start it" \
    "  --no-config-dir           Skip creating /etc/pve/proxnix/containers/<vmid>/" \
    "  --dry-run                 Print the commands without running them" \
    "  --yes                     Skip the confirmation prompt" \
    "  --help                    Show this help" \
    "" \
    "Examples:" \
    "  ${SELF_NAME} \\" \
    "    --vmid 120 \\" \
    "    --hostname nixos-media \\" \
    "    --disk 16 \\" \
    "    --memory 4096 \\" \
    "    --cores 4 \\" \
    "    --start" \
    "" \
    "  # Override the auto-detected template/storage when needed:" \
    "  ${SELF_NAME} --vmid 121 --hostname nixos-alt --template local:vztmpl/nixos-custom.tar.xz --storage local-lvm"
}

prompt_if_empty() {
  local var_name="$1" prompt="$2" default="${3:-}"
  local value="${!var_name}"

  if [[ -n "$value" ]]; then
    return
  fi

  if [[ -n "$default" ]]; then
    read -r -p "$prompt [$default]: " value
    value="${value:-$default}"
  else
    read -r -p "$prompt: " value
  fi

  printf -v "$var_name" '%s' "$value"
}

next_vmid_default() {
  if [[ -n "$PVESH_BIN" ]]; then
    "$PVESH_BIN" get /cluster/nextid 2>/dev/null || true
  fi
}

normalize_template_volid() {
  local storage="$1" candidate="$2"

  if [[ "$candidate" == *:* ]]; then
    printf '%s\n' "$candidate"
    return
  fi

  candidate="${candidate##*/}"
  printf '%s:vztmpl/%s\n' "$storage" "$candidate"
}

file_mtime() {
  local path="$1"
  local mtime

  mtime="$("$STAT_BIN" -c '%Y' "$path" 2>/dev/null || true)"
  if [[ -n "$mtime" ]]; then
    printf '%s\n' "$mtime"
    return
  fi

  mtime="$("$STAT_BIN" -f '%m' "$path" 2>/dev/null || true)"
  if [[ -n "$mtime" ]]; then
    printf '%s\n' "$mtime"
    return
  fi

  printf '0\n'
}

detect_latest_template() {
  local storage candidate volid path mtime
  local best_volid="" best_mtime="-1"

  while IFS= read -r storage; do
    [[ -n "$storage" ]] || continue

    while IFS= read -r candidate; do
      [[ -n "$candidate" ]] || continue
      case "${candidate,,}" in
        *nixos*.tar.*) ;;
        *) continue ;;
      esac

      volid="$(normalize_template_volid "$storage" "$candidate")"
      path="$("$PVESM_BIN" path "$volid" 2>/dev/null || true)"
      if [[ -n "$path" && -f "$path" ]]; then
        mtime="$(file_mtime "$path")"
      else
        mtime="0"
      fi

      if (( mtime > best_mtime )); then
        best_volid="$volid"
        best_mtime="$mtime"
      elif (( mtime == best_mtime )) && [[ -n "$best_volid" && "$volid" > "$best_volid" ]]; then
        best_volid="$volid"
      fi
    done < <("$PVEAM_BIN" list "$storage" 2>/dev/null | "$AWK_BIN" 'NR>1 { print $1 }')
  done < <("$PVESM_BIN" status --content vztmpl 2>/dev/null | "$AWK_BIN" 'NR>1 { print $1 }')

  [[ -n "$best_volid" ]] || die "could not auto-detect a local NixOS template; pass --template explicitly or download one first with pveam"
  printf '%s\n' "$best_volid"
}

auto_detect_template_if_needed() {
  case "$TEMPLATE" in
    ""|auto|latest)
      TEMPLATE="$(detect_latest_template)"
      TEMPLATE_AUTO=1
      ;;
  esac
}

detect_rootfs_storage() {
  local storage candidate
  local -a storages=()

  while IFS= read -r storage; do
    [[ -n "$storage" ]] || continue
    storages+=("$storage")
  done < <("$PVESM_BIN" status --content rootdir 2>/dev/null | "$AWK_BIN" 'NR>1 && $3 == "active" { print $1 }')

  if [[ ${#storages[@]} -eq 0 ]]; then
    die "could not auto-detect a rootdir-capable active storage; pass --storage explicitly"
  fi

  for candidate in local-lvm local-zfs; do
    for storage in "${storages[@]}"; do
      if [[ "$storage" == "$candidate" ]]; then
        printf '%s\n' "$storage"
        return
      fi
    done
  done

  printf '%s\n' "${storages[0]}"
}

auto_detect_storage_if_needed() {
  case "$STORAGE" in
    ""|auto|latest)
      STORAGE="$(detect_rootfs_storage)"
      STORAGE_AUTO=1
      ;;
  esac
}

resolve_doctor() {
  if [[ -x /usr/local/sbin/proxnix-doctor ]]; then
    printf '%s\n' /usr/local/sbin/proxnix-doctor
    return
  fi

  if [[ -x "${SCRIPT_DIR}/proxnix-doctor" ]]; then
    printf '%s\n' "${SCRIPT_DIR}/proxnix-doctor"
    return
  fi

  die "proxnix-doctor is not available. Install proxnix separately before using this helper."
}

run_proxnix_check() {
  local doctor_bin
  doctor_bin="$(resolve_doctor)"

  echo ""
  echo "Checking proxnix installation..."
  if ! "$doctor_bin" --host-only; then
    die "proxnix host checks failed. This helper does not install proxnix; fix the existing install and re-run."
  fi
}

validate_inputs() {
  [[ "$VMID" =~ ^[0-9]+$ ]] || die "--vmid must be numeric"
  [[ -n "$HOSTNAME" ]] || die "--hostname is required"
  [[ -n "$STORAGE" ]] || die "--storage is required"
  [[ "$DISK" =~ ^[0-9]+([.][0-9]+)?$ ]] || die "--disk must be a size in GB"
  [[ "$MEMORY" =~ ^[0-9]+$ ]] || die "--memory must be numeric"
  [[ "$SWAP" =~ ^[0-9]+$ ]] || die "--swap must be numeric"
  [[ "$CORES" =~ ^[0-9]+$ ]] || die "--cores must be numeric"
  [[ "$UNPRIVILEGED" == "0" || "$UNPRIVILEGED" == "1" ]] || die "--unprivileged must be 0 or 1"
  [[ -z "$GATEWAY" || "$IP_CONFIG" != "dhcp" ]] || die "--gw requires a static --ip value"

  if [[ -n "$SSH_PUBLIC_KEYS" && ! -f "$SSH_PUBLIC_KEYS" ]]; then
    die "--ssh-public-keys file not found: $SSH_PUBLIC_KEYS"
  fi

  if [[ -e "/etc/pve/lxc/${VMID}.conf" ]]; then
    die "container VMID ${VMID} already exists"
  fi
}

verify_container_created() {
  if [[ $DRY_RUN -eq 1 ]]; then
    return
  fi

  [[ -f "/etc/pve/lxc/${VMID}.conf" ]] || die "pct create returned successfully, but /etc/pve/lxc/${VMID}.conf was not created"
}

verify_host_side_dirs() {
  [[ $DRY_RUN -eq 1 ]] && return
  [[ $CREATE_CONFIG_DIR -eq 1 ]] || return

  [[ -d "/etc/pve/proxnix/containers/${VMID}/quadlets" ]] || die "host-side quadlets dir was not created for VMID ${VMID}"
  [[ -d "/etc/pve/proxnix/containers/${VMID}/dropins" ]] || die "host-side dropins dir was not created for VMID ${VMID}"
}

verify_container_started() {
  local state

  [[ $DRY_RUN -eq 1 ]] && return
  [[ $START_AFTER_CREATE -eq 1 ]] || return

  state="$("$PCT_BIN" status "$VMID" 2>/dev/null | "$AWK_BIN" '{print $2}')"
  [[ "$state" == "running" ]] || die "container ${VMID} was created, but failed to start"
}

build_net0() {
  local net0="name=eth0,bridge=${BRIDGE},ip=${IP_CONFIG}"
  if [[ -n "$GATEWAY" ]]; then
    net0="${net0},gw=${GATEWAY}"
  fi
  printf '%s\n' "$net0"
}

print_plan() {
  local template_display storage_display

  template_display="$TEMPLATE"
  storage_display="$STORAGE"
  [[ $TEMPLATE_AUTO -eq 1 ]] && template_display="${template_display} (auto)"
  [[ $STORAGE_AUTO -eq 1 ]] && storage_display="${storage_display} (auto)"

  echo ""
  echo "proxnix NixOS LXC plan"
  echo "======================"
  info "VMID:           ${VMID}"
  info "Hostname:       ${HOSTNAME}"
  info "Template:       ${template_display}"
  info "Rootfs:         ${storage_display}:${DISK}"
  info "Memory / swap:  ${MEMORY} / ${SWAP} MB"
  info "Cores:          ${CORES}"
  info "Bridge:         ${BRIDGE}"
  info "IP config:      ${IP_CONFIG}"
  [[ -n "$GATEWAY" ]] && info "Gateway:        ${GATEWAY}"
  info "Unprivileged:   ${UNPRIVILEGED}"
  info "Nesting:        1 (always enabled)"
  info "Create config:  ${CREATE_CONFIG_DIR}"
  info "Start after:    ${START_AFTER_CREATE}"
  [[ -n "$SSH_PUBLIC_KEYS" ]] && info "SSH keys:       ${SSH_PUBLIC_KEYS}"
  [[ $DRY_RUN -eq 1 ]] && info "Mode:           dry-run"
}

confirm_plan() {
  local answer
  [[ $ASSUME_YES -eq 1 ]] && return

  echo ""
  read -r -p "Create this NixOS container? [y/N]: " answer
  case "$answer" in
    y|Y|yes|YES) ;;
    *) die "aborted by user" ;;
  esac
}

run_cmd() {
  if [[ $DRY_RUN -eq 1 ]]; then
    printf '+'
    printf ' %q' "$@"
    printf '\n'
    return
  fi

  "$@"
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --vmid)
        VMID="${2:?missing value for --vmid}"
        shift 2
        ;;
      --hostname)
        HOSTNAME="${2:?missing value for --hostname}"
        shift 2
        ;;
      --template)
        TEMPLATE="${2:?missing value for --template}"
        shift 2
        ;;
      --storage)
        STORAGE="${2:?missing value for --storage}"
        shift 2
        ;;
      --disk)
        DISK="${2:?missing value for --disk}"
        shift 2
        ;;
      --memory)
        MEMORY="${2:?missing value for --memory}"
        shift 2
        ;;
      --swap)
        SWAP="${2:?missing value for --swap}"
        shift 2
        ;;
      --cores)
        CORES="${2:?missing value for --cores}"
        shift 2
        ;;
      --bridge)
        BRIDGE="${2:?missing value for --bridge}"
        shift 2
        ;;
      --ip)
        IP_CONFIG="${2:?missing value for --ip}"
        shift 2
        ;;
      --gw)
        GATEWAY="${2:?missing value for --gw}"
        shift 2
        ;;
      --ssh-public-keys)
        SSH_PUBLIC_KEYS="${2:?missing value for --ssh-public-keys}"
        shift 2
        ;;
      --unprivileged)
        UNPRIVILEGED="${2:?missing value for --unprivileged}"
        shift 2
        ;;
      --nesting)
        ENABLE_NESTING=1
        shift
        ;;
      --start)
        START_AFTER_CREATE=1
        shift
        ;;
      --no-start)
        START_AFTER_CREATE=0
        shift
        ;;
      --no-config-dir)
        CREATE_CONFIG_DIR=0
        shift
        ;;
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      --yes)
        ASSUME_YES=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1"
        ;;
    esac
  done
}

prompt_for_missing_values() {
  local default_vmid
  default_vmid="$(next_vmid_default)"

  prompt_if_empty VMID "VMID" "$default_vmid"
  prompt_if_empty HOSTNAME "Hostname"
  prompt_if_empty DISK "Disk size in GB" "$DISK"
  prompt_if_empty MEMORY "Memory in MB" "$MEMORY"
  prompt_if_empty SWAP "Swap in MB" "$SWAP"
  prompt_if_empty CORES "CPU cores" "$CORES"
  prompt_if_empty BRIDGE "Bridge" "$BRIDGE"
  prompt_if_empty IP_CONFIG "IP config (dhcp or CIDR)" "$IP_CONFIG"

  if [[ "$IP_CONFIG" != "dhcp" ]]; then
    prompt_if_empty GATEWAY "Gateway"
  fi
}

create_container() {
  local net0
  local -a pct_create_cmd

  net0="$(build_net0)"
  pct_create_cmd=(
    "$PCT_BIN" create "$VMID" "$TEMPLATE"
    --ostype nixos
    --hostname "$HOSTNAME"
    --rootfs "${STORAGE}:${DISK}"
    --memory "$MEMORY"
    --swap "$SWAP"
    --cores "$CORES"
    --net0 "$net0"
    --unprivileged "$UNPRIVILEGED"
  )

  if [[ -n "$SSH_PUBLIC_KEYS" ]]; then
    pct_create_cmd+=(--ssh-public-keys "$SSH_PUBLIC_KEYS")
  fi

  pct_create_cmd+=(--features nesting=1)

  msg_info "Creating container ${VMID}"
  run_cmd "${pct_create_cmd[@]}"
  verify_container_created
  msg_ok "Created container ${VMID}"
}

create_host_side_dirs() {
  [[ $CREATE_CONFIG_DIR -eq 1 ]] || return
  msg_info "Creating proxnix config directories for ${VMID}"
  run_cmd "$MKDIR_BIN" -p "/etc/pve/proxnix/containers/${VMID}/quadlets"
  run_cmd "$MKDIR_BIN" -p "/etc/pve/proxnix/containers/${VMID}/dropins"
  verify_host_side_dirs
  msg_ok "Created host-side proxnix directories for ${VMID}"
}

create_host_side_identity() {
  [[ $DRY_RUN -eq 1 ]] && return
  msg_info "Ensuring host-generated container age identity for ${VMID}"
  ensure_container_age_identity
  msg_ok "Container ${VMID} age recipient ready on host"
}

start_container_if_requested() {
  [[ $START_AFTER_CREATE -eq 1 ]] || return
  msg_info "Starting container ${VMID}"
  run_cmd "$PCT_BIN" start "$VMID"
  verify_container_started
  msg_ok "Started container ${VMID}"
}

print_next_steps() {
  echo ""
  echo "Done."
  echo ""
  echo "Next steps:"
  echo "  1. Watch the automatic first-boot apply finish:"
  echo "       pct exec ${VMID} -- journalctl -u proxnix-apply-config.service -b -f"
  echo "       # If it ever needs a manual retry: pct enter ${VMID}"
  echo "       # then run /root/proxnix-bootstrap.sh"
  echo ""
  echo "  2. Add or update secrets for this container at any time:"
  echo "       proxnix-secrets set ${VMID} mysecret"
  echo "       # restart the CT after changing secrets so proxnix stages them"
  echo ""
  echo "  3. Re-run health checks:"
  echo "       $(resolve_doctor) ${VMID}"
}

main() {
  parse_args "$@"
  init_bins
  [[ "$("$ID_BIN" -u)" -eq 0 ]] || die "must be run as root"
  [[ -x "$PVEVERSION_BIN" ]] || die "pveversion not found — is this a Proxmox host?"
  [[ -x "$PCT_BIN" ]] || die "pct not found — is this a Proxmox host?"
  msg_info "Checking proxnix installation and local Proxmox defaults"
  auto_detect_storage_if_needed
  auto_detect_template_if_needed
  prompt_for_missing_values
  validate_inputs
  if [[ $STORAGE_AUTO -eq 1 ]]; then
    msg_ok "Using rootfs storage: ${STORAGE}"
  fi
  if [[ $TEMPLATE_AUTO -eq 1 ]]; then
    msg_ok "Using newest local NixOS template: ${TEMPLATE}"
  fi
  run_proxnix_check
  print_plan
  confirm_plan
  create_container
  create_host_side_dirs
  create_host_side_identity
  start_container_if_requested
  print_next_steps
}

main "$@"
