#!/run/current-system/sw/bin/bash
# proxnix-secrets-guest — In-container SOPS extraction and Podman secret driver.
#
# Installed into managed guests as /usr/local/bin/proxnix-secrets.

set -euo pipefail

PROXNIX_GUEST_SECRET_DIR="${PROXNIX_GUEST_SECRET_DIR:-/etc/proxnix/secrets}"
PROXNIX_IDS_DIR="${PROXNIX_IDS_DIR:-/etc/secrets/.ids}"
PROXNIX_PODMAN_SECRETS_JSON="${PROXNIX_PODMAN_SECRETS_JSON:-/var/lib/containers/storage/secrets/secrets.json}"
SOPS_AGE_KEY_FILE="${SOPS_AGE_KEY_FILE:-/etc/proxnix/secrets/age-keys.txt}"

die() { echo "error: $*" >&2; exit 1; }

usage() {
  cat >&2 <<EOF
Usage:
  $(basename "$0") ls
  $(basename "$0") ls-shared
  $(basename "$0") get             <name>
  $(basename "$0") get-shared      <name>
  $(basename "$0") podman          list|lookup|store|delete
EOF
  exit 1
}

need_tools() {
  command -v sops >/dev/null 2>&1 || die "sops not found"
  command -v python3 >/dev/null 2>&1 || die "python3 not found"
  [[ -f /etc/age/identity.txt ]] || die "/etc/age/identity.txt not found"
  [[ -f "$SOPS_AGE_KEY_FILE" ]] || die "SOPS age key file not found: $SOPS_AGE_KEY_FILE"
}

container_store() { printf '%s/container.sops.yaml' "$PROXNIX_GUEST_SECRET_DIR"; }
shared_store() { printf '%s/shared.sops.yaml' "$PROXNIX_GUEST_SECRET_DIR"; }

sops_path() {
  local name="$1"
  if [[ "$name" == \[* ]]; then
    printf '%s' "$name"
  else
    python3 - "$name" <<'PY'
import json, sys
print("[" + json.dumps(sys.argv[1]) + "]")
PY
  fi
}

top_level_keys_from_file() {
  local path="$1"
  [[ -f "$path" ]] || return 0
  awk '
    /^[A-Za-z0-9_.-]+:/ {
      key=$1
      sub(/:$/, "", key)
      if (key != "sops") print key
    }
  ' "$path" | sort -u
}

sops_get_from_file() {
  local file="$1" name="$2"
  [[ -f "$file" ]] || return 1
  sops decrypt --extract "$(sops_path "$name")" "$file"
}

cmd_ls() {
  {
    top_level_keys_from_file "$(shared_store)" | sed 's/$/\tshared/'
    top_level_keys_from_file "$(container_store)" | sed 's/$/\tcontainer/'
  } | awk -F '\t' '{ seen[$1]=$2 } END { for (k in seen) printf "%s\t%s\n", k, seen[k] }' | sort
}

cmd_ls_shared() {
  top_level_keys_from_file "$(shared_store)"
}

cmd_get() {
  local name="$1"
  sops_get_from_file "$(container_store)" "$name" \
    || sops_get_from_file "$(shared_store)" "$name" \
    || die "secret not found: $name"
}

cmd_get_shared() {
  local name="$1"
  sops_get_from_file "$(shared_store)" "$name" \
    || die "shared secret not found: $name"
}

podman_list() {
  mkdir -p "$PROXNIX_IDS_DIR"
  python3 - "$PROXNIX_IDS_DIR" <<'PY'
import sys
from pathlib import Path
ids = Path(sys.argv[1])
for path in sorted(ids.glob("*")):
    if path.is_file():
        print(path.name)
PY
}

podman_lookup() {
  local name_file name
  name_file="${PROXNIX_IDS_DIR}/${SECRET_ID:-}"
  if [[ -f "$name_file" ]]; then
    name="$(cat "$name_file")"
  elif [[ -f "$PROXNIX_PODMAN_SECRETS_JSON" ]]; then
    name="$(python3 - "$PROXNIX_PODMAN_SECRETS_JSON" "${SECRET_ID:-}" <<'PY'
import json
import sys

path, sid = sys.argv[1], sys.argv[2]
try:
    with open(path) as fh:
        data = json.load(fh)
except Exception:
    data = {}

name = (data.get("idToName") or {}).get(sid, "")
if not name:
    entry = (data.get("secrets") or {}).get(sid, {})
    name = entry.get("name", "")
print(name)
PY
)"
  else
    # Accept the logical name directly as a fallback so the helper keeps
    # working if Podman changes the shell-driver contract or the cache has not
    # yet been seeded by list/store.
    name="${SECRET_ID:-}"
  fi
  if [[ -z "$name" ]]; then
    name="${SECRET_ID:-}"
  fi
  [[ -n "$name" ]] || die "secret id not found: ${SECRET_ID:-unset}"
  cmd_get "$name"
}

podman_store() {
  die "podman secret store is read-only for proxnix-managed secrets; use proxnix-secrets on the host"
}

podman_delete() {
  [[ -n "${SECRET_ID:-}" ]] && rm -f "${PROXNIX_IDS_DIR}/${SECRET_ID}"
}

cmd_podman() {
  case "${1:-}" in
    list) podman_list ;;
    lookup) podman_lookup ;;
    store) podman_store ;;
    delete) podman_delete ;;
    *) usage ;;
  esac
}

need_tools
[[ $# -ge 1 ]] || usage
CMD="$1"; shift

case "$CMD" in
  ls) [[ $# -eq 0 ]] || usage; cmd_ls ;;
  ls-shared) [[ $# -eq 0 ]] || usage; cmd_ls_shared ;;
  get) [[ $# -eq 1 ]] || usage; cmd_get "$@" ;;
  get-shared) [[ $# -eq 1 ]] || usage; cmd_get_shared "$@" ;;
  podman) cmd_podman "$@" ;;
  *) usage ;;
esac
