#!/bin/bash
# LXC mount hook: copy proxnix's rendered state into the mounted guest rootfs.
#
# Consumes the staging directory produced by nixos-proxnix-prestart under
# /run/proxnix/<vmid>/ and syncs it into the mounted rootfs exposed at
# $LXC_ROOTFS_MOUNT. This hook is the only proxnix hook that writes into the
# guest filesystem.

set -uo pipefail
umask 022  # ensure files written into the container rootfs have sane default permissions

VMID="${LXC_NAME:-}"
ROOTFS="${LXC_ROOTFS_MOUNT:-}"
PROXNIX_LIB_DIR="/usr/local/lib/proxnix"
PROXNIX_SECRETS_GUEST_BIN="${PROXNIX_LIB_DIR}/proxnix-secrets-guest"
COMMON_LIB="${PROXNIX_LIB_DIR}/nixos-proxnix-common.sh"

log() { echo "[proxnix-mount][${VMID}] $*" >&2; }

if [[ -z "$VMID" ]]; then
    log "ERROR: LXC_NAME is not set."
    exit 1
fi

if [[ ! -f "$COMMON_LIB" ]]; then
    log "ERROR: ${COMMON_LIB} not found."
    log "Run ./install.sh on this Proxmox node to install local runtime files."
    exit 1
fi

# shellcheck source=/dev/null
source "$COMMON_LIB"

STAGE_DIR="$(proxnix_stage_dir "$VMID")"
RENDERED_DIR="${STAGE_DIR}/rendered"
MANAGED_DIR="${RENDERED_DIR}/managed"
QUADLET_DIR="${STAGE_DIR}/quadlet"
RUNTIME_DIR="${STAGE_DIR}/runtime"
RUNTIME_SYSTEMD_DIR="${RUNTIME_DIR}/systemd"
RUNTIME_BIN_DIR="${RUNTIME_DIR}/bin"
QUADLET_ROOT_DIR="${ROOTFS}/etc/proxnix/quadlets"
QUADLET_SYSTEMD_DIR="${ROOTFS}/etc/containers/systemd"
SECRETS_STAGE_DIR="${STAGE_DIR}/secrets"
KEYS_STAGE_DIR="${STAGE_DIR}/keys"
META_DIR="${STAGE_DIR}/meta"
DESIRED_CONFIG_HASH="$(tr -d '\r\n' < "${META_DIR}/current-config-hash" 2>/dev/null || true)"
CURRENT_CONFIG_HASH=""
needs_managed_sync=0

if [[ -z "$ROOTFS" || ! -d "$ROOTFS" ]]; then
    log "ERROR: rootfs mount not accessible."
    log "  LXC_ROOTFS_MOUNT=${LXC_ROOTFS_MOUNT:-unset}"
    exit 1
fi

if [[ ! -d "${ROOTFS}/etc" ]]; then
    log "ERROR: ${ROOTFS}/etc missing — rootfs does not look right."
    exit 1
fi

if [[ ! -d "$STAGE_DIR" ]]; then
    log "ERROR: staged proxnix state missing at ${STAGE_DIR}."
    log "Hint: ensure nixos-proxnix-prestart ran successfully before this hook."
    exit 1
fi

if [[ ! -f "${RENDERED_DIR}/configuration.nix" || ! -d "$MANAGED_DIR" || -z "$DESIRED_CONFIG_HASH" ]]; then
    log "ERROR: staged proxnix state is incomplete under ${STAGE_DIR}."
    exit 1
fi

# Clean up any real /etc/systemd/system/ directory left by an older proxnix
# version — NixOS setup-etc.pl requires it to be a symlink, not a directory.
if [[ -d "${ROOTFS}/etc/systemd/system" && ! -L "${ROOTFS}/etc/systemd/system" ]]; then
    rm -rf "${ROOTFS}/etc/systemd/system"
fi

mkdir -p \
    "${ROOTFS}/etc/nixos" \
    "${ROOTFS}/etc/nixos/managed" \
    "${ROOTFS}/etc/nixos/managed/dropins" \
    "${ROOTFS}/etc/proxnix" \
    "${ROOTFS}/etc/proxnix/secrets" \
    "${QUADLET_ROOT_DIR}" \
    "${ROOTFS}/etc/secrets" \
    "${ROOTFS}/usr/local/bin" \
    "${QUADLET_SYSTEMD_DIR}" \
    "${ROOTFS}/etc/systemd/system.attached" \
    "${ROOTFS}/etc/systemd/system.attached/multi-user.target.wants"
chmod 700 "${ROOTFS}/etc/proxnix/secrets" "${ROOTFS}/etc/secrets"

if [[ -f "$PROXNIX_SECRETS_GUEST_BIN" ]]; then
    proxnix_write_if_changed "$PROXNIX_SECRETS_GUEST_BIN" "${ROOTFS}/usr/local/bin/proxnix-secrets" "755" >/dev/null || true
else
    log "WARNING: ${PROXNIX_SECRETS_GUEST_BIN} missing; run ./install.sh on this node"
fi

CURRENT_CONFIG_HASH="$(tr -d '\r\n' < "${ROOTFS}/etc/proxnix/current-config-hash" 2>/dev/null || true)"
if [[ "$DESIRED_CONFIG_HASH" != "$CURRENT_CONFIG_HASH" \
   || ! -f "${ROOTFS}/etc/nixos/configuration.nix" \
   || ! -d "${ROOTFS}/etc/nixos/managed" ]]; then
    needs_managed_sync=1
fi

if [[ $needs_managed_sync -eq 1 ]]; then
    rm -rf "${ROOTFS}/etc/nixos/managed"
    mkdir -p "${ROOTFS}/etc/nixos/managed"
    cp "${RENDERED_DIR}/configuration.nix" "${ROOTFS}/etc/nixos/configuration.nix"
    cp -a "${MANAGED_DIR}/." "${ROOTFS}/etc/nixos/managed/"
    rm -f \
        "${ROOTFS}/etc/nixos/base.nix" \
        "${ROOTFS}/etc/nixos/common.nix" \
        "${ROOTFS}/etc/nixos/proxmox.nix" \
        "${ROOTFS}/etc/nixos/user.nix"
    rm -rf "${ROOTFS}/etc/nixos/dropins"
    proxnix_set_tree_readonly "${ROOTFS}/etc/nixos/managed"
    chmod 0444 "${ROOTFS}/etc/nixos/configuration.nix"
    log "Updated managed NixOS config (hash ${DESIRED_CONFIG_HASH})"
else
    log "Managed NixOS config unchanged (hash ${DESIRED_CONFIG_HASH})"
fi
proxnix_write_text_if_changed "${DESIRED_CONFIG_HASH}" "${ROOTFS}/etc/proxnix/current-config-hash" "644" >/dev/null || true

SYSTEMD_MANIFEST="${ROOTFS}/etc/proxnix/managed-systemd-attached.list"
BIN_MANIFEST="${ROOTFS}/etc/proxnix/managed-local-bin.list"

if [[ -f "$SYSTEMD_MANIFEST" ]]; then
    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        if [[ ! -f "${RUNTIME_SYSTEMD_DIR}/${name}" ]]; then
            rm -f "${ROOTFS}/etc/systemd/system.attached/${name}"
        fi
    done < "$SYSTEMD_MANIFEST"
fi

current_systemd_manifest=""
if [[ -d "$RUNTIME_SYSTEMD_DIR" ]]; then
    while IFS= read -r -d '' f; do
        name="$(basename "$f")"
        proxnix_write_if_changed "$f" "${ROOTFS}/etc/systemd/system.attached/${name}" "644" >/dev/null || true
        current_systemd_manifest+="${name}"$'\n'
    done < <(find "$RUNTIME_SYSTEMD_DIR" -maxdepth 1 -type f -name '*.service' -print0 2>/dev/null | sort -z)
fi
proxnix_write_text_if_changed "$current_systemd_manifest" "$SYSTEMD_MANIFEST" "644" >/dev/null || true

if [[ -f "$BIN_MANIFEST" ]]; then
    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        if [[ ! -f "${RUNTIME_BIN_DIR}/${name}" ]]; then
            rm -f "${ROOTFS}/usr/local/bin/${name}"
        fi
    done < "$BIN_MANIFEST"
fi

current_bin_manifest=""
if [[ -d "$RUNTIME_BIN_DIR" ]]; then
    while IFS= read -r -d '' f; do
        name="$(basename "$f")"
        proxnix_write_if_changed "$f" "${ROOTFS}/usr/local/bin/${name}" "755" >/dev/null || true
        current_bin_manifest+="${name}"$'\n'
    done < <(find "$RUNTIME_BIN_DIR" -maxdepth 1 -type f \( -name '*.sh' -o -name '*.py' \) -print0 2>/dev/null | sort -z)
fi
proxnix_write_text_if_changed "$current_bin_manifest" "$BIN_MANIFEST" "644" >/dev/null || true

if [[ -f "${META_DIR}/vmid" ]]; then
    proxnix_write_if_changed "${META_DIR}/vmid" "${ROOTFS}/etc/proxnix/vmid" "644" >/dev/null || true
fi

PROXNIX_APPLY_CONFIG_RUNNER="${ROOTFS}/etc/proxnix/proxnix-apply-config-runner"
if proxnix_write_text_if_changed '#!/bin/sh
set -eu

SYSTEM_BIN="/run/current-system/sw/bin"
MKDIR_BIN="${SYSTEM_BIN}/mkdir"
TOUCH_BIN="${SYSTEM_BIN}/touch"
TR_BIN="${SYSTEM_BIN}/tr"
GREP_BIN="${SYSTEM_BIN}/grep"
INSTALL_BIN="${SYSTEM_BIN}/install"
NIX_CHANNEL_BIN="${SYSTEM_BIN}/nix-channel"
NIXOS_REBUILD_BIN="${SYSTEM_BIN}/nixos-rebuild"
RM_BIN="${SYSTEM_BIN}/rm"

STAMP_DIR="/run/proxnix"
STAMP_FILE="${STAMP_DIR}/apply-config-ran"
CURRENT_HASH_FILE="/etc/proxnix/current-config-hash"
APPLIED_HASH_FILE="/etc/proxnix/applied-config-hash"
ROOT_CHANNEL_DIR="/nix/var/nix/profiles/per-user/root/channels/nixos"

export PATH="${SYSTEM_BIN}:/nix/var/nix/profiles/default/bin:/bin:/usr/bin${PATH:+:$PATH}"

"$MKDIR_BIN" -p "$STAMP_DIR"

current="$("$TR_BIN" -d "\r\n" < "$CURRENT_HASH_FILE" 2>/dev/null || true)"
applied="$("$TR_BIN" -d "\r\n" < "$APPLIED_HASH_FILE" 2>/dev/null || true)"

if [ -z "$current" ]; then
    echo "proxnix-apply-config: no current config hash, skipping"
    exit 0
fi

if [ "$current" = "$applied" ]; then
    echo "proxnix-apply-config: config hash unchanged ($current)"
    exit 0
fi

if [ -e "$STAMP_FILE" ]; then
    echo "proxnix-apply-config: already ran this boot, skipping"
    exit 0
fi

"$TOUCH_BIN" "$STAMP_FILE"
trap '"'"'status=$?; if [ "$status" -ne 0 ]; then "$RM_BIN" -f "$STAMP_FILE"; fi; exit "$status"'"'"' EXIT INT TERM

if [ -z "${XDG_STATE_HOME:-}" ]; then
    XDG_STATE_HOME="/root/.local/state"
fi
export XDG_STATE_HOME

if [ -f /etc/set-environment ]; then
    # shellcheck disable=SC1091
    # /etc/set-environment is written for login shells, which may rely on
    # unset XDG variables. Temporarily relax nounset so sourcing cannot abort
    # before the rebuild starts.
    set +u
    . /etc/set-environment
    set -u
fi

if [ ! -d "$ROOT_CHANNEL_DIR" ] || [ ! -d /nix/var/nix/profiles/per-user/root/channels/nixpkgs-unstable ]; then
    state_version="$("$GREP_BIN" -oP '"'"'system\.stateVersion\s*=\s*"\K[^"]+'"'"' /etc/nixos/configuration.nix 2>/dev/null || true)"
    state_version="${state_version:-25.05}"
    echo "proxnix-apply-config: bootstrapping root channels for NixOS ${state_version}"
    "$NIX_CHANNEL_BIN" --add "https://nixos.org/channels/nixos-${state_version}" nixos
    "$NIX_CHANNEL_BIN" --add https://nixos.org/channels/nixpkgs-unstable nixpkgs-unstable
    "$NIX_CHANNEL_BIN" --update
fi

export NIX_PATH="nixpkgs=${ROOT_CHANNEL_DIR}:nixos-config=/etc/nixos/configuration.nix:/nix/var/nix/profiles/per-user/root/channels${NIX_PATH:+:$NIX_PATH}"

echo "proxnix-apply-config: hash changed (${applied:-unset} -> ${current}), rebuilding..."
"$NIXOS_REBUILD_BIN" switch
"$INSTALL_BIN" -m 0644 "$CURRENT_HASH_FILE" "$APPLIED_HASH_FILE"
trap - EXIT INT TERM
echo "proxnix-apply-config: rebuild complete"
' "$PROXNIX_APPLY_CONFIG_RUNNER" "755"; then
    log "Installed runtime rebuild runner"
fi

PROXNIX_APPLY_CONFIG_SERVICE="${ROOTFS}/etc/systemd/system.attached/proxnix-apply-config.service"
if proxnix_write_text_if_changed '[Unit]
Description=Apply proxnix-managed NixOS config after boot
Documentation=man:nixos-rebuild(8)
After=network-online.target nss-lookup.target
Wants=network-online.target
ConditionPathExists=/etc/proxnix/current-config-hash

[Service]
Type=oneshot
ExecStart=/etc/proxnix/proxnix-apply-config-runner
StandardOutput=journal
StandardError=journal
[Install]
WantedBy=multi-user.target
' "$PROXNIX_APPLY_CONFIG_SERVICE" "644"; then
    log "Installed runtime rebuild service"
fi

ln -sfn ../proxnix-apply-config.service "${ROOTFS}/etc/systemd/system.attached/multi-user.target.wants/proxnix-apply-config.service"

if [[ -e "${ROOTFS}/etc/systemd/system-generators/proxnix-apply-config-generator" ]]; then
    rm -f "${ROOTFS}/etc/systemd/system-generators/proxnix-apply-config-generator"
fi

if [[ -e "${ROOTFS}/etc/systemd/system/proxnix-apply-config.service" ]]; then
    rm -f "${ROOTFS}/etc/systemd/system/proxnix-apply-config.service"
fi
if [[ -e "${ROOTFS}/etc/systemd/system/multi-user.target.wants/proxnix-apply-config.service" ]]; then
    rm -f "${ROOTFS}/etc/systemd/system/multi-user.target.wants/proxnix-apply-config.service"
fi
if [[ -e "${ROOTFS}/etc/systemd/system/timers.target.wants/proxnix-apply-config.timer" ]]; then
    rm -f "${ROOTFS}/etc/systemd/system/timers.target.wants/proxnix-apply-config.timer"
fi
if [[ -e "${ROOTFS}/usr/lib/systemd/system/proxnix-apply-config.service" ]]; then
    rm -f "${ROOTFS}/usr/lib/systemd/system/proxnix-apply-config.service"
fi
if [[ -e "${ROOTFS}/usr/lib/systemd/system/multi-user.target.wants/proxnix-apply-config.service" ]]; then
    rm -f "${ROOTFS}/usr/lib/systemd/system/multi-user.target.wants/proxnix-apply-config.service"
fi
if [[ -e "${ROOTFS}/usr/lib/systemd/system/proxnix-apply-config.timer" ]]; then
    rm -f "${ROOTFS}/usr/lib/systemd/system/proxnix-apply-config.timer"
fi
if [[ -e "${ROOTFS}/usr/lib/systemd/system/timers.target.wants/proxnix-apply-config.timer" ]]; then
    rm -f "${ROOTFS}/usr/lib/systemd/system/timers.target.wants/proxnix-apply-config.timer"
fi

if [[ -d "$QUADLET_DIR" ]]; then
    find "$QUADLET_ROOT_DIR" -mindepth 1 -maxdepth 1 \
        ! -name .jj \
        ! -name .git \
        -exec rm -rf {} +
    cp -a "${QUADLET_DIR}/." "$QUADLET_ROOT_DIR/"
    find "$QUADLET_ROOT_DIR" -type f \
        \( -name '*.container' -o -name '*.volume' -o -name '*.network' -o -name '*.pod' -o -name '*.image' -o -name '*.build' \) \
        -delete
    chmod -R a+rX "$QUADLET_ROOT_DIR"

    while IFS= read -r -d '' f; do
        fname="$(basename "$f")"
        systemd_dest="${QUADLET_SYSTEMD_DIR}/${fname}"
        dest="$systemd_dest"
        if proxnix_write_if_changed "$f" "$dest" "644"; then
            log "Updated Quadlet drop-in: ${fname}"
        fi
    done < <(find "$QUADLET_DIR" -maxdepth 1 -type f \
        \( -name '*.container' -o -name '*.volume' -o -name '*.network' -o -name '*.pod' -o -name '*.image' -o -name '*.build' \) \
        -print0 2>/dev/null)
    log "Synced Quadlet config tree"
fi

proxnix_remove_missing_matching_files "$QUADLET_DIR" "$QUADLET_SYSTEMD_DIR" \
    \( -name '*.container' -o -name '*.volume' -o -name '*.network' -o -name '*.pod' -o -name '*.image' -o -name '*.build' \) || true

if [[ -d "$SECRETS_STAGE_DIR" ]]; then
    for secret_store in shared.sops.yaml container.sops.yaml; do
        src="${SECRETS_STAGE_DIR}/${secret_store}"
        dest="${ROOTFS}/etc/proxnix/secrets/${secret_store}"
        if [[ -f "$src" ]]; then
            if proxnix_write_if_changed "$src" "$dest" "400"; then
                log "Updated secret store: ${secret_store}"
            fi
        else
            rm -f "$dest"
        fi
    done
fi

rm -f "${ROOTFS}/etc/containers/containers.conf.d/age-secrets.conf" 2>/dev/null || true
find "${ROOTFS}/etc/secrets" -maxdepth 1 -type f -name '*.age' -delete 2>/dev/null || true


python3 - "$ROOTFS" "$VMID" "$SECRETS_STAGE_DIR" <<'PYEOF'
import json
import sys
import uuid
from datetime import datetime, timezone
from pathlib import Path

rootfs = Path(sys.argv[1])
vmid = sys.argv[2]
secrets_dir = Path(sys.argv[3])

def top_level_keys(path: Path):
    if not path.exists():
        return set()
    keys = set()
    for line in path.read_text().splitlines():
        if not line or line[0].isspace() or ":" not in line:
            continue
        key = line.split(":", 1)[0].strip()
        if key and key != "sops":
            keys.add(key)
    return keys

live_names = set()
if secrets_dir.is_dir():
    live_names.update(top_level_keys(secrets_dir / "shared.sops.yaml"))
    live_names.update(top_level_keys(secrets_dir / "container.sops.yaml"))

SECRETS_JSON = rootfs / "var/lib/containers/storage/secrets/secrets.json"
IDS_DIR = rootfs / "etc/secrets/.ids"
LABEL_KEY = "proxnix.managed"

DRIVER_OPTS = {
    "store": "/usr/local/bin/proxnix-secrets podman store",
    "lookup": "/usr/local/bin/proxnix-secrets podman lookup",
    "list": "/usr/local/bin/proxnix-secrets podman list",
    "delete": "/usr/local/bin/proxnix-secrets podman delete",
}

def make_uuid(vmid: str, name: str) -> str:
    return uuid.uuid5(uuid.NAMESPACE_DNS, f"proxnix:{vmid}:{name}").hex

IDS_DIR.mkdir(parents=True, exist_ok=True)
SECRETS_JSON.parent.mkdir(parents=True, exist_ok=True)
SECRETS_JSON.parent.chmod(0o700)

if SECRETS_JSON.exists():
    try:
        data = json.loads(SECRETS_JSON.read_text())
    except Exception:
        data = {}
else:
    data = {}

if not isinstance(data.get("secrets"), dict):
    data["secrets"] = {}
if not isinstance(data.get("nameToID"), dict):
    data["nameToID"] = {}
if not isinstance(data.get("idToName"), dict):
    data["idToName"] = {}

now = datetime.now(timezone.utc).isoformat()
changed = False

stale_ids = [
    sid for sid, entry in data["secrets"].items()
    if isinstance(entry.get("labels"), dict)
    and entry["labels"].get(LABEL_KEY) == "true"
    and (entry.get("name") or "") not in live_names
]
for sid in stale_ids:
    name = data["secrets"][sid].get("name", "")
    del data["secrets"][sid]
    data["nameToID"].pop(name, None)
    data["idToName"].pop(sid, None)
    (IDS_DIR / sid).unlink(missing_ok=True)
    print(f"[proxnix-mount][{vmid}] Unregistered removed secret: {name}", file=sys.stderr)
    changed = True

for name in sorted(live_names):
    sid = make_uuid(vmid, name)
    existing = data["secrets"].get(sid, {})
    created_at = existing.get("createdAt") or now

    entry = {
        "name": name,
        "id": sid,
        "labels": {LABEL_KEY: "true"},
        "metadata": {},
        "createdAt": created_at,
        "updatedAt": now,
        "driver": "shell",
        "driverOptions": DRIVER_OPTS,
    }
    if data["secrets"].get(sid) != entry:
        data["secrets"][sid] = entry
        data["nameToID"][name] = sid
        data["idToName"][sid] = name
        changed = True

    ids_file = IDS_DIR / sid
    if not ids_file.exists() or ids_file.read_text() != name:
        ids_file.write_text(name)
        ids_file.chmod(0o640)

if changed:
    SECRETS_JSON.write_text(json.dumps(data, indent=2) + "\n")
    SECRETS_JSON.chmod(0o600)
    print(
        f"[proxnix-mount][{vmid}] Podman secrets.json reconciled ({len(live_names)} secret(s))",
        file=sys.stderr,
    )
PYEOF

if [[ -f "${META_DIR}/bootstrap_done" ]]; then
    touch "${ROOTFS}/etc/secrets/.bootstrap_done"
else
    rm -f "${ROOTFS}/etc/secrets/.bootstrap_done"
fi

if [[ -f "${KEYS_STAGE_DIR}/identity" ]]; then
    mkdir -p "${ROOTFS}/etc/proxnix/secrets"
    chmod 700 "${ROOTFS}/etc/proxnix/secrets"
    cp "${KEYS_STAGE_DIR}/identity" "${ROOTFS}/etc/proxnix/secrets/identity"
    chmod 600 "${ROOTFS}/etc/proxnix/secrets/identity"
    if [[ -f "${KEYS_STAGE_DIR}/identity.pub" ]]; then
        cp "${KEYS_STAGE_DIR}/identity.pub" "${ROOTFS}/etc/proxnix/secrets/identity.pub"
        chmod 644 "${ROOTFS}/etc/proxnix/secrets/identity.pub"
    fi
    log "Deployed host-generated container age identity"
fi

# Deploy the shared SSH-backed age identity — every container gets it when one
# exists.
if [[ -f "${KEYS_STAGE_DIR}/shared_identity.txt" ]]; then
    mkdir -p "${ROOTFS}/etc/proxnix/secrets"
    chmod 700 "${ROOTFS}/etc/proxnix/secrets"
    cp "${KEYS_STAGE_DIR}/shared_identity.txt" "${ROOTFS}/etc/proxnix/secrets/shared_identity"
    chmod 600 "${ROOTFS}/etc/proxnix/secrets/shared_identity"
    log "Deployed shared SSH-backed age identity"
fi

STATE_VERSION="$(grep -oP 'system\.stateVersion\s*=\s*"\K[^"]+' "${RENDERED_DIR}/configuration.nix" || true)"
STATE_VERSION="${STATE_VERSION:-25.05}"
cat > "${ROOTFS}/root/proxnix-bootstrap.sh" << EOF
#!/run/current-system/sw/bin/bash
set -euo pipefail
SYSTEM_BIN="/run/current-system/sw/bin"
INSTALL_BIN="${SYSTEM_BIN}/install"
NIX_CHANNEL_BIN="${SYSTEM_BIN}/nix-channel"
NIXOS_REBUILD_BIN="${SYSTEM_BIN}/nixos-rebuild"
if [ -z "${XDG_STATE_HOME:-}" ]; then
    XDG_STATE_HOME="/root/.local/state"
fi
export XDG_STATE_HOME
if [ -f /etc/set-environment ]; then
    # shellcheck disable=SC1091
    set +u
    source /etc/set-environment
    set -u
fi
"$NIX_CHANNEL_BIN" --add https://nixos.org/channels/nixos-${STATE_VERSION} nixos
"$NIX_CHANNEL_BIN" --add https://nixos.org/channels/nixpkgs-unstable nixpkgs-unstable
"$NIX_CHANNEL_BIN" --update
"$NIXOS_REBUILD_BIN" switch
if [ -f /etc/proxnix/current-config-hash ]; then
    "$INSTALL_BIN" -m 0644 /etc/proxnix/current-config-hash /etc/proxnix/applied-config-hash
fi
EOF
chmod 755 "${ROOTFS}/root/proxnix-bootstrap.sh"

log "Mount-time sync complete."
exit 0
