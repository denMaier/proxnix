#!/bin/bash
# LXC pre-start hook: render proxnix's desired guest state on the host.
#
# Registered automatically for every ostype=nixos container via
# nixos.common.conf / nixos.userns.conf. Runs after lxc-pve-prestart-hook so
# the PVE config is available, but before the rootfs mount is required.
#
# This hook does not touch the guest rootfs directly. It stages the desired
# state under /run/proxnix/<vmid>/ for the matching mount hook to copy into the
# mounted rootfs:
#   rendered/configuration.nix
#   rendered/managed/{base,common,proxmox,user}.nix
#   rendered/managed/dropins/*.nix
#   quadlet/                             recursive Quadlet source tree
#   secrets/{container,shared}.sops.yaml
#   meta/{current-config-hash,vmid,proxnix-apply-config.service}
#
# Managed Nix files are hashed from the rendered tree only. The guest-side
# proxnix-apply-config service compares that desired hash with the last applied
# hash and runs nixos-rebuild switch only when they differ.

set -uo pipefail
umask 022  # ensure staged files/dirs are world-readable by the mount hook (runs as subuid)

VMID="${LXC_NAME:-}"
PROXNIX_LIB_DIR="/usr/local/lib/proxnix"
COMMON_LIB="${PROXNIX_LIB_DIR}/nixos-proxnix-common.sh"

log() { echo "[proxnix-prestart][${VMID}] $*" >&2; }

if [[ -z "$VMID" ]]; then
    log "ERROR: LXC_NAME is not set."
    exit 1
fi

if [[ ! -f "$COMMON_LIB" ]]; then
    log "ERROR: ${COMMON_LIB} not found."
    log "Run ./install.sh on this Proxmox node to install local runtime files."
    exit 1
fi

# shellcheck source=/dev/null
source "$COMMON_LIB"

YAML_TO_NIX="${PROXNIX_LIB_DIR}/yaml-to-nix.py"
CONTAINER_DIR="${NIXLXC_DIR}/containers/${VMID}"
CONTAINER_PRIV_DIR="${NIXLXC_PRIV_DIR}/containers/${VMID}"
STAGE_DIR="$(proxnix_stage_dir "$VMID")"
RENDERED_DIR="${STAGE_DIR}/rendered"
MANAGED_DIR="${RENDERED_DIR}/managed"
MANAGED_DROPIN_DIR="${MANAGED_DIR}/dropins"
QUADLET_DIR="${STAGE_DIR}/quadlet"
SECRETS_STAGE_DIR="${STAGE_DIR}/secrets"
META_DIR="${STAGE_DIR}/meta"
PVE_CONF="/etc/pve/lxc/${VMID}.conf"

cleanup_stage() {
    rm -rf "$STAGE_DIR"
}

trap 'status=$?; if [[ $status -ne 0 ]]; then cleanup_stage; fi; exit $status' EXIT

if [[ ! -f "$YAML_TO_NIX" ]]; then
    log "ERROR: ${YAML_TO_NIX} not found."
    log "Run ./install.sh on this Proxmox node to install local runtime files."
    exit 1
fi

KEYS_STAGE_DIR="${STAGE_DIR}/keys"

cleanup_stage
mkdir -p \
    "$MANAGED_DROPIN_DIR" \
    "$QUADLET_DIR" \
    "$SECRETS_STAGE_DIR" \
    "$KEYS_STAGE_DIR" \
    "$META_DIR"

for f in "${PROXNIX_SHARED_FILES[@]}"; do
    src="${NIXLXC_DIR}/${f}"
    if [[ ! -f "$src" ]]; then
        log "ERROR: missing required shared file: ${src}"
        log "Run ./install.sh on the Proxmox host to restore proxnix shared files."
        exit 1
    fi
done

cp "${NIXLXC_DIR}/configuration.nix" "${RENDERED_DIR}/configuration.nix"
cp "${NIXLXC_DIR}/base.nix"          "${MANAGED_DIR}/base.nix"
cp "${NIXLXC_DIR}/common.nix"        "${MANAGED_DIR}/common.nix"

ARGS=("--out-dir" "$MANAGED_DIR")
[[ -f "$PVE_CONF"                     ]] && ARGS+=("--pve-conf"     "$PVE_CONF")
[[ -f "${CONTAINER_DIR}/proxmox.yaml" ]] && ARGS+=("--proxmox-yaml" "${CONTAINER_DIR}/proxmox.yaml")
[[ -f "${CONTAINER_DIR}/user.yaml"    ]] && ARGS+=("--user-yaml"    "${CONTAINER_DIR}/user.yaml")

log "Rendering desired state (PVE conf: ${PVE_CONF})..."
if ! python3 "$YAML_TO_NIX" "${ARGS[@]}"; then
    log "ERROR: yaml-to-nix.py failed — check PVE conf and ${CONTAINER_DIR}/*.yaml"
    exit 1
fi

DROPIN_DIR="${CONTAINER_DIR}/dropins"
QUADLET_SOURCE_DIR="${CONTAINER_DIR}/quadlets"
if [[ -d "$QUADLET_SOURCE_DIR" ]]; then
    cp -a "${QUADLET_SOURCE_DIR}/." "$QUADLET_DIR/"
fi

if [[ -d "$DROPIN_DIR" ]]; then
    while IFS= read -r -d '' f; do
        fname="$(basename "$f")"
        case "$fname" in
            *.nix)
                cp "$f" "${MANAGED_DROPIN_DIR}/${fname}"
                ;;
            *.container|*.volume|*.network|*.pod|*.image|*.build)
                cp "$f" "${QUADLET_DIR}/${fname}"
                ;;
            *)
                log "Ignored unknown drop-in type: ${fname}"
                ;;
        esac
    done < <(find "$DROPIN_DIR" -maxdepth 1 -type f -print0 2>/dev/null)

    while IFS= read -r -d '' d; do
        dname="$(basename "$d")"
        rm -rf "${MANAGED_DROPIN_DIR:?}/${dname}"
        cp -a "$d" "${MANAGED_DROPIN_DIR}/${dname}"
    done < <(find "$DROPIN_DIR" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
fi

has_quadlet_units=0
if find "$QUADLET_DIR" -maxdepth 1 -type f \
    \( -name '*.container' -o -name '*.volume' -o -name '*.network' -o -name '*.pod' -o -name '*.image' -o -name '*.build' \) \
    -print -quit | grep -q .; then
    has_quadlet_units=1
fi

if [[ $has_quadlet_units -eq 0 ]]; then
    cat > "${MANAGED_DROPIN_DIR}/proxnix-disable-podman.nix" <<'EOF'
{ lib, ... }: {
  virtualisation.podman.enable = lib.mkOverride 90 false;
  virtualisation.podman.dockerCompat = lib.mkOverride 90 false;
}
EOF
else
    if [[ -f "$PVE_CONF" ]]; then
        FEATURES_LINE="$(sed -n 's/^features: //p' "$PVE_CONF" | head -n1)"
        if [[ ! "${FEATURES_LINE}" =~ (^|,)nesting=1($|,) ]]; then
            log "WARNING: features: nesting=1 is not enabled."
            log "  Podman Quadlet workloads are present; set nesting=1 in the Proxmox CT config."
        fi
    fi
fi

SHARED_SECRETS_FILE="${NIXLXC_PRIV_DIR}/shared/secrets.sops.yaml"
CONTAINER_SECRETS_FILE="${CONTAINER_PRIV_DIR}/secrets.sops.yaml"

if [[ -f "$SHARED_SECRETS_FILE" ]]; then
    cp "$SHARED_SECRETS_FILE" "${SECRETS_STAGE_DIR}/shared.sops.yaml"
fi

if [[ -f "$CONTAINER_SECRETS_FILE" ]]; then
    cp "$CONTAINER_SECRETS_FILE" "${SECRETS_STAGE_DIR}/container.sops.yaml"
fi

# The mount hook runs as the container's subuid (e.g. host UID 100000), not as
# root.  Files copied with 'cp' from pmxcfs inherit the source mode (0640),
# which is not world-readable.  Make the entire stage dir world-readable so
# the mount hook can access it.  Secrets are age-encrypted, so 0644 is fine.
chmod -R a+rX "${STAGE_DIR}"

DESIRED_CONFIG_HASH="$(proxnix_hash_tree "$RENDERED_DIR")"
printf '%s' "$DESIRED_CONFIG_HASH" > "${META_DIR}/current-config-hash"
chmod 0644 "${META_DIR}/current-config-hash"
printf '%s' "$VMID" > "${META_DIR}/vmid"
chmod 0644 "${META_DIR}/vmid"

if [[ -f "${CONTAINER_DIR}/age_pubkey" ]]; then
    : > "${META_DIR}/bootstrap_done"
fi

# Stage the shared age identity if one exists — every container gets it.
# chmod 644 explicitly: the source is mode 600 and chmod -R a+rX below uses
# capital X which only sets execute on directories, leaving 600 files unreadable
# by the mount hook (which runs as the container's subuid, not root).
SHARED_IDENTITY_PATH="${NIXLXC_PRIV_DIR}/shared_age_identity.txt"
if [[ -f "$SHARED_IDENTITY_PATH" ]]; then
    cp "$SHARED_IDENTITY_PATH" "${KEYS_STAGE_DIR}/shared_identity.txt"
    chmod 644 "${KEYS_STAGE_DIR}/shared_identity.txt"
fi

trap - EXIT
log "Rendered staged state at ${STAGE_DIR}"
exit 0
