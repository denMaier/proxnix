#!/bin/bash
# LXC pre-start hook: render proxnix's desired guest state on the host.
#
# Registered automatically for every ostype=nixos container via
# nixos.common.conf / nixos.userns.conf. Runs after lxc-pve-prestart-hook so
# the PVE config is available, but before the rootfs mount is required.
#
# This hook does not touch the guest rootfs directly. It stages the desired
# state under /run/proxnix/<vmid>/ for the matching mount hook to bind-mount
# into the guest rootfs read-only where appropriate:
#   rendered/configuration.nix
#   rendered/managed/{base,common,proxmox,user}.nix
#   rendered/managed/_template/          selected shared Nix template trees
#   rendered/managed/dropins/*.nix
#   runtime/systemd/*.service
#   runtime/bin/*.{sh,py}
#   quadlet/                             recursive Quadlet source tree
#   secrets/{container,shared}.sops.yaml
#   secrets/{identity,shared_identity}   transient plaintext guest identities
#   meta/{current-config-hash,vmid,proxnix-apply-config.service}
#
# Managed Nix files are hashed from the rendered tree only. The guest-side
# proxnix-apply-config service compares that desired hash with the last applied
# hash and runs nixos-rebuild switch only when they differ.

set -uo pipefail
umask 077  # staging content is private until explicitly chowned to the container's subuid

VMID="${LXC_NAME:-}"
PROXNIX_LIB_DIR="/usr/local/lib/proxnix"
COMMON_LIB="${PROXNIX_LIB_DIR}/nixos-proxnix-common.sh"

log() { echo "[proxnix-prestart][${VMID}] $*" >&2; }

if [[ -z "$VMID" ]]; then
    log "ERROR: LXC_NAME is not set."
    exit 1
fi

if [[ ! -f "$COMMON_LIB" ]]; then
    log "ERROR: ${COMMON_LIB} not found."
    log "Run ./install.sh on this Proxmox node to install local runtime files."
    exit 1
fi

# shellcheck source=/dev/null
source "$COMMON_LIB"

PVE_CONF_TO_NIX="${PROXNIX_LIB_DIR}/pve-conf-to-nix.py"
CONTAINER_TEMPLATE_DIR="${NIXLXC_DIR}/containers/_template"
CONTAINER_DIR="${NIXLXC_DIR}/containers/${VMID}"
CONTAINER_PRIV_DIR="${NIXLXC_PRIV_DIR}/containers/${VMID}"
TEMPLATE_SELECTOR_DIR="${CONTAINER_DIR}/templates"
DROPIN_DIR="${CONTAINER_DIR}/dropins"
QUADLET_SOURCE_DIR="${CONTAINER_DIR}/quadlets"
STAGE_DIR="$(proxnix_stage_dir "$VMID")"
RENDERED_DIR="${STAGE_DIR}/rendered"
MANAGED_DIR="${RENDERED_DIR}/managed"
MANAGED_DROPIN_DIR="${MANAGED_DIR}/dropins"
MANAGED_TEMPLATE_DIR="${MANAGED_DIR}/_template"
QUADLET_DIR="${STAGE_DIR}/quadlet"
RUNTIME_DIR="${STAGE_DIR}/runtime"
RUNTIME_SYSTEMD_DIR="${RUNTIME_DIR}/systemd"
RUNTIME_BIN_DIR="${RUNTIME_DIR}/bin"
SECRETS_STAGE_DIR="${STAGE_DIR}/secrets"
META_DIR="${STAGE_DIR}/meta"
PVE_CONF="/etc/pve/lxc/${VMID}.conf"

cleanup_stage() {
    rm -rf "$STAGE_DIR"
}

trap 'status=$?; if [[ $status -ne 0 ]]; then cleanup_stage; fi; exit $status' EXIT

if [[ ! -f "$PVE_CONF_TO_NIX" ]]; then
    log "ERROR: ${PVE_CONF_TO_NIX} not found."
    log "Run ./install.sh on this Proxmox node to install local runtime files."
    exit 1
fi

if ! command -v sops >/dev/null 2>&1; then
    log "ERROR: sops not found on the Proxmox host."
    log "Install sops on the host; proxnix now decrypts relay-encrypted guest identities during pre-start."
    exit 1
fi

cleanup_stage
mkdir -p \
    "$MANAGED_DROPIN_DIR" \
    "$QUADLET_DIR" \
    "$RUNTIME_SYSTEMD_DIR" \
    "$RUNTIME_BIN_DIR" \
    "$SECRETS_STAGE_DIR" \
    "$META_DIR"

for f in "${PROXNIX_SHARED_FILES[@]}"; do
    src="${NIXLXC_DIR}/${f}"
    if [[ ! -f "$src" ]]; then
        log "ERROR: missing required shared file: ${src}"
        log "Run ./install.sh on the Proxmox host to restore proxnix shared files."
        exit 1
    fi
done

cp "${NIXLXC_DIR}/configuration.nix" "${RENDERED_DIR}/configuration.nix"
cp "${NIXLXC_DIR}/base.nix"          "${MANAGED_DIR}/base.nix"
cp "${NIXLXC_DIR}/common.nix"        "${MANAGED_DIR}/common.nix"
if [[ -f "${NIXLXC_DIR}/site.nix" ]]; then
    cp "${NIXLXC_DIR}/site.nix"      "${MANAGED_DIR}/site.nix"
fi

for legacy_yaml in "${CONTAINER_DIR}/proxmox.yaml" "${CONTAINER_DIR}/user.yaml"; do
    if [[ -f "$legacy_yaml" ]]; then
        log "ERROR: legacy YAML config is no longer supported: ${legacy_yaml}"
        log "Move container config into ${CONTAINER_DIR}/dropins/*.nix and keep base identity in the Proxmox CT config."
        exit 1
    fi
done

log "Rendering desired state (PVE conf: ${PVE_CONF})..."
if ! python3 "$PVE_CONF_TO_NIX" --pve-conf "$PVE_CONF" --out-dir "$MANAGED_DIR"; then
    log "ERROR: pve-conf-to-nix.py failed — check ${PVE_CONF}"
    exit 1
fi

if [[ -d "$QUADLET_SOURCE_DIR" ]]; then
    cp -a "${QUADLET_SOURCE_DIR}/." "$QUADLET_DIR/"
fi

if [[ -d "$TEMPLATE_SELECTOR_DIR" ]]; then
    if [[ ! -d "$CONTAINER_TEMPLATE_DIR" ]]; then
        log "ERROR: ${TEMPLATE_SELECTOR_DIR} exists but ${CONTAINER_TEMPLATE_DIR} is missing."
        exit 1
    fi

    while IFS= read -r -d '' selector; do
        selector_name="$(basename "$selector")"
        template_name="${selector_name%.template}"
        template_source="${CONTAINER_TEMPLATE_DIR}/${template_name}"

        if [[ ! -d "$template_source" ]]; then
            log "ERROR: selected template not found: ${template_source}"
            exit 1
        fi

        mkdir -p "$MANAGED_TEMPLATE_DIR"
        cp -a "$template_source" "${MANAGED_TEMPLATE_DIR}/${template_name}"
    done < <(find "$TEMPLATE_SELECTOR_DIR" -maxdepth 1 -type f -name '*.template' -print0 2>/dev/null | sort -z)
fi

if [[ -d "$DROPIN_DIR" ]]; then
    while IFS= read -r -d '' f; do
        fname="$(basename "$f")"
        case "$fname" in
            *.nix)
                cp "$f" "${MANAGED_DROPIN_DIR}/${fname}"
                ;;
            *.service)
                cp "$f" "${RUNTIME_SYSTEMD_DIR}/${fname}"
                ;;
            *.sh|*.py)
                cp "$f" "${RUNTIME_BIN_DIR}/${fname}"
                ;;
            *.container|*.volume|*.network|*.pod|*.image|*.build)
                cp "$f" "${QUADLET_DIR}/${fname}"
                ;;
            *)
                log "Ignored unknown drop-in type: ${fname}"
                ;;
        esac
    done < <(find "$DROPIN_DIR" -maxdepth 1 -type f -print0 2>/dev/null)

    while IFS= read -r -d '' d; do
        dname="$(basename "$d")"
        rm -rf "${MANAGED_DROPIN_DIR:?}/${dname}"
        cp -a "$d" "${MANAGED_DROPIN_DIR}/${dname}"
    done < <(find "$DROPIN_DIR" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
fi

has_quadlet_units=0
if find "$QUADLET_DIR" -maxdepth 1 -type f \
    \( -name '*.container' -o -name '*.volume' -o -name '*.network' -o -name '*.pod' -o -name '*.image' -o -name '*.build' \) \
    -print -quit | grep -q .; then
    has_quadlet_units=1
fi

if [[ $has_quadlet_units -eq 1 ]]; then
    cat > "${MANAGED_DROPIN_DIR}/proxnix-enable-podman.nix" <<'EOF'
{ lib, ... }: {
  virtualisation.podman.enable = lib.mkOverride 90 true;
  virtualisation.podman.dockerCompat = lib.mkOverride 90 true;
}
EOF

    if [[ -f "$PVE_CONF" ]]; then
        FEATURES_LINE="$(sed -n 's/^features: //p' "$PVE_CONF" | head -n1)"
        if [[ ! "${FEATURES_LINE}" =~ (^|,)nesting=1($|,) ]]; then
            log "WARNING: features: nesting=1 is not enabled."
            log "  Podman Quadlet workloads are present; set nesting=1 in the Proxmox CT config."
        fi
    fi
fi

DESIRED_CONFIG_HASH="$(proxnix_hash_tree "$RENDERED_DIR")"

SHARED_SECRETS_FILE="${NIXLXC_PRIV_DIR}/shared/secrets.sops.yaml"
CONTAINER_SECRETS_FILE="${CONTAINER_PRIV_DIR}/secrets.sops.yaml"

if [[ -f "$SHARED_SECRETS_FILE" ]]; then
    cp "$SHARED_SECRETS_FILE" "${SECRETS_STAGE_DIR}/shared.sops.yaml"
fi

if [[ -f "$CONTAINER_SECRETS_FILE" ]]; then
    cp "$CONTAINER_SECRETS_FILE" "${SECRETS_STAGE_DIR}/container.sops.yaml"
fi

printf '%s' "$DESIRED_CONFIG_HASH" > "${META_DIR}/current-config-hash"
printf '%s' "$VMID" > "${META_DIR}/vmid"

CONTAINER_IDENTITY_STORE_PATH="$(proxnix_container_age_identity_store_path "$VMID")"
if [[ -f "$CONTAINER_IDENTITY_STORE_PATH" ]]; then
    if ! proxnix_decrypt_host_identity_store_to_file "$CONTAINER_IDENTITY_STORE_PATH" "${SECRETS_STAGE_DIR}/identity"; then
        log "ERROR: failed to decrypt host-relay container identity: ${CONTAINER_IDENTITY_STORE_PATH}"
        exit 1
    fi
fi

SHARED_IDENTITY_STORE_PATH="$(proxnix_shared_age_identity_store_path)"
if [[ -f "$SHARED_IDENTITY_STORE_PATH" ]]; then
    if ! proxnix_decrypt_host_identity_store_to_file "$SHARED_IDENTITY_STORE_PATH" "${SECRETS_STAGE_DIR}/shared_identity"; then
        log "ERROR: failed to decrypt host-relay shared identity: ${SHARED_IDENTITY_STORE_PATH}"
        exit 1
    fi
fi

# Restrict staging to the container's subuid — the exact UID that the mount hook
# runs as. Any other subuid process (e.g. from a different container) cannot
# read this container's staged keys or config even if a container escape occurs.
HOST_SUBUID=""
if [[ -f "$PVE_CONF" ]]; then
    HOST_SUBUID=$(awk '/^lxc\.idmap: *u 0 / { print $4; exit }' "$PVE_CONF")
fi

if [[ -n "$HOST_SUBUID" && "$HOST_SUBUID" =~ ^[0-9]+$ ]]; then
    chown -R "${HOST_SUBUID}" "${STAGE_DIR}"
    find "${STAGE_DIR}" -type d -exec chmod 700 {} +
    find "${STAGE_DIR}" -type f -exec chmod 400 {} +
else
    log "WARNING: could not determine container subuid from ${PVE_CONF}; staging is world-readable"
    chmod -R a+rX "${STAGE_DIR}"
    chmod 644 "${SECRETS_STAGE_DIR}/identity" \
              "${SECRETS_STAGE_DIR}/shared_identity" 2>/dev/null || true
fi

trap - EXIT
log "Rendered staged state at ${STAGE_DIR} (subuid: ${HOST_SUBUID:-unknown})"
exit 0
