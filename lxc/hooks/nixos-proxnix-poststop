#!/bin/bash
# LXC post-stop hook: remove any proxnix staging artefacts left for this container.
#
# The mount hook leaves the staging dir in place for the container lifetime
# because read-only bind mounts may use it as their source. This hook removes
# that staged state after the container stops, and also covers the case where
# the container failed to start after pre-start rendered the tree.

set -uo pipefail

VMID="${LXC_NAME:-}"

if [[ -z "$VMID" ]]; then
    exit 0
fi

rm -rf "/run/proxnix/${VMID}"
