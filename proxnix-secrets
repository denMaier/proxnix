#!/bin/bash
# proxnix-secrets — Manage age-encrypted secrets for proxNix LXC containers.
#
# Runs on your local workstation. Uses SSH to read/write files on the Proxmox
# host. Your age private key never leaves this machine.
#
# Install:
#   cp proxnix-secrets ~/.local/bin/proxnix-secrets
#   chmod +x ~/.local/bin/proxnix-secrets
#
# Config (~/.config/proxnix/config):
#   PROXNIX_HOST=root@proxmox
#   PROXNIX_IDENTITY=~/.age/identity.txt   # or ~/.ssh/id_ed25519
#   PROXNIX_DIR=/etc/pve/proxnix             # shared configs + public keys
#   PROXNIX_PRIV_DIR=/etc/pve/priv/proxnix   # shared encrypted secrets
#
# Usage:
#   proxnix-secrets ls [<vmid>]
#   proxnix-secrets ls-shared
#   proxnix-secrets get    <vmid> <name>
#   proxnix-secrets get-shared <name>
#   proxnix-secrets set    <vmid> <name>   # value read from stdin or prompt
#   proxnix-secrets set-shared <name>      # encrypt for every bootstrapped CT
#   proxnix-secrets rm     <vmid> <name>
#   proxnix-secrets rm-shared <name>
#   proxnix-secrets rotate <vmid> <name>   # re-encrypt with current keys
#   proxnix-secrets rotate-shared <name>|--all

set -euo pipefail

# ── config ────────────────────────────────────────────────────────────────────

CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/proxnix/config"

# Defaults (overridden by config file or environment)
PROXNIX_HOST="${PROXNIX_HOST:-}"
PROXNIX_IDENTITY="${PROXNIX_IDENTITY:-$HOME/.age/identity.txt}"
PROXNIX_DIR="${PROXNIX_DIR:-/etc/pve/proxnix}"
PROXNIX_PRIV_DIR="${PROXNIX_PRIV_DIR:-/etc/pve/priv/proxnix}"

[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

# Expand leading ~ that survived quoting in the config file
PROXNIX_IDENTITY="${PROXNIX_IDENTITY/#\~/$HOME}"

# ── sanity checks ─────────────────────────────────────────────────────────────

die()   { echo "error: $*" >&2; exit 1; }
info()  { echo "$*"; }

usage() {
  cat >&2 <<EOF
Usage:
  $(basename "$0") ls [<vmid>]
  $(basename "$0") ls-shared
  $(basename "$0") get    <vmid> <name>
  $(basename "$0") get-shared <name>
  $(basename "$0") set    <vmid> <name>
  $(basename "$0") set-shared <name>
  $(basename "$0") rm     <vmid> <name>
  $(basename "$0") rm-shared <name>
  $(basename "$0") rotate <vmid> <name>
  $(basename "$0") rotate-shared <name>|--all

Config: $CONFIG_FILE
  PROXNIX_HOST      SSH target (e.g. root@proxmox)
  PROXNIX_IDENTITY  Local age private key (default: ~/.age/identity.txt)
  PROXNIX_DIR       Shared config dir    (default: /etc/pve/proxnix)
  PROXNIX_PRIV_DIR  Shared secret dir    (default: /etc/pve/priv/proxnix)
EOF
  exit 1
}

[[ -n "$PROXNIX_HOST" ]]     || die "PROXNIX_HOST not set — create $CONFIG_FILE"
[[ -f "$PROXNIX_IDENTITY" ]] || die "Age identity not found: $PROXNIX_IDENTITY"

# ── path helpers ──────────────────────────────────────────────────────────────

container_dir() { printf '%s/containers/%s'         "$PROXNIX_DIR" "$1"; }
secrets_dir()   { printf '%s/containers/%s/secrets' "$PROXNIX_PRIV_DIR" "$1"; }
secret_path()   { printf '%s/containers/%s/secrets/%s.age' "$PROXNIX_PRIV_DIR" "$1" "$2"; }
shared_secrets_dir() { printf '%s/shared' "$PROXNIX_PRIV_DIR"; }
shared_secret_path() { printf '%s/shared/%s.age' "$PROXNIX_PRIV_DIR" "$1"; }

# ── SSH helpers ───────────────────────────────────────────────────────────────

rsh() { ssh "$PROXNIX_HOST" "$@"; }

# Fetch a text file from the host and strip trailing whitespace
rcat() { rsh cat "$1" | tr -d '\r' | sed 's/[[:space:]]*$//'; }

read_secret_value() {
  local value confirm

  if [[ -t 0 ]]; then
    IFS= read -r -s -p "Secret value: " value; echo
    IFS= read -r -s -p "Confirm: "      confirm; echo
    [[ "$value" == "$confirm" ]] || die "Values do not match."
  else
    value="$(cat)"
  fi

  [[ -n "$value" ]] || die "Empty secret value."
  printf '%s' "$value"
}

list_shared_secret_names() {
  rsh bash <<EOF
shopt -s nullglob
for f in $(shared_secrets_dir)/*.age; do
  basename "\${f%.age}"
done | sort
EOF
}

# Fetch both public keys needed to encrypt a secret for a container.
# Sets globals CONTAINER_KEY and MASTER_KEY to avoid multiple SSH round-trips.
fetch_recipients() {
  local vmid="$1"
  CONTAINER_KEY="$(rcat "$(container_dir "$vmid")/age_pubkey")" \
    || die "Container ${vmid} has no age_pubkey. Run bootstrap.sh first."
  MASTER_KEY="$(rcat "${PROXNIX_DIR}/master_age_pubkey")" \
    || die "No master_age_pubkey at ${PROXNIX_DIR}/master_age_pubkey"
}

fetch_shared_recipients() {
  local vmid key
  local -a recipients=()
  local -a missing=()

  MASTER_KEY="$(rcat "${PROXNIX_DIR}/master_age_pubkey")" \
    || die "No master_age_pubkey at ${PROXNIX_DIR}/master_age_pubkey"

  while IFS=$'\t' read -r vmid key; do
    [[ -n "$vmid" ]] || continue
    if [[ -z "$key" ]]; then
      missing+=("$vmid")
      continue
    fi
    recipients+=("$key")
  done < <(rsh bash <<EOF
shopt -s nullglob
for dir in ${PROXNIX_DIR}/containers/*; do
  [[ -d "\$dir" ]] || continue
  vmid=\$(basename "\$dir")
  key_file="\$dir/age_pubkey"
  if [[ -f "\$key_file" ]]; then
    key=\$(tr -d '\r' < "\$key_file" | sed 's/[[:space:]]*$//')
    printf '%s\t%s\n' "\$vmid" "\$key"
  else
    printf '%s\t\n' "\$vmid"
  fi
done
EOF
)

  [[ ${#recipients[@]} -gt 0 ]] \
    || die "No container age_pubkey files found under ${PROXNIX_DIR}/containers."
  [[ ${#missing[@]} -eq 0 ]] \
    || die "Shared secrets missing age_pubkey for vmid(s): ${missing[*]}. Run bootstrap.sh, then rotate-shared."

  SHARED_RECIPIENTS=("${recipients[@]}")
}

# ── commands ──────────────────────────────────────────────────────────────────

cmd_ls() {
  if [[ $# -eq 0 ]]; then
    # All secrets — shared first, then per-container
    rsh bash <<EOF
shopt -s nullglob
for f in $(shared_secrets_dir)/*.age; do
  printf 'shared\t%s\n' "\$(basename "\${f%.age}")"
done
for d in ${PROXNIX_PRIV_DIR}/containers/*/secrets; do
  vmid=\$(basename "\$(dirname "\$d")")
  for f in "\$d"/*.age; do
    printf '%s\t%s\n' "\$vmid" "\$(basename "\${f%.age}")"
  done
done | sort
EOF
  else
    local vmid="$1"
    local sdir
    sdir="$(secrets_dir "$vmid")"
    rsh bash <<EOF
shopt -s nullglob
declare -A names=()
for f in $(shared_secrets_dir)/*.age; do
  [[ -e "\$f" ]] || continue
  names["\$(basename "\${f%.age}")"]="shared"
done
for f in ${sdir}/*.age; do
  [[ -e "\$f" ]] || continue
  names["\$(basename "\${f%.age}")"]="container"
done
if [[ \${#names[@]} -eq 0 ]]; then
  echo "(no secrets for vmid ${vmid})"
else
  for name in "\${!names[@]}"; do
    printf '%s\t%s\n' "\$name" "\${names[\$name]}"
  done | sort
fi
EOF
  fi
}

cmd_ls_shared() {
  local names
  names="$(list_shared_secret_names)"
  if [[ -z "$names" ]]; then
    echo "(no shared secrets)"
    return
  fi
  printf '%s\n' "$names"
}

cmd_get() {
  local vmid="$1" name="$2"
  local path
  path="$(secret_path "$vmid" "$name")"
  if ! rsh test -f "$path"; then
    path="$(shared_secret_path "$name")"
    rsh test -f "$path" \
      || die "Secret not found for vmid=${vmid}: ${name}"
  fi
  rsh cat "$path" \
    | age --decrypt -i "$PROXNIX_IDENTITY"
}

cmd_get_shared() {
  local name="$1"
  rsh test -f "$(shared_secret_path "$name")" \
    || die "Shared secret not found: ${name}"
  rsh cat "$(shared_secret_path "$name")" \
    | age --decrypt -i "$PROXNIX_IDENTITY"
}

cmd_set() {
  local vmid="$1" name="$2"
  local value
  local -a age_args=()

  value="$(read_secret_value)"

  fetch_recipients "$vmid"
  rsh mkdir -p "$(secrets_dir "$vmid")"
  age_args=(-r "$CONTAINER_KEY" -r "$MASTER_KEY")

  printf '%s' "$value" \
    | age "${age_args[@]}" \
    | rsh "cat > '$(secret_path "$vmid" "$name")'"

  info "Set: vmid=${vmid} name=${name}"
}

cmd_set_shared() {
  local name="$1"
  local value recipient
  local -a age_args=()

  value="$(read_secret_value)"
  fetch_shared_recipients
  rsh mkdir -p "$(shared_secrets_dir)"

  for recipient in "${SHARED_RECIPIENTS[@]}"; do
    age_args+=("-r" "$recipient")
  done
  age_args+=("-r" "$MASTER_KEY")

  printf '%s' "$value" \
    | age "${age_args[@]}" \
    | rsh "cat > '$(shared_secret_path "$name")'"

  info "Set shared: name=${name} recipients=${#SHARED_RECIPIENTS[@]}"
}

cmd_rm() {
  local vmid="$1" name="$2"
  rsh rm -f "$(secret_path "$vmid" "$name")"
  info "Removed: vmid=${vmid} name=${name}"
}

cmd_rm_shared() {
  local name="$1"
  rsh rm -f "$(shared_secret_path "$name")"
  info "Removed shared: name=${name}"
}

cmd_rotate() {
  local vmid="$1" name="$2"
  # Decrypt with the current master key, immediately re-encrypt with current
  # recipients. Use a temp file on the host to make the write atomic.
  fetch_recipients "$vmid"

  rsh cat "$(secret_path "$vmid" "$name")" \
    | age --decrypt -i "$PROXNIX_IDENTITY" \
    | age -r "$CONTAINER_KEY" -r "$MASTER_KEY" \
    | rsh "cat > '$(secret_path "$vmid" "$name")'"

  info "Rotated: vmid=${vmid} name=${name}"
}

cmd_rotate_shared() {
  local target="$1"
  local name recipient
  local -a age_args=()
  local -a names=()

  fetch_shared_recipients
  for recipient in "${SHARED_RECIPIENTS[@]}"; do
    age_args+=("-r" "$recipient")
  done
  age_args+=("-r" "$MASTER_KEY")

  if [[ "$target" == "--all" ]]; then
    mapfile -t names < <(list_shared_secret_names)
    [[ ${#names[@]} -gt 0 ]] || {
      info "No shared secrets to rotate."
      return
    }
  else
    names=("$target")
  fi

  for name in "${names[@]}"; do
    rsh test -f "$(shared_secret_path "$name")" \
      || die "Shared secret not found: ${name}"
    rsh cat "$(shared_secret_path "$name")" \
      | age --decrypt -i "$PROXNIX_IDENTITY" \
      | age "${age_args[@]}" \
      | rsh "cat > '$(shared_secret_path "$name")'"
    info "Rotated shared: name=${name}"
  done
}

# ── dispatch ──────────────────────────────────────────────────────────────────

[[ $# -ge 1 ]] || usage
CMD="$1"; shift

case "$CMD" in
  ls)     [[ $# -le 1 ]] || usage; cmd_ls "$@" ;;
  ls-shared) [[ $# -eq 0 ]] || usage; cmd_ls_shared ;;
  get)    [[ $# -eq 2 ]] || usage; cmd_get "$@" ;;
  get-shared) [[ $# -eq 1 ]] || usage; cmd_get_shared "$@" ;;
  set)    [[ $# -eq 2 ]] || usage; cmd_set "$@" ;;
  set-shared) [[ $# -eq 1 ]] || usage; cmd_set_shared "$@" ;;
  rm)     [[ $# -eq 2 ]] || usage; cmd_rm  "$@" ;;
  rm-shared) [[ $# -eq 1 ]] || usage; cmd_rm_shared "$@" ;;
  rotate) [[ $# -eq 2 ]] || usage; cmd_rotate "$@" ;;
  rotate-shared) [[ $# -eq 1 ]] || usage; cmd_rotate_shared "$@" ;;
  *)      usage ;;
esac
