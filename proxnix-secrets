#!/bin/bash
# proxnix-secrets — Manage age-encrypted secrets for proxNix LXC containers.
#
# Runs on your local workstation. Uses SSH to read/write files on the Proxmox
# host. Your age private key never leaves this machine.
#
# Install:
#   cp proxnix-secrets ~/.local/bin/proxnix-secrets
#   chmod +x ~/.local/bin/proxnix-secrets
#
# Config (~/.config/proxnix/config):
#   PROXNIX_HOST=root@proxmox
#   PROXNIX_IDENTITY=~/.age/identity.txt   # or ~/.ssh/id_ed25519
#   PROXNIX_DIR=/etc/nixos-lxc             # default shown
#
# Usage:
#   proxnix-secrets ls [<vmid>]
#   proxnix-secrets get    <vmid> <name>
#   proxnix-secrets set    <vmid> <name>   # value read from stdin or prompt
#   proxnix-secrets rm     <vmid> <name>
#   proxnix-secrets rotate <vmid> <name>   # re-encrypt with current keys

set -euo pipefail

# ── config ────────────────────────────────────────────────────────────────────

CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/proxnix/config"

# Defaults (overridden by config file or environment)
PROXNIX_HOST="${PROXNIX_HOST:-}"
PROXNIX_IDENTITY="${PROXNIX_IDENTITY:-$HOME/.age/identity.txt}"
PROXNIX_DIR="${PROXNIX_DIR:-/etc/nixos-lxc}"

[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

# Expand leading ~ that survived quoting in the config file
PROXNIX_IDENTITY="${PROXNIX_IDENTITY/#\~/$HOME}"

# ── sanity checks ─────────────────────────────────────────────────────────────

die()   { echo "error: $*" >&2; exit 1; }
info()  { echo "$*"; }

usage() {
  cat >&2 <<EOF
Usage:
  $(basename "$0") ls [<vmid>]
  $(basename "$0") get    <vmid> <name>
  $(basename "$0") set    <vmid> <name>
  $(basename "$0") rm     <vmid> <name>
  $(basename "$0") rotate <vmid> <name>

Config: $CONFIG_FILE
  PROXNIX_HOST      SSH target (e.g. root@proxmox)
  PROXNIX_IDENTITY  Local age private key (default: ~/.age/identity.txt)
  PROXNIX_DIR       Base dir on host     (default: /etc/nixos-lxc)
EOF
  exit 1
}

[[ -n "$PROXNIX_HOST" ]]     || die "PROXNIX_HOST not set — create $CONFIG_FILE"
[[ -f "$PROXNIX_IDENTITY" ]] || die "Age identity not found: $PROXNIX_IDENTITY"

# ── path helpers ──────────────────────────────────────────────────────────────

container_dir() { printf '%s/containers/%s'         "$PROXNIX_DIR" "$1"; }
secrets_dir()   { printf '%s/containers/%s/secrets' "$PROXNIX_DIR" "$1"; }
secret_path()   { printf '%s/containers/%s/secrets/%s.age' "$PROXNIX_DIR" "$1" "$2"; }

# ── SSH helpers ───────────────────────────────────────────────────────────────

rsh() { ssh "$PROXNIX_HOST" "$@"; }

# Fetch a text file from the host and strip trailing whitespace
rcat() { rsh cat "$1" | tr -d '\r' | sed 's/[[:space:]]*$//'; }

# Fetch both public keys needed to encrypt a secret for a container.
# Sets globals CONTAINER_KEY and MASTER_KEY to avoid multiple SSH round-trips.
fetch_recipients() {
  local vmid="$1"
  CONTAINER_KEY="$(rcat "$(container_dir "$vmid")/age_pubkey")" \
    || die "Container ${vmid} has no age_pubkey. Run bootstrap.sh first."
  MASTER_KEY="$(rcat "${PROXNIX_DIR}/master_age_pubkey")" \
    || die "No master_age_pubkey at ${PROXNIX_DIR}/master_age_pubkey"
}

# ── commands ──────────────────────────────────────────────────────────────────

cmd_ls() {
  if [[ $# -eq 0 ]]; then
    # All containers — run one SSH session, expand PROXNIX_DIR locally
    rsh bash <<EOF
shopt -s nullglob
for d in ${PROXNIX_DIR}/containers/*/secrets; do
  vmid=\$(basename "\$(dirname "\$d")")
  for f in "\$d"/*.age; do
    printf '%s\t%s\n' "\$vmid" "\$(basename "\${f%.age}")"
  done
done
EOF
  else
    local vmid="$1"
    local sdir
    sdir="$(secrets_dir "$vmid")"
    rsh bash <<EOF
shopt -s nullglob
files=(${sdir}/*.age)
if [[ \${#files[@]} -eq 0 ]]; then
  echo "(no secrets for vmid ${vmid})"
else
  for f in "\${files[@]}"; do
    basename "\${f%.age}"
  done
fi
EOF
  fi
}

cmd_get() {
  local vmid="$1" name="$2"
  rsh cat "$(secret_path "$vmid" "$name")" \
    | age --decrypt -i "$PROXNIX_IDENTITY"
}

cmd_set() {
  local vmid="$1" name="$2"
  local value

  if [[ -t 0 ]]; then
    # Interactive terminal: prompt with confirmation, no echo
    local confirm
    IFS= read -r -s -p "Secret value for '${name}': " value; echo
    IFS= read -r -s -p "Confirm: "                  confirm; echo
    [[ "$value" == "$confirm" ]] || die "Values do not match."
  else
    value="$(cat)"
  fi

  [[ -n "$value" ]] || die "Empty secret value."

  fetch_recipients "$vmid"
  rsh mkdir -p "$(secrets_dir "$vmid")"

  printf '%s' "$value" \
    | age -r "$CONTAINER_KEY" -r "$MASTER_KEY" \
    | rsh "cat > '$(secret_path "$vmid" "$name")'"

  info "Set: vmid=${vmid} name=${name}"
}

cmd_rm() {
  local vmid="$1" name="$2"
  rsh rm -f "$(secret_path "$vmid" "$name")"
  info "Removed: vmid=${vmid} name=${name}"
}

cmd_rotate() {
  local vmid="$1" name="$2"
  # Decrypt with the current master key, immediately re-encrypt with current
  # recipients. Use a temp file on the host to make the write atomic.
  fetch_recipients "$vmid"

  rsh cat "$(secret_path "$vmid" "$name")" \
    | age --decrypt -i "$PROXNIX_IDENTITY" \
    | age -r "$CONTAINER_KEY" -r "$MASTER_KEY" \
    | rsh "cat > '$(secret_path "$vmid" "$name")'"

  info "Rotated: vmid=${vmid} name=${name}"
}

# ── dispatch ──────────────────────────────────────────────────────────────────

[[ $# -ge 1 ]] || usage
CMD="$1"; shift

case "$CMD" in
  ls)     [[ $# -le 1 ]] || usage; cmd_ls "$@" ;;
  get)    [[ $# -eq 2 ]] || usage; cmd_get "$@" ;;
  set)    [[ $# -eq 2 ]] || usage; cmd_set "$@" ;;
  rm)     [[ $# -eq 2 ]] || usage; cmd_rm  "$@" ;;
  rotate) [[ $# -eq 2 ]] || usage; cmd_rotate "$@" ;;
  *)      usage ;;
esac
