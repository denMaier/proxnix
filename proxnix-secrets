#!/bin/bash
# proxnix-secrets — Workstation/admin command for SOPS-backed proxnix secrets.
#
# This command edits the Proxmox pmxcfs-backed secret stores over SSH. The
# in-container helper is a separate script: proxnix-secrets-guest.

set -euo pipefail

CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/proxnix/config"

PROXNIX_HOST="${PROXNIX_HOST:-}"
PROXNIX_IDENTITY="${PROXNIX_IDENTITY:-$HOME/.config/age/identity.txt}"
PROXNIX_DIR="${PROXNIX_DIR:-/etc/pve/proxnix}"
PROXNIX_PRIV_DIR="${PROXNIX_PRIV_DIR:-/etc/pve/priv/proxnix}"

[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"
PROXNIX_IDENTITY="${PROXNIX_IDENTITY/#\~/$HOME}"

die() { echo "error: $*" >&2; exit 1; }
info() { echo "$*"; }

usage() {
  cat >&2 <<EOF
Usage:
  $(basename "$0") ls [<vmid>]
  $(basename "$0") ls-shared
  $(basename "$0") get             <vmid> <name>
  $(basename "$0") get-shared      <name>
  $(basename "$0") set             <vmid> <name>
  $(basename "$0") set-shared      <name>
  $(basename "$0") rm              <vmid> <name>
  $(basename "$0") rm-shared       <name>
  $(basename "$0") rotate          <vmid>
  $(basename "$0") rotate-shared
  $(basename "$0") init-shared

Config: $CONFIG_FILE
  PROXNIX_HOST      SSH target, for example root@proxmox
  PROXNIX_IDENTITY  Local age identity used by SOPS
  PROXNIX_DIR       Shared config dir on Proxmox
  PROXNIX_PRIV_DIR  Private secret dir on Proxmox
EOF
  exit 1
}

need_tools() {
  [[ -n "$PROXNIX_HOST" ]] || die "PROXNIX_HOST not set — create $CONFIG_FILE"
  [[ -f "$PROXNIX_IDENTITY" ]] || die "age identity not found: $PROXNIX_IDENTITY"
  command -v ssh >/dev/null 2>&1 || die "ssh not found"
  command -v sops >/dev/null 2>&1 || die "sops not found"
  command -v age-keygen >/dev/null 2>&1 || die "age-keygen not found"
  command -v python3 >/dev/null 2>&1 || die "python3 not found"
}

container_store() { printf '%s/containers/%s/secrets.sops.yaml' "$PROXNIX_PRIV_DIR" "$1"; }
shared_store() { printf '%s/shared/secrets.sops.yaml' "$PROXNIX_PRIV_DIR"; }
container_pubkey() { printf '%s/containers/%s/age_pubkey' "$PROXNIX_DIR" "$1"; }
master_pubkey() { printf '%s/master_age_pubkey' "$PROXNIX_DIR"; }
shared_identity_path() { printf '%s/shared_age_identity.txt' "$PROXNIX_PRIV_DIR"; }
shared_pubkey_path() { printf '%s/shared_age_pubkey' "$PROXNIX_DIR"; }

quote() { printf '%q' "$1"; }
rsh() { ssh "$PROXNIX_HOST" "$@"; }

remote_file_exists() {
  local path="$1"
  rsh "test -f $(quote "$path")"
}

remote_cat() {
  local path="$1"
  rsh "cat -- $(quote "$path")"
}

remote_write() {
  local path="$1" dir
  dir="$(dirname "$path")"
  rsh "mkdir -p $(quote "$dir") && umask 077 && cat > $(quote "$path")"
}

sops_json_value_file() {
  local value="$1" out="$2"
  SECRET_VALUE="$value" python3 - "$out" <<'PY'
import json
import os
import sys

with open(sys.argv[1], "w") as fh:
    json.dump(os.environ["SECRET_VALUE"], fh)
    fh.write("\n")
PY
}

sops_path() {
  local name="$1"
  if [[ "$name" == \[* ]]; then
    printf '%s' "$name"
  else
    python3 - "$name" <<'PY'
import json, sys
print("[" + json.dumps(sys.argv[1]) + "]")
PY
  fi
}

with_sops_key() {
  local first_line
  first_line="$(sed -n '1p' "$PROXNIX_IDENTITY" 2>/dev/null || true)"
  case "$first_line" in
    AGE-SECRET-KEY-*)
      SOPS_AGE_KEY_FILE="$PROXNIX_IDENTITY" "$@"
      ;;
    -----BEGIN\ OPENSSH\ PRIVATE\ KEY-----|-----BEGIN\ RSA\ PRIVATE\ KEY-----|-----BEGIN\ EC\ PRIVATE\ KEY-----|-----BEGIN\ DSA\ PRIVATE\ KEY-----)
      SOPS_AGE_SSH_PRIVATE_KEY_FILE="$PROXNIX_IDENTITY" "$@"
      ;;
    *)
      die "unsupported identity format in PROXNIX_IDENTITY: $PROXNIX_IDENTITY"
      ;;
  esac
}

read_secret_value() {
  local value confirm
  if [[ -t 0 ]]; then
    IFS= read -r -s -p "Secret value: " value
    echo
    IFS= read -r -s -p "Confirm: " confirm
    echo
    [[ "$value" == "$confirm" ]] || die "values do not match"
  else
    value="$(cat)"
  fi
  [[ -n "$value" ]] || die "empty secret value"
  printf '%s' "$value"
}

top_level_keys() {
  awk '
    /^[A-Za-z0-9_.-]+:/ {
      key=$1
      sub(/:$/, "", key)
      if (key != "sops") print key
    }
  ' | sort -u
}

container_recipients() {
  local vmid="$1" ckey mkey
  ckey="$(remote_cat "$(container_pubkey "$vmid")" | tr -d '\r\n')" \
    || die "container ${vmid} has no age_pubkey. Run bootstrap.sh first."
  mkey="$(remote_cat "$(master_pubkey)" | tr -d '\r\n')" \
    || die "missing master age public key: $(master_pubkey)"
  printf '%s,%s' "$ckey" "$mkey"
}

shared_recipients() {
  local skey mkey
  skey="$(remote_cat "$(shared_pubkey_path)" | tr -d '\r\n')" \
    || die "missing shared age public key. Run: proxnix-secrets init-shared"
  mkey="$(remote_cat "$(master_pubkey)" | tr -d '\r\n')" \
    || die "missing master age public key: $(master_pubkey)"
  printf '%s,%s' "$skey" "$mkey"
}

ensure_remote_store() {
  local remote="$1" recipients="$2" tmp out
  remote_file_exists "$remote" && return 0
  tmp="$(mktemp /tmp/proxnix-secrets-plain.XXXXXX.yaml)"
  out="$(mktemp /tmp/proxnix-secrets-encrypted.XXXXXX.sops.yaml)"
  printf '{}\n' > "$tmp"
  with_sops_key sops --encrypt --age "$recipients" \
    --input-type yaml --output-type yaml "$tmp" > "$out"
  remote_write "$remote" < "$out"
  rm -f "$tmp" "$out"
}

sops_set_remote() {
  local remote="$1" recipients="$2" name="$3" value="$4" tmp value_json
  tmp="$(mktemp /tmp/proxnix-secrets-store.XXXXXX.sops.yaml)"
  value_json="$(mktemp /tmp/proxnix-secrets-value.XXXXXX.json)"
  ensure_remote_store "$remote" "$recipients"
  remote_cat "$remote" > "$tmp"
  sops_json_value_file "$value" "$value_json"
  with_sops_key sops set --input-type yaml --value-file "$tmp" "$(sops_path "$name")" "$value_json"
  remote_write "$remote" < "$tmp"
  rm -f "$tmp" "$value_json"
}

sops_unset_remote() {
  local remote="$1" name="$2" tmp
  remote_file_exists "$remote" || return 0
  tmp="$(mktemp /tmp/proxnix-secrets-store.XXXXXX.sops.yaml)"
  remote_cat "$remote" > "$tmp"
  with_sops_key sops unset --input-type yaml "$tmp" "$(sops_path "$name")" || true
  remote_write "$remote" < "$tmp"
  rm -f "$tmp"
}

sops_get_remote() {
  local remote="$1" name="$2" tmp
  remote_file_exists "$remote" || return 1
  tmp="$(mktemp /tmp/proxnix-secrets-store.XXXXXX.sops.yaml)"
  remote_cat "$remote" > "$tmp"
  with_sops_key sops decrypt --input-type yaml --extract "$(sops_path "$name")" "$tmp"
  rm -f "$tmp"
}

reencrypt_remote() {
  local remote="$1" recipients="$2" tmp plain encrypted
  remote_file_exists "$remote" || die "store not found: $remote"
  tmp="$(mktemp /tmp/proxnix-secrets-store.XXXXXX.sops.yaml)"
  plain="$(mktemp /tmp/proxnix-secrets-plain.XXXXXX.yaml)"
  encrypted="$(mktemp /tmp/proxnix-secrets-encrypted.XXXXXX.sops.yaml)"
  remote_cat "$remote" > "$tmp"
  with_sops_key sops decrypt --input-type yaml "$tmp" > "$plain"
  with_sops_key sops --encrypt --age "$recipients" \
    --input-type yaml --output-type yaml "$plain" > "$encrypted"
  remote_write "$remote" < "$encrypted"
  rm -f "$tmp" "$plain" "$encrypted"
}

cmd_ls() {
  need_tools
  if [[ $# -eq 0 ]]; then
    rsh "find $(quote "$PROXNIX_PRIV_DIR") -name secrets.sops.yaml -type f -print" | while IFS= read -r f; do
      if [[ "$f" == */shared/secrets.sops.yaml ]]; then
        remote_cat "$f" | top_level_keys | sed 's/^/shared\t/'
      elif [[ "$f" == */containers/*/secrets.sops.yaml ]]; then
        vmid="${f#*/containers/}"
        vmid="${vmid%%/*}"
        remote_cat "$f" | top_level_keys | sed "s/^/${vmid}\t/"
      fi
    done | sort
  else
    local vmid="$1"
    {
      remote_file_exists "$(shared_store)" && remote_cat "$(shared_store)" | top_level_keys | sed 's/$/\tshared/' || true
      remote_file_exists "$(container_store "$vmid")" && remote_cat "$(container_store "$vmid")" | top_level_keys | sed 's/$/\tcontainer/' || true
    } | awk -F '\t' '{ seen[$1]=$2 } END { for (k in seen) printf "%s\t%s\n", k, seen[k] }' | sort
  fi
}

cmd_ls_shared() {
  need_tools
  remote_file_exists "$(shared_store)" && remote_cat "$(shared_store)" | top_level_keys || true
}

cmd_get() {
  local vmid="$1" name="$2"
  need_tools
  sops_get_remote "$(container_store "$vmid")" "$name" \
    || sops_get_remote "$(shared_store)" "$name" \
    || die "secret not found for vmid=${vmid}: $name"
}

cmd_get_shared() {
  local name="$1"
  need_tools
  sops_get_remote "$(shared_store)" "$name" \
    || die "shared secret not found: $name"
}

cmd_set() {
  local vmid="$1" name="$2" value recipients
  need_tools
  value="$(read_secret_value)"
  recipients="$(container_recipients "$vmid")"
  sops_set_remote "$(container_store "$vmid")" "$recipients" "$name" "$value"
  info "Set: vmid=${vmid} name=${name}"
}

cmd_set_shared() {
  local name="$1" value recipients
  need_tools
  value="$(read_secret_value)"
  recipients="$(shared_recipients)"
  sops_set_remote "$(shared_store)" "$recipients" "$name" "$value"
  info "Set shared: name=${name}"
}

cmd_rm() {
  local vmid="$1" name="$2"
  need_tools
  sops_unset_remote "$(container_store "$vmid")" "$name"
  info "Removed: vmid=${vmid} name=${name}"
}

cmd_rm_shared() {
  local name="$1"
  need_tools
  sops_unset_remote "$(shared_store)" "$name"
  info "Removed shared: name=${name}"
}

cmd_rotate() {
  local vmid="$1" recipients
  need_tools
  recipients="$(container_recipients "$vmid")"
  reencrypt_remote "$(container_store "$vmid")" "$recipients"
  info "Rotated store: vmid=${vmid}"
}

cmd_rotate_shared() {
  local recipients
  need_tools
  recipients="$(shared_recipients)"
  reencrypt_remote "$(shared_store)" "$recipients"
  info "Rotated shared store"
}

cmd_init_shared() {
  need_tools
  if remote_file_exists "$(shared_identity_path)"; then
    die "shared keypair already exists"
  fi

  local tmp priv pub
  tmp="$(mktemp -d)"
  age-keygen -o "$tmp/identity.txt" 2>/dev/null
  priv="$(cat "$tmp/identity.txt")"
  pub="$(sed -n 's/^# public key: //p' "$tmp/identity.txt" | head -n1)"
  rm -rf "$tmp"

  printf '%s\n' "$priv" | remote_write "$(shared_identity_path)"
  printf '%s\n' "$pub" | remote_write "$(shared_pubkey_path)"
  info "Initialized shared age keypair"
  info "Public key: ${pub}"
}

[[ $# -ge 1 ]] || usage
CMD="$1"; shift

case "$CMD" in
  ls) [[ $# -le 1 ]] || usage; cmd_ls "$@" ;;
  ls-shared) [[ $# -eq 0 ]] || usage; cmd_ls_shared ;;
  get) [[ $# -eq 2 ]] || usage; cmd_get "$@" ;;
  get-shared) [[ $# -eq 1 ]] || usage; cmd_get_shared "$@" ;;
  set) [[ $# -eq 2 ]] || usage; cmd_set "$@" ;;
  set-shared) [[ $# -eq 1 ]] || usage; cmd_set_shared "$@" ;;
  rm) [[ $# -eq 2 ]] || usage; cmd_rm "$@" ;;
  rm-shared) [[ $# -eq 1 ]] || usage; cmd_rm_shared "$@" ;;
  rotate) [[ $# -eq 1 ]] || usage; cmd_rotate "$@" ;;
  rotate-shared) [[ $# -eq 0 ]] || usage; cmd_rotate_shared ;;
  init-shared) [[ $# -eq 0 ]] || usage; cmd_init_shared ;;
  *) usage ;;
esac
