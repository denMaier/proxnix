#!/bin/bash
# proxnix-secrets — Workstation/admin command for local proxnix secret stores.
#
# This command is authoritative for the workstation-owned proxnix site repo.
# It manages encrypted secret stores plus encrypted private identities locally.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/proxnix-workstation-common.sh"
load_proxnix_workstation_config

die() { echo "error: $*" >&2; exit 1; }
info() { echo "$*"; }

usage() {
  cat >&2 <<EOF
Usage:
  $(basename "$0") ls [<vmid>]
  $(basename "$0") ls-shared
  $(basename "$0") get             <vmid> <name>
  $(basename "$0") get-shared      <name>
  $(basename "$0") set             <vmid> <name>
  $(basename "$0") set-shared      <name>
  $(basename "$0") rm              <vmid> <name>
  $(basename "$0") rm-shared       <name>
  $(basename "$0") rotate          <vmid>
  $(basename "$0") rotate-shared
  $(basename "$0") init-host-relay
  $(basename "$0") init-container  <vmid>
  $(basename "$0") init-shared

Config: $CONFIG_FILE
  PROXNIX_SITE_DIR         Local proxnix site repo
  PROXNIX_MASTER_IDENTITY  Local SSH private key used by SOPS
EOF
  exit 1
}

need_tools() {
  proxnix_need_site_tools
}

ensure_secret_parent_dir() {
  local path="$1" dir
  dir="$(dirname "$path")"
  mkdir -p "$dir"
  find "$(proxnix_site_private_dir)" -type d -exec chmod 700 {} +
}

create_identity_store() (
  local store="$1" label="$2" tmpdir plain_yaml encrypted pubkey
  [[ -f "$store" ]] && die "${label} keypair already exists"

  ensure_secret_parent_dir "$store"

  tmpdir="$(mktemp -d /tmp/proxnix-identity.XXXXXX)"
  plain_yaml="$(mktemp /tmp/proxnix-identity.XXXXXX.yaml)"
  encrypted="$(mktemp /tmp/proxnix-identity.XXXXXX.sops.yaml)"
  trap 'rm -rf "$tmpdir"; rm -f "$plain_yaml" "$encrypted"' EXIT

  ssh-keygen -q -t ed25519 -N "" -f "${tmpdir}/identity" >/dev/null
  proxnix_write_identity_file_payload "${tmpdir}/identity" "$plain_yaml"
  proxnix_with_master_key sops --encrypt --age "$(proxnix_master_recipient)" \
    --input-type yaml --output-type yaml "$plain_yaml" > "$encrypted"
  install -m 600 "$encrypted" "$store"
  pubkey="$(tr -d '\r\n' < "${tmpdir}/identity.pub")"

  rm -rf "$tmpdir"
  rm -f "$plain_yaml" "$encrypted"
  trap - EXIT

  info "Initialized ${label} SSH-backed age keypair"
  info "Public key: ${pubkey}"
)

ensure_host_relay_identity() {
  local store
  store="$(proxnix_site_host_relay_identity_store)"
  if [[ ! -f "$store" ]]; then
    create_identity_store "$store" "host relay"
  fi
}

ensure_container_identity() {
  local vmid="$1" store
  store="$(proxnix_site_container_identity_store "$vmid")"
  if [[ ! -f "$store" ]]; then
    create_identity_store "$store" "container ${vmid}"
  fi
}

ensure_shared_identity() {
  local store
  store="$(proxnix_site_shared_identity_store)"
  if [[ ! -f "$store" ]]; then
    create_identity_store "$store" "shared"
  fi
}

container_recipients() {
  local vmid="$1"
  ensure_container_identity "$vmid"
  printf '%s,%s' \
    "$(proxnix_identity_public_key_from_store "$(proxnix_site_container_identity_store "$vmid")")" \
    "$(proxnix_master_recipient)"
}

shared_recipients() {
  ensure_shared_identity
  printf '%s,%s' \
    "$(proxnix_identity_public_key_from_store "$(proxnix_site_shared_identity_store)")" \
    "$(proxnix_master_recipient)"
}

ensure_store() (
  local path="$1" recipients="$2" tmp out
  [[ -f "$path" ]] && return 0

  ensure_secret_parent_dir "$path"
  tmp="$(mktemp /tmp/proxnix-secrets.XXXXXX.yaml)"
  out="$(mktemp /tmp/proxnix-secrets.XXXXXX.sops.yaml)"
  trap 'rm -f "$tmp" "$out"' EXIT
  printf '{}\n' > "$tmp"
  proxnix_with_master_key sops --encrypt --age "$recipients" \
    --input-type yaml --output-type yaml "$tmp" > "$out"
  install -m 600 "$out" "$path"
  rm -f "$tmp" "$out"
  trap - EXIT
)

sops_set_local() (
  local path="$1" recipients="$2" name="$3" value="$4" tmp
  tmp="$(mktemp /tmp/proxnix-secrets-store.XXXXXX.sops.yaml)"
  trap 'rm -f "$tmp"' EXIT
  ensure_store "$path" "$recipients"
  cp "$path" "$tmp"
  proxnix_sops_encode_value "$value" | proxnix_with_master_key sops set \
    --input-type yaml --output-type yaml --value-stdin "$tmp" \
    "$(proxnix_sops_path "$name")"
  install -m 600 "$tmp" "$path"
  rm -f "$tmp"
  trap - EXIT
)

sops_unset_local() (
  local path="$1" name="$2" tmp
  [[ -f "$path" ]] || return 0
  tmp="$(mktemp /tmp/proxnix-secrets-store.XXXXXX.sops.yaml)"
  trap 'rm -f "$tmp"' EXIT
  cp "$path" "$tmp"
  proxnix_with_master_key sops unset --input-type yaml --output-type yaml "$tmp" \
    "$(proxnix_sops_path "$name")" || true
  install -m 600 "$tmp" "$path"
  rm -f "$tmp"
  trap - EXIT
)

sops_get_local() (
  local path="$1" name="$2" tmp
  [[ -f "$path" ]] || return 1
  tmp="$(mktemp /tmp/proxnix-secrets-store.XXXXXX.sops.yaml)"
  trap 'rm -f "$tmp"' EXIT
  cp "$path" "$tmp"
  proxnix_with_master_key sops decrypt --input-type yaml --extract \
    "$(proxnix_sops_path "$name")" "$tmp"
  rm -f "$tmp"
  trap - EXIT
)

reencrypt_local() (
  local path="$1" recipients="$2" tmp plain encrypted
  [[ -f "$path" ]] || die "store not found: $path"
  tmp="$(mktemp /tmp/proxnix-secrets-store.XXXXXX.sops.yaml)"
  plain="$(mktemp /tmp/proxnix-secrets.XXXXXX.yaml)"
  encrypted="$(mktemp /tmp/proxnix-secrets.XXXXXX.sops.yaml)"
  trap 'rm -f "$tmp" "$plain" "$encrypted"' EXIT
  cp "$path" "$tmp"
  proxnix_with_master_key sops decrypt --input-type yaml --output-type yaml "$tmp" > "$plain"
  proxnix_with_master_key sops --encrypt --age "$recipients" \
    --input-type yaml --output-type yaml "$plain" > "$encrypted"
  install -m 600 "$encrypted" "$path"
  rm -f "$tmp" "$plain" "$encrypted"
  trap - EXIT
)

cmd_ls() {
  need_tools
  if [[ $# -eq 0 ]]; then
    [[ -d "$(proxnix_site_private_dir)" ]] || return 0
    find "$(proxnix_site_private_dir)" -name secrets.sops.yaml -type f -print | while IFS= read -r f; do
      if [[ "$f" == */shared/secrets.sops.yaml ]]; then
        cat "$f" | proxnix_top_level_keys | sed 's/^/shared\t/'
      elif [[ "$f" == */containers/*/secrets.sops.yaml ]]; then
        vmid="${f#*/containers/}"
        vmid="${vmid%%/*}"
        cat "$f" | proxnix_top_level_keys | sed "s/^/${vmid}\t/"
      fi
    done | sort
  else
    local vmid="$1"
    {
      [[ -f "$(proxnix_site_shared_store)" ]] \
        && cat "$(proxnix_site_shared_store)" | proxnix_top_level_keys | sed 's/$/\tshared/' \
        || true
      [[ -f "$(proxnix_site_container_store "$vmid")" ]] \
        && cat "$(proxnix_site_container_store "$vmid")" | proxnix_top_level_keys | sed 's/$/\tcontainer/' \
        || true
    } | awk -F '\t' '{ seen[$1]=$2 } END { for (k in seen) printf "%s\t%s\n", k, seen[k] }' | sort
  fi
}

cmd_ls_shared() {
  need_tools
  [[ -f "$(proxnix_site_shared_store)" ]] \
    && cat "$(proxnix_site_shared_store)" | proxnix_top_level_keys \
    || true
}

cmd_get() {
  local vmid="$1" name="$2"
  need_tools
  sops_get_local "$(proxnix_site_container_store "$vmid")" "$name" \
    || sops_get_local "$(proxnix_site_shared_store)" "$name" \
    || die "secret not found for vmid=${vmid}: $name"
}

cmd_get_shared() {
  local name="$1"
  need_tools
  sops_get_local "$(proxnix_site_shared_store)" "$name" \
    || die "shared secret not found: $name"
}

cmd_set() {
  local vmid="$1" name="$2" value recipients
  need_tools
  value="$(proxnix_read_secret_value)"
  recipients="$(container_recipients "$vmid")"
  sops_set_local "$(proxnix_site_container_store "$vmid")" "$recipients" "$name" "$value"
  info "Set: vmid=${vmid} name=${name}"
}

cmd_set_shared() {
  local name="$1" value recipients
  need_tools
  value="$(proxnix_read_secret_value)"
  recipients="$(shared_recipients)"
  sops_set_local "$(proxnix_site_shared_store)" "$recipients" "$name" "$value"
  info "Set shared: name=${name}"
}

cmd_rm() {
  local vmid="$1" name="$2"
  need_tools
  sops_unset_local "$(proxnix_site_container_store "$vmid")" "$name"
  info "Removed: vmid=${vmid} name=${name}"
}

cmd_rm_shared() {
  local name="$1"
  need_tools
  sops_unset_local "$(proxnix_site_shared_store)" "$name"
  info "Removed shared: name=${name}"
}

cmd_rotate() {
  local vmid="$1" recipients
  need_tools
  recipients="$(container_recipients "$vmid")"
  reencrypt_local "$(proxnix_site_container_store "$vmid")" "$recipients"
  info "Rotated store: vmid=${vmid}"
}

cmd_rotate_shared() {
  local recipients
  need_tools
  recipients="$(shared_recipients)"
  reencrypt_local "$(proxnix_site_shared_store)" "$recipients"
  info "Rotated shared store"
}

cmd_init_host_relay() {
  need_tools
  create_identity_store "$(proxnix_site_host_relay_identity_store)" "host relay"
}

cmd_init_shared() {
  need_tools
  create_identity_store "$(proxnix_site_shared_identity_store)" "shared"
}

cmd_init_container() {
  local vmid="$1"
  need_tools
  create_identity_store "$(proxnix_site_container_identity_store "$vmid")" "container ${vmid}"
}

[[ $# -ge 1 ]] || usage
CMD="$1"; shift

case "$CMD" in
  ls) [[ $# -le 1 ]] || usage; cmd_ls "$@" ;;
  ls-shared) [[ $# -eq 0 ]] || usage; cmd_ls_shared ;;
  get) [[ $# -eq 2 ]] || usage; cmd_get "$@" ;;
  get-shared) [[ $# -eq 1 ]] || usage; cmd_get_shared "$@" ;;
  set) [[ $# -eq 2 ]] || usage; cmd_set "$@" ;;
  set-shared) [[ $# -eq 1 ]] || usage; cmd_set_shared "$@" ;;
  rm) [[ $# -eq 2 ]] || usage; cmd_rm "$@" ;;
  rm-shared) [[ $# -eq 1 ]] || usage; cmd_rm_shared "$@" ;;
  rotate) [[ $# -eq 1 ]] || usage; cmd_rotate "$@" ;;
  rotate-shared) [[ $# -eq 0 ]] || usage; cmd_rotate_shared ;;
  init-host-relay) [[ $# -eq 0 ]] || usage; cmd_init_host_relay ;;
  init-container) [[ $# -eq 1 ]] || usage; cmd_init_container "$@" ;;
  init-shared) [[ $# -eq 0 ]] || usage; cmd_init_shared ;;
  *) usage ;;
esac
